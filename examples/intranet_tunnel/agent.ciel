import /std/async as async;
import /std/async_net as anet;
import /std/io as io;
import /std/meta as meta;
import /std/net as net;
import /std/result;
import ./cli as cli;
import ./protocol/auth as auth;
import ./protocol/codec as tunnel_codec;
import ./protocol/frame as frame;
import ./runtime as rt;

struct AgentControlState {
    async::Sender<anet::Bytes> writer;
    rt::StreamRegistry streams;
    net::SocketAddr target_addr;
}

Error agent_auth_error() {
    return text_error("tunnel-agent failed to authenticate");
}

async Result<void, Error> agent_control_writer(
    anet::AsyncTcpStream stream,
    async::Receiver<anet::Bytes> receiver
) {
    while (true) {
        _ next = await async::recv<anet::Bytes>(receiver);
        switch (next) {
            case Ok(bytes):
                _ wrote = await anet::write_all(stream, bytes);
                switch (wrote) {
                    case Ok:
                        {}
                    case Err(error):
                        rt::close_stream_silent(stream);
                        return Err(error);
                }
            case Err(_):
                rt::close_stream_silent(stream);
                return Ok;
        }
    }
    return Ok;
}

async Result<void, Error> handle_agent_handshake(
    anet::BufferedStreamReader reader,
    async::Sender<anet::Bytes> writer,
    rt::AuthConfig auth_config
) {
    io::eprintln_value("tunnel-agent: sending hello")?;
    []const char route = rt::auth_config_route(&auth_config)?;
    []u8 psk = rt::auth_config_psk(&auth_config)?;
    []u8 hello_payload =
        auth::encode_hello(
            route,
            psk
        )?;
    io::eprintln("tunnel-agent: hello payload {} bytes", [hello_payload.len])?;
    anet::Bytes hello_frame =
        rt::encode_frame_from_slice(frame::Hello, 0 as u32, hello_payload)?;
    await rt::send_control_bytes(writer, hello_frame)?;

    rt::AsyncFrame response = await rt::read_frame(reader)?;
    if (rt::kind_is(response.kind, frame::HelloOk)) {
        []u8 payload = rt::bytes_to_slice(response.payload)?;
        auth::decode_hello_ok(payload)?;
        io::eprintln_value("tunnel-agent: authenticated")?;
        return Ok;
    }
    if (rt::kind_is(response.kind, frame::ErrorFrame)) {
        io::eprintln_value("tunnel-agent: authentication rejected")?;
        return Err(agent_auth_error());
    }
    return Err(text_error("protocol error: expected HelloOk or Error"));
}

void agent_stream_cleanup(
    u32 stream_id,
    anet::AsyncTcpStream target,
    AgentControlState control
) {
    rt::close_stream_silent(target);
    rt::stream_registry_remove_close(control.streams, stream_id);
}

Result<void, Error> remove_agent_stream(AgentControlState control, u32 stream_id) {
    return rt::stream_registry_remove_close(control.streams, stream_id);
}

async Result<void, Error> send_agent_open_result_error(
    AgentControlState control,
    u32 stream_id,
    u16 code,
    []const char message
) {
    []u8 failure = tunnel_codec::encode_open_result_error(code, message)?;
    anet::Bytes failure_frame =
        rt::encode_frame_from_slice(frame::OpenResult, stream_id, failure)?;
    []u8 close_payload = tunnel_codec::encode_close_reason(code, message)?;
    anet::Bytes close_frame =
        rt::encode_frame_from_slice(frame::CloseStream, stream_id, close_payload)?;
    await rt::send_control_bytes(control.writer, failure_frame)?;
    await rt::send_control_bytes(control.writer, close_frame)?;
    return Ok;
}

async Result<void, Error> agent_stream_worker(
    u32 stream_id,
    AgentControlState control,
    async::Receiver<meta::Repr<rt::StreamEvent>> receiver,
    async::Sender<meta::Repr<rt::StreamEvent>> local_events
) {
    _ connected = await anet::connect_timeout(control.target_addr, 2000);
    switch (connected) {
        case Ok(target):
            defer agent_stream_cleanup(stream_id, target, control);

            []u8 success = tunnel_codec::encode_open_result_success()?;
            anet::Bytes success_frame =
                rt::encode_frame_from_slice(frame::OpenResult, stream_id, success)?;
            await rt::send_control_bytes(control.writer, success_frame)?;
            _ reader = rt::spawn_local_reader(stream_id, target, control.writer, local_events)?;

            bool @remote_write_closed = false;
            bool @local_write_closed = false;
            while (true) {
                _ next = await async::recv<meta::Repr<rt::StreamEvent>>(receiver);
                switch (next) {
                    case Ok(event_message):
                        rt::StreamEvent event = rt::stream_event_from_message(event_message);
                        switch (event) {
                            case rt::StreamLocalFailed(message):
                                await rt::send_close_stream_text(
                                    control.writer,
                                    stream_id,
                                    102 as u16,
                                    message
                                )?;
                                return Ok;
                            case rt::StreamLocalClosed:
                                local_write_closed = true;
                                await rt::send_control_empty(
                                    control.writer,
                                    frame::CloseWrite,
                                    stream_id
                                )?;
                                if (remote_write_closed) {
                                    return Ok;
                                }
                            case rt::StreamFrame(incoming):
                                if (rt::kind_is(incoming.kind, frame::Data)) {
                                    _ wrote = await anet::write_all(target, incoming.payload);
                                    switch (wrote) {
                                        case Ok:
                                            {}
                                        case Err(_):
                                            await rt::send_close_stream(
                                                control.writer,
                                                stream_id,
                                                101 as u16,
                                                "target write failed"
                                            )?;
                                            return Ok;
                                    }
                                } else if (rt::kind_is(incoming.kind, frame::CloseWrite)) {
                                    remote_write_closed = true;
                                    anet::shutdown_write(target);
                                    if (local_write_closed) {
                                        return Ok;
                                    }
                                } else if (rt::kind_is(incoming.kind, frame::CloseStream)) {
                                    return Ok;
                                } else {
                                    return Ok;
                                }
                        }
                    case Err(_):
                        return Ok;
                }
            }
        case Err(_):
            io::eprintln("tunnel-agent: stream {} target connect failed", [stream_id])?;
            await send_agent_open_result_error(
                control,
                stream_id,
                100 as u16,
                "target dial failed"
            )?;
            remove_agent_stream(control, stream_id)?;
            return Ok;
    }
    return Ok;
}

async Result<void, Error> agent_control_reader(
    anet::BufferedStreamReader reader,
    AgentControlState control
) {
    while (true) {
        Result<rt::AsyncFrame, Error> read = await rt::read_frame(reader);
        switch (read) {
            case Ok(incoming):
                if (rt::kind_is(incoming.kind, frame::OpenStream)) {
                    if (anet::bytes_len(incoming.payload) != 0) {
                        async::close<anet::Bytes>(control.writer)?;
                        rt::stream_registry_close_all(control.streams)?;
                        return Err(text_error("protocol error: malformed OpenStream"));
                    }
                    _ events = async::channel<meta::Repr<rt::StreamEvent>>(64)?;
                    rt::stream_registry_insert(control.streams, incoming.stream_id, events.sender)?;
                    _ worker = async::spawn<void>(agent_stream_worker(
                        incoming.stream_id,
                        control,
                        events.receiver,
                        events.sender
                    ))?;
                } else if (
                    rt::kind_is(incoming.kind, frame::Data) ||
                    rt::kind_is(incoming.kind, frame::CloseWrite) ||
                    rt::kind_is(incoming.kind, frame::CloseStream)
                ) {
                    rt::StreamRegistryGet found =
                        rt::stream_registry_get(control.streams, incoming.stream_id)?;
                    switch (found) {
                        case rt::StreamRegistryFound(sender):
                            await rt::send_stream_event(sender, rt::StreamFrame(incoming))?;
                        case rt::StreamRegistryMissing:
                            if (rt::kind_is(incoming.kind, frame::Data)) {
                                await rt::send_close_stream(
                                    control.writer,
                                    incoming.stream_id,
                                    20 as u16,
                                    "unknown stream"
                                )?;
                            }
                    }
                } else if (rt::kind_is(incoming.kind, frame::Ping)) {
                    await rt::send_control_empty(control.writer, frame::Pong, 0 as u32)?;
                } else if (rt::kind_is(incoming.kind, frame::Pong)) {
                    {}
                } else {
                    io::eprintln_value(
                        "tunnel-agent: protocol error: illegal control frame"
                    )?;
                    async::close<anet::Bytes>(control.writer)?;
                    rt::stream_registry_close_all(control.streams)?;
                    return Err(text_error("protocol error: illegal agent control frame"));
                }
            case Err(error):
                io::eprintln("tunnel-agent: control read error: {}", [error])?;
                async::close<anet::Bytes>(control.writer)?;
                rt::stream_registry_close_all(control.streams)?;
                return Ok;
        }
    }
    return Ok;
}

async Result<void, Error> run_agent_async(
    net::SocketAddr server_addr,
    net::SocketAddr target_addr,
    rt::AuthConfig auth_config
) {
    anet::AsyncTcpStream control_stream = await anet::connect(server_addr)?;
    anet::AsyncTcpSplit split = anet::split(control_stream)?;
    anet::BufferedStreamReader reader =
        anet::buffered_reader(split.read, frame::max_payload_len())?;
    async::ChannelPair<anet::Bytes> control_channel = async::channel<anet::Bytes>(128)?;
    _ control_writer =
        async::spawn<void>(agent_control_writer(control_stream, control_channel.receiver))?;

    io::eprintln_value("tunnel-agent: control connected")?;
    _ handshaken = await handle_agent_handshake(reader, control_channel.sender, auth_config);
    switch (handshaken) {
        case Ok:
            {}
        case Err(error):
            async::close<anet::Bytes>(control_channel.sender)?;
            return Err(error);
    }

    AgentControlState control = {
        writer: control_channel.sender,
        streams: rt::stream_registry_new()?,
        target_addr: target_addr
    };
    return await agent_control_reader(reader, control);
}

export Result<void, Error> run_agent() {
    cli::AgentConfig config = cli::parse_agent_args()?;
    rt::AuthConfig auth_config = rt::auth_config_new(config.route, config.psk)?;
    return async::block_on(run_agent_async(
        config.server_addr,
        config.target_addr,
        auth_config
    ));
}
