import /std/io as io;
import /std/result;
import ./cli as cli;
import ./error as app_error;
import ./server as server;

i32 main() {
    Result<cli::ServerConfig, app_error::TunnelError> parsed =
        cli::parse_server_args();
    switch (parsed) {
        case Ok(_):
            Result<void, app_error::TunnelError> run = server::run_server();
            switch (run) {
                case Ok:
                    return 0;
                case Err(error):
                    io::eprintln("tunnel-server: {}", [error]);
                    return 1;
            }
        case Err(error):
            io::eprintln("{}", [error]);
            io::eprintln_value(cli::server_usage());
            return 2;
    }
}
