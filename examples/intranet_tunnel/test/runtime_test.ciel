import /std/async_net as anet;
import /std/result;
import /intranet_tunnel/protocol/codec as tunnel_codec;
import /intranet_tunnel/protocol/frame as frame;
import /intranet_tunnel/runtime as rt;

bool bytes_equal_text([]const u8 bytes, []const char text) {
    if (bytes.len != text.len) {
        return false;
    }
    usize @i = 0;
    while (i < bytes.len) {
        if (bytes[i] != (text[i] as u8)) {
            return false;
        }
        i = i + 1;
    }
    return true;
}

bool read_result_need_more(rt::FrameReadResult value) {
    switch (value) {
        case rt::NeedMore:
            return true;
        case rt::FrameReady(_):
            return false;
    }
}

bool frame_matches(rt::FrameReadResult value, frame::FrameKind kind, u32 stream_id, []const u8 payload) {
    switch (value) {
        case rt::NeedMore:
            return false;
        case rt::FrameReady(incoming):
            if (!rt::kind_is(incoming.kind, kind)) {
                return false;
            }
            if (incoming.stream_id != stream_id) {
                return false;
            }
            []u8 got = must(rt::bytes_to_slice(incoming.payload));
            if (got.len != payload.len) {
                return false;
            }
            usize @i = 0;
            while (i < got.len) {
                if (got[i] != payload[i]) {
                    return false;
                }
                i = i + 1;
            }
            return true;
    }
}

i32 main() {
    []u8 ok_payload = must(tunnel_codec::encode_open_result_success());
    tunnel_codec::OpenResultPayload ok = must(tunnel_codec::decode_open_result(ok_payload));
    if (!ok.ok || ok.message.len != 0) {
        return 1;
    }

    []u8 fail_payload = must(tunnel_codec::encode_open_result_error(77 as u16, "dial failed"));
    tunnel_codec::OpenResultPayload fail = must(tunnel_codec::decode_open_result(fail_payload));
    if (fail.ok || fail.code != (77 as u16) || !bytes_equal_text(fail.message, "dial failed")) {
        return 2;
    }

    []u8 close_payload = must(tunnel_codec::encode_close_reason(9 as u16, "done"));
    tunnel_codec::CloseReason close = must(tunnel_codec::decode_close_reason(close_payload));
    if (close.code != (9 as u16) || !bytes_equal_text(close.message, "done")) {
        return 3;
    }

    [1]u8 empty = [0;];
    tunnel_codec::CloseReason empty_close = must(tunnel_codec::decode_close_reason(empty[..0]));
    if (empty_close.code != (0 as u16) || empty_close.message.len != 0) {
        return 4;
    }

    rt::FrameReader @reader = must(rt::frame_reader_new());
    []u8 first_payload = [10 as u8, 11 as u8, 12 as u8];
    anet::Bytes first_encoded =
        must(rt::encode_frame_from_slice(frame::Data, 42 as u32, first_payload));
    []u8 first_frame = must(rt::bytes_to_slice(first_encoded));
    must(rt::frame_reader_push(&reader, must(anet::bytes_copy(first_frame[..5]))));
    if (!read_result_need_more(must(rt::frame_reader_next(&reader)))) {
        return 5;
    }
    must(rt::frame_reader_push(&reader, must(anet::bytes_copy(first_frame[5..]))));
    if (!frame_matches(must(rt::frame_reader_next(&reader)), frame::Data, 42 as u32, first_payload)) {
        return 6;
    }
    if (!read_result_need_more(must(rt::frame_reader_next(&reader)))) {
        return 7;
    }

    []u8 second_payload = [1 as u8, 2 as u8];
    anet::Bytes second_encoded =
        must(rt::encode_frame_from_slice(frame::Data, 7 as u32, second_payload));
    anet::Bytes third_encoded =
        must(rt::encode_frame_from_slice(frame::CloseWrite, 7 as u32, empty[..0]));
    []u8 second_frame = must(rt::bytes_to_slice(second_encoded));
    []u8 third_frame = must(rt::bytes_to_slice(third_encoded));
    must(rt::frame_reader_push(&reader, must(anet::bytes_copy(second_frame))));
    must(rt::frame_reader_push(&reader, must(anet::bytes_copy(third_frame))));
    if (!frame_matches(must(rt::frame_reader_next(&reader)), frame::Data, 7 as u32, second_payload)) {
        return 8;
    }
    if (!frame_matches(must(rt::frame_reader_next(&reader)), frame::CloseWrite, 7 as u32, empty[..0])) {
        return 9;
    }
    if (!read_result_need_more(must(rt::frame_reader_next(&reader)))) {
        return 10;
    }

    return 0;
}
