export async Result<AsyncTcpStream, Error> accept(AsyncTcpListener listener) {
    AsyncAccept op = accept_async(listener)?;
    return await flow::future_from_op<AsyncAccept, AsyncTcpStream>(op);
}

export async Result<AsyncTcpStream, Error> connect(net::SocketAddr addr) {
    AsyncConnect op = connect_async(addr)?;
    return await flow::future_from_op<AsyncConnect, AsyncTcpStream>(op);
}

export async Result<Bytes, Error> read(AsyncTcpStream stream, usize max_len) {
    AsyncTcpRead op = read_bytes(stream, max_len)?;
    return await flow::future_from_op<AsyncTcpRead, Bytes>(op);
}

export async Result<ReadIntoResult, Error> read_into(AsyncTcpStream stream, Bytes buffer) {
    AsyncTcpRead op = read_into_async(stream, buffer)?;
    return await flow::future_from_op<AsyncTcpRead, ReadIntoResult>(op);
}

export async Result<usize, Error> write(AsyncTcpStream stream, Bytes data) {
    AsyncTcpWrite op = write_bytes(stream, data)?;
    return await flow::future_from_op<AsyncTcpWrite, usize>(op);
}

export async Result<usize, Error> write_half(AsyncTcpWriteHalf half, Bytes data) {
    AsyncTcpWrite op = write_half_bytes(half, data)?;
    return await flow::future_from_op<AsyncTcpWrite, usize>(op);
}

export async Result<void, Error> write_all(AsyncTcpStream stream, Bytes data) {
    usize written = await write(stream, data)?;
    if (written != bytes_len(data)) {
        return Err(text_error("short tcp write"));
    }
    return Ok;
}

export async Result<void, Error> write_all_half(AsyncTcpWriteHalf half, Bytes data) {
    usize written = await write_half(half, data)?;
    if (written != bytes_len(data)) {
        return Err(text_error("short tcp write"));
    }
    return Ok;
}

export async Result<Bytes, Error> read_buffered(
    BufferedStreamReader reader,
    usize max_len
) {
    AsyncBufferedRead op = read_buffered_async(reader, max_len)?;
    return await flow::future_from_op<AsyncBufferedRead, Bytes>(op);
}

export Result<void, Error> notify_accept_done<M: Message>(
    *const AsyncAccept op,
    *const actor::Actor<M> actor_handle,
    M message
) {
    *void boxed = box_message(message)?;
    c::c_int rc = unsafe { ciel_async_tcp_notify_accept(raw_accept(*op), actor_handle->handle as *CielActor, boxed) };
    if ((rc as i64) != 0) {
        return Err(code_error(rc as i64));
    }
    return Ok;
}

export Result<void, Error> notify_connect_done<M: Message>(
    *const AsyncConnect op,
    *const actor::Actor<M> actor_handle,
    M message
) {
    *void boxed = box_message(message)?;
    c::c_int rc = unsafe { ciel_async_tcp_notify_connect(raw_connect(*op), actor_handle->handle as *CielActor, boxed) };
    if ((rc as i64) != 0) {
        return Err(code_error(rc as i64));
    }
    return Ok;
}

export Result<void, Error> notify_read_done<M: Message>(
    *const AsyncTcpRead op,
    *const actor::Actor<M> actor_handle,
    M message
) {
    *void boxed = box_message(message)?;
    c::c_int rc = unsafe { ciel_async_notify_read(raw_read(*op), actor_handle->handle as *CielActor, boxed) };
    if ((rc as i64) != 0) {
        return Err(code_error(rc as i64));
    }
    return Ok;
}

export Result<void, Error> notify_write_done<M: Message>(
    *const AsyncTcpWrite op,
