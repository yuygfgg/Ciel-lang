unsafe impl abort_future(*AsyncAccept op) {
    return cancel_accept(*op);
}

unsafe impl abort_future(*AsyncConnect op) {
    return cancel_connect(*op);
}

unsafe impl abort_future(*AsyncTcpRead op) {
    return cancel_read(*op);
}

unsafe impl abort_future(*AsyncTcpWrite op) {
    return cancel_write(*op);
}

unsafe impl abort_future(*AsyncBufferedRead op) {
    return cancel_buffered_read(*op);
}

export Result<flow::Completion<S, AsyncTcpStream>, Error> accept_completion<S: Message>(
    AsyncTcpListener listener
) {
    AsyncAccept op = accept_async(listener)?;
    return Ok(flow::completion_from_op<S, AsyncTcpStream, AsyncAccept>(op));
}

export Result<flow::Completion<S, AsyncTcpStream>, Error> connect_completion<S: Message>(
    net::SocketAddr addr
) {
    AsyncConnect op = connect_async(addr)?;
    return Ok(flow::completion_from_op<S, AsyncTcpStream, AsyncConnect>(op));
}

export Result<flow::Completion<S, Bytes>, Error> read_bytes_completion<S: Message>(
    AsyncTcpStream stream,
    usize max_len
) {
    AsyncTcpRead op = read_bytes(stream, max_len)?;
    return Ok(flow::completion_from_op<S, Bytes, AsyncTcpRead>(op));
}

export Result<flow::Completion<S, usize>, Error> write_bytes_completion<S: Message>(
    AsyncTcpStream stream,
    Bytes data
) {
    AsyncTcpWrite op = write_bytes(stream, data)?;
    return Ok(flow::completion_from_op<S, usize, AsyncTcpWrite>(op));
}

export Result<flow::AsyncTask<S, AsyncTcpStream>, Error> accept_task<S: Message>(
    AsyncTcpListener listener
) {
    flow::Completion<S, AsyncTcpStream> completion = accept_completion<S>(listener)?;
    return Ok(flow::from_completion<S, AsyncTcpStream>(completion));
}

export Result<flow::AsyncTask<S, AsyncTcpStream>, Error> connect_task<S: Message>(
    net::SocketAddr addr
) {
    flow::Completion<S, AsyncTcpStream> completion = connect_completion<S>(addr)?;
    return Ok(flow::from_completion<S, AsyncTcpStream>(completion));
}

export Result<flow::AsyncTask<S, Bytes>, Error> read_bytes_task<S: Message>(
    AsyncTcpStream stream,
    usize max_len
) {
    flow::Completion<S, Bytes> completion = read_bytes_completion<S>(stream, max_len)?;
    return Ok(flow::from_completion<S, Bytes>(completion));
}

export Result<flow::AsyncTask<S, usize>, Error> write_bytes_task<S: Message>(
    AsyncTcpStream stream,
    Bytes data
) {
    flow::Completion<S, usize> completion = write_bytes_completion<S>(stream, data)?;
    return Ok(flow::from_completion<S, usize>(completion));
}

impl<M: Message> notify_done(
    AsyncAccept op,
    actor::Actor<M> actor_handle,
    M message
) {
    return notify_accept_done(&op, &actor_handle, message);
}

impl finish<AsyncTcpStream>(AsyncAccept op) {
    return finish_accept(op);
}

unsafe impl poll_done<AsyncTcpStream>(AsyncAccept op, *AsyncTcpStream out) {
    ?*CielAsyncFd @raw = null;
    c::c_int rc = unsafe { ciel_async_tcp_finish_accept(raw_accept(op), &raw) };
    if ((rc as i64) == 0) {
        if (raw == null) {
            return 5 as c::c_int;
        }
        out->handle = raw as *void;
    }
    return rc;
}

impl<M: Message> notify_done(
    AsyncConnect op,
    actor::Actor<M> actor_handle,
    M message
) {
    return notify_connect_done(&op, &actor_handle, message);
}

impl finish<AsyncTcpStream>(AsyncConnect op) {
    return finish_connect(op);
}

unsafe impl poll_done<AsyncTcpStream>(AsyncConnect op, *AsyncTcpStream out) {
    ?*CielAsyncFd @raw = null;
    c::c_int rc = unsafe { ciel_async_tcp_finish_connect(raw_connect(op), &raw) };
    if ((rc as i64) == 0) {
        if (raw == null) {
            return 5 as c::c_int;
        }
        out->handle = raw as *void;
    }
    return rc;
}

impl<M: Message> notify_done(
    AsyncTcpRead op,
    actor::Actor<M> actor_handle,
    M message
) {
    return notify_read_done(&op, &actor_handle, message);
}

impl finish<Bytes>(AsyncTcpRead op) {
    return finish_read(op);
}

unsafe impl poll_done<Bytes>(AsyncTcpRead op, *Bytes out) {
    ?*CielBytes @raw = null;
    c::c_int rc = unsafe { ciel_async_finish_read(raw_read(op), &raw) };
    if ((rc as i64) == 0) {
        if (raw == null) {
            return 5 as c::c_int;
        }
        out->handle = raw as *void;
    }
    return rc;
}

unsafe impl poll_done<ReadIntoResult>(AsyncTcpRead op, *ReadIntoResult out) {
    ?*CielBytes @raw = null;
    c::c_int rc = unsafe { ciel_async_finish_read(raw_read(op), &raw) };
    if ((rc as i64) == 0) {
        if (raw == null) {
            return 5 as c::c_int;
        }
        Bytes bytes = { handle: raw as *void };
        out->bytes = bytes;
        out->read = bytes_len(bytes);
    }
    return rc;
}

unsafe impl poll_done<Bytes>(AsyncBufferedRead op, *Bytes out) {
    ?*CielBytes @raw = null;
    c::c_int rc = unsafe { ciel_async_finish_read(raw_buffered_read(op), &raw) };
    if ((rc as i64) == 0) {
        if (raw == null) {
            return 5 as c::c_int;
        }
        out->handle = raw as *void;
    }
    return rc;
}

impl<M: Message> notify_done(
    AsyncTcpWrite op,
    actor::Actor<M> actor_handle,
    M message
) {
    return notify_write_done(&op, &actor_handle, message);
}

impl finish<usize>(AsyncTcpWrite op) {
    return finish_write(op);
}

unsafe impl poll_done<usize>(AsyncTcpWrite op, *usize out) {
    usize @written = 0;
    c::c_int rc = unsafe { ciel_async_finish_write(raw_write(op), &written) };
    if ((rc as i64) == 0) {
        *out = written;
    }
    return rc;
}
