    if (raw == null) {
        return Err(code_error(5));
    }
    return Ok({ handle: raw as *void });
}

export Result<Bytes, Error> finish_read(AsyncTcpRead op) {
    ?*CielBytes @raw = null;
    c::c_int rc = unsafe { ciel_async_finish_read(raw_read(op), &raw) };
    if ((rc as i64) != 0) {
        return Err(code_error(rc as i64));
