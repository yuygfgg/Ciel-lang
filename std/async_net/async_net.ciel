    }
    return Ok(addr_from_raw(unsafe { raw as *CielSocketAddr }));
}

// Starts an async TCP read operation and returns its low-level token.
export Result<AsyncTcpRead, Error> read_bytes(*const AsyncTcpStream stream, usize max_len) = .read_async {
    ?*CielAsyncOp raw = unsafe { ciel_async_tcp_read_bytes(raw_stream(stream)?, max_len) };
    if (raw == null) {
        return Err(runtime_error());
    }
    return Ok(read_from_handle(register_async_op_owned(unsafe { raw as *CielAsyncOp })?));
}

// Starts an async TCP write operation and returns its low-level token.
export Result<AsyncTcpWrite, Error> write_bytes(*const AsyncTcpStream stream, Bytes data) = .write_async {
    ?*CielAsyncOp raw = unsafe { ciel_async_tcp_write_bytes(raw_stream(stream)?, raw_bytes(data)) };
    if (raw == null) {
        return Err(runtime_error());
    }
    return Ok(write_from_handle(register_async_op_owned(unsafe { raw as *CielAsyncOp })?));
}

// Starts an async TCP read into an owned buffer and returns its token.
export Result<AsyncTcpRead, Error> read_into_async(*const AsyncTcpStream stream, Bytes buffer) = .read_into_async {
    ?*CielAsyncOp raw = unsafe { ciel_async_tcp_read_into(raw_stream(stream)?, raw_bytes(buffer)) };
    if (raw == null) {
        return Err(runtime_error());
    }
    return Ok(read_from_handle(register_async_op_owned(unsafe { raw as *CielAsyncOp })?));
}

// Starts an async TCP write on a split write half and returns its token.
export Result<AsyncTcpWrite, Error> write_half_bytes(*const AsyncTcpWriteHalf half, Bytes data) = .write_async {
    ?*CielAsyncOp raw = unsafe { ciel_async_tcp_write_bytes(raw_write_half(half)?, raw_bytes(data)) };
    if (raw == null) {
        return Err(runtime_error());
    }
    return Ok(write_from_handle(register_async_op_owned(unsafe { raw as *CielAsyncOp })?));
}

// Creates a cancel-safe buffered reader from a split read half.
export Result<BufferedStreamReader, Error> buffered_reader(AsyncTcpReadHalf @half, usize capacity) = .buffered_reader {
    ?*CielBufferedReader raw =
        unsafe { ciel_async_tcp_buffered_reader_new(raw_read_half(&half)?, capacity) };
    if (raw == null) {
        return Err(runtime_error());
    }
    resource::Handle fd_handle =
        unsafe { resource::take_handle_in_place(read_half_handle_mut(&half)) };
    return Ok(unsafe { { handle: raw, fd_handle: fd_handle } });
}

// Consumes split halves and creates a cancel-safe buffered reader from the read half.
export Result<BufferedStreamReader, Error> buffered_reader_from_split(
    AsyncTcpSplit @split,
    usize capacity
) = .buffered_reader {
    resource::Handle read_handle = unsafe {
        resource::take_handle_in_place(read_half_handle_mut(&split.read))
    };
    AsyncTcpReadHalf half = read_half_from_handle(read_handle);
    return buffered_reader(half, capacity);
}

// Consumes a stream and creates a cancel-safe buffered reader from its read half.
export Result<BufferedStreamReader, Error> buffered_reader_from_stream(
    AsyncTcpStream @stream,
    usize capacity
) = .buffered_reader {
    ?*CielBufferedReader raw =
        unsafe { ciel_async_tcp_buffered_reader_new(raw_stream(&stream)?, capacity) };
    if (raw == null) {
        return Err(runtime_error());
    }
    resource::Handle fd_handle =
        unsafe { resource::take_handle_in_place(stream_handle_mut(&stream)) };
    return Ok(unsafe { { handle: raw, fd_handle: fd_handle } });
}

// Consumes a buffered reader and returns its underlying read half.
export Result<AsyncTcpReadHalf, Error> into_read_half(BufferedStreamReader @reader) = .into_read_half {
    ?*CielAsyncFd raw =
        unsafe { ciel_async_tcp_buffered_reader_into_read_half(raw_buffered_reader(&reader)?) };
    if (raw == null) {
        return Err(runtime_error());
    }
    resource::Handle handle =
        unsafe { resource::take_handle_in_place(&reader.fd_handle) };
    return Ok(read_half_from_handle(handle));
}

// Takes the buffered reader out of a buffered split without exposing partial
// resource field moves to user code.
export Result<BufferedStreamReader, Error> take_buffered_split_reader(
    *AsyncTcpBufferedSplit split_value
) {
    *BufferedStreamReader reader = buffered_split_reader_mut(split_value);
    ?*CielBufferedReader raw = unsafe { reader->handle };
    if (raw == null) {
        return Err(code_error(5));
    }
    resource::Handle handle = unsafe { resource::take_handle_in_place(&reader->fd_handle) };
    unsafe { reader->handle = null; };
    return Ok(unsafe { { handle: raw, fd_handle: handle } });
}

// Takes the write half out of a buffered split without exposing partial
// resource field moves to user code.
export Result<AsyncTcpWriteHalf, Error> take_buffered_split_write(
    *AsyncTcpBufferedSplit split_value
) {
    *AsyncTcpWriteHalf write = buffered_split_write_mut(split_value);
    resource::Handle handle = unsafe {
        resource::take_handle_in_place(write_half_handle_mut(write))
    };
    return Ok(write_half_from_handle(handle));
}

// Starts a cancel-safe buffered read operation and returns its token.
export Result<AsyncBufferedRead, Error> read_buffered_async(
    *const BufferedStreamReader reader,
    usize max_len
) = .read_async {
    ?*CielAsyncOp raw =
        unsafe { ciel_async_tcp_read_buffered(raw_buffered_reader(reader)?, max_len) };
    if (raw == null) {
        return Err(runtime_error());
    }
    return Ok(buffered_read_from_handle(register_async_op_owned(unsafe { raw as *CielAsyncOp })?));
}

// Starts a cancel-safe buffered read that completes only after len bytes or EOF/error.
export Result<AsyncBufferedRead, Error> read_exact_buffered_async(
    *const BufferedStreamReader reader,
    usize len
) = .read_exact_async {
    ?*CielAsyncOp raw =
        unsafe { ciel_async_tcp_read_exact_buffered(raw_buffered_reader(reader)?, len) };
    if (raw == null) {
        return Err(runtime_error());
    }
    return Ok(buffered_read_from_handle(register_async_op_owned(unsafe { raw as *CielAsyncOp })?));
}

// Awaits the next incoming async TCP connection.
export async Result<AsyncTcpStream, Error> accept(*const AsyncTcpListener listener) = .accept {
    AsyncAccept op = accept_async(listener)?;
    return await async_core::future_from_op<AsyncAccept, AsyncTcpStream>(op);
}

// Awaits an async TCP connection to addr.
export async Result<AsyncTcpStream, Error> connect(net::SocketAddr addr) {
    AsyncConnect op = connect_async(addr)?;
    return await async_core::future_from_op<AsyncConnect, AsyncTcpStream>(op);
}

// Connects to addr with a timeout.
export async Result<AsyncTcpStream, Error> connect_timeout(net::SocketAddr addr, u64 ms) = .connect_timeout {
    Result<AsyncTcpStream, Error> connected = await async::timeout(connect(addr), ms)?;
    return connected;
}

// Awaits a TCP read and returns owned Bytes; zero-length Bytes means EOF.
export async Result<Bytes, Error> read(*const AsyncTcpStream stream, usize max_len) = .read {
    AsyncTcpRead op = read_bytes(stream, max_len)?;
    return await async_core::future_from_op<AsyncTcpRead, Bytes>(op);
}

// Awaits a TCP read into an owned buffer and returns the buffer plus bytes read.
export async Result<ReadIntoResult, Error> read_into(*const AsyncTcpStream stream, Bytes buffer) = .read_into {
    AsyncTcpRead op = read_into_async(stream, buffer)?;
    return await async_core::future_from_op<AsyncTcpRead, ReadIntoResult>(op);
}

// Awaits a TCP write and returns bytes written.
export async Result<usize, Error> write(*const AsyncTcpStream stream, Bytes data) = .write {
    AsyncTcpWrite op = write_bytes(stream, data)?;
    return await async_core::future_from_op<AsyncTcpWrite, usize>(op);
}

// Awaits a TCP write on a split write half and returns bytes written.
export async Result<usize, Error> write_half(*const AsyncTcpWriteHalf half, Bytes data) = .write {
    AsyncTcpWrite op = write_half_bytes(half, data)?;
    return await async_core::future_from_op<AsyncTcpWrite, usize>(op);
}

// Writes all bytes on a stream, retrying short async writes until complete.
export async Result<AsyncTcpStream, Error> write_all(AsyncTcpStream @stream, Bytes data) = .write_all {
    usize total = bytes_len(data);
    usize @offset = 0;
    while (offset < total) {
        Bytes chunk;
        if (offset == 0) {
            chunk = data;
        } else {
            chunk = bytes_slice(data, offset, total - offset)?;
        }
        usize written = await write(&stream, chunk)?;
        if (written == 0) {
            return Err(text_error("tcp write returned zero"));
        }
        offset = offset + written;
    }
    return Ok(stream);
}

// Writes all bytes on a split write half, retrying short async writes until complete.
export async Result<AsyncTcpWriteHalf, Error> write_all_half(AsyncTcpWriteHalf @half, Bytes data) = .write_all {
    usize total = bytes_len(data);
    usize @offset = 0;
    while (offset < total) {
        Bytes chunk;
        if (offset == 0) {
            chunk = data;
        } else {
            chunk = bytes_slice(data, offset, total - offset)?;
        }
        usize written = await write_half(&half, chunk)?;
        if (written == 0) {
            return Err(text_error("tcp write returned zero"));
        }
        offset = offset + written;
    }
    return Ok(half);
}

// Awaits a cancel-safe buffered read.
export async Result<Bytes, Error> read_buffered(
    *const BufferedStreamReader reader,
    usize max_len
) = .read {
    AsyncBufferedRead op = read_buffered_async(reader, max_len)?;
    return await async_core::future_from_op<AsyncBufferedRead, Bytes>(op);
}

// Awaits exactly len buffered bytes unless EOF or error is reached first.
export async Result<Bytes, Error> read_exact_buffered(
    *const BufferedStreamReader reader,
    usize len
) = .read_exact {
    AsyncBufferedRead op = read_exact_buffered_async(reader, len)?;
    return await async_core::future_from_op<AsyncBufferedRead, Bytes>(op);
}

// Sends message to actor_handle when an accept operation completes.
export Result<void, Error> notify_accept_done<M: Message>(
    *const AsyncAccept op,
    *const actor::Actor<M> actor_handle,
    M message
) = .notify_done {
    *void boxed = box_message(message)?;
    c::c_int rc = unsafe { ciel_async_tcp_notify_accept(raw_accept(op)?, actor_handle->handle as *CielActor, boxed) };
    if ((rc as i64) != 0) {
        return Err(code_error(rc as i64));
    }
    return Ok;
}

// Sends message to actor_handle when a connect operation completes.
export Result<void, Error> notify_connect_done<M: Message>(
    *const AsyncConnect op,
    *const actor::Actor<M> actor_handle,
    M message
) = .notify_done {
    *void boxed = box_message(message)?;
    c::c_int rc = unsafe { ciel_async_tcp_notify_connect(raw_connect(op)?, actor_handle->handle as *CielActor, boxed) };
    if ((rc as i64) != 0) {
        return Err(code_error(rc as i64));
    }
    return Ok;
}

// Sends message to actor_handle when a TCP read operation completes.
export Result<void, Error> notify_read_done<M: Message>(
    *const AsyncTcpRead op,
    *const actor::Actor<M> actor_handle,
    M message
) = .notify_done {
    *void boxed = box_message(message)?;
    c::c_int rc = unsafe { ciel_async_notify_read(raw_read(op)?, actor_handle->handle as *CielActor, boxed) };
    if ((rc as i64) != 0) {
        return Err(code_error(rc as i64));
    }
    return Ok;
}

// Sends message to actor_handle when a TCP write operation completes.
export Result<void, Error> notify_write_done<M: Message>(
    *const AsyncTcpWrite op,
    *const actor::Actor<M> actor_handle,
    M message
) = .notify_done {
    *void boxed = box_message(message)?;
    c::c_int rc = unsafe { ciel_async_notify_write(raw_write(op)?, actor_handle->handle as *CielActor, boxed) };
    if ((rc as i64) != 0) {
        return Err(code_error(rc as i64));
    }
    return Ok;
}

// Finishes a completed accept operation and returns the accepted stream.
export Result<AsyncTcpStream, Error> finish_accept(AsyncAccept @op) = .finish {
    ?*CielAsyncFd @raw = null;
    c::c_int rc = unsafe { ciel_async_tcp_finish_accept(raw_accept(&op)?, &raw) };
    if ((rc as i64) != 0) {
        return Err(code_error(rc as i64));
    }
    if (raw == null) {
        return Err(code_error(5));
    }
    return Ok(stream_from_handle(register_finished_async_fd(unsafe { raw as *CielAsyncFd }, accept_handle_mut(&op))?));
}

// Finishes a completed connect operation and returns the connected stream.
export Result<AsyncTcpStream, Error> finish_connect(AsyncConnect @op) = .finish {
    ?*CielAsyncFd @raw = null;
    c::c_int rc = unsafe { ciel_async_tcp_finish_connect(raw_connect(&op)?, &raw) };
    if ((rc as i64) != 0) {
        return Err(code_error(rc as i64));
    }
    if (raw == null) {
        return Err(code_error(5));
    }
    return Ok(stream_from_handle(register_finished_async_fd(unsafe { raw as *CielAsyncFd }, connect_handle_mut(&op))?));
}

// Finishes a completed TCP read operation and returns owned Bytes.
export Result<Bytes, Error> finish_read(AsyncTcpRead @op) = .finish {
    ?*CielBytes @raw = null;
    c::c_int rc = unsafe { ciel_async_finish_read(raw_read(&op)?, &raw) };
    if ((rc as i64) != 0) {
        return Err(code_error(rc as i64));
    }
    if (raw == null) {
        return Err(code_error(5));
    }
    c::c_int close_rc = close_handle(read_handle_mut(&op));
    if ((close_rc as i64) != 0) {
        return Err(code_error(close_rc as i64));
    }
    return Ok({ handle: raw as *void });
}

// Finishes a completed TCP write operation and returns bytes written.
export Result<usize, Error> finish_write(AsyncTcpWrite @op) = .finish {
    usize @written = 0;
    c::c_int rc = unsafe { ciel_async_finish_write(raw_write(&op)?, &written) };
    if ((rc as i64) != 0) {
        return Err(code_error(rc as i64));
    }
    c::c_int close_rc = close_handle(write_handle_mut(&op));
    if ((close_rc as i64) != 0) {
        return Err(code_error(close_rc as i64));
    }
    return Ok(written);
}

// Cancels a pending accept operation.
export Result<void, Error> cancel_accept(AsyncAccept @op) = .cancel {
    c::c_int rc = close_handle(accept_handle_mut(&op));
    if ((rc as i64) != 0) {
        return Err(code_error(rc as i64));
    }
    return Ok;
}

// Cancels a pending connect operation.
export Result<void, Error> cancel_connect(AsyncConnect @op) = .cancel {
    c::c_int rc = close_handle(connect_handle_mut(&op));
    if ((rc as i64) != 0) {
        return Err(code_error(rc as i64));
    }
    return Ok;
}

// Cancels a pending raw TCP read operation.
export Result<void, Error> cancel_read(AsyncTcpRead @op) = .cancel {
    c::c_int rc = close_handle(read_handle_mut(&op));
    if ((rc as i64) != 0) {
        return Err(code_error(rc as i64));
    }
    return Ok;
}

// Cancels a pending raw TCP write operation.
export Result<void, Error> cancel_write(AsyncTcpWrite @op) = .cancel {
    c::c_int rc = close_handle(write_handle_mut(&op));
    if ((rc as i64) != 0) {
        return Err(code_error(rc as i64));
    }
    return Ok;
}

// Cancels a pending buffered read operation without discarding preserved bytes.
export Result<void, Error> cancel_buffered_read(AsyncBufferedRead @op) = .cancel {
    c::c_int rc = close_handle(buffered_read_handle_mut(&op));
    if ((rc as i64) != 0) {
        return Err(code_error(rc as i64));
    }
    return Ok;
}

unsafe impl abort_future(*AsyncAccept op) {
    return cancel_accept(*op);
}

unsafe impl abort_future(*AsyncConnect op) {
    return cancel_connect(*op);
}

unsafe impl abort_future(*AsyncTcpRead op) {
    return cancel_read(*op);
}

unsafe impl abort_future(*AsyncTcpWrite op) {
    return cancel_write(*op);
}

unsafe impl abort_future(*AsyncBufferedRead op) {
    return cancel_buffered_read(*op);
}

impl<M: Message> notify_done(
    AsyncAccept op,
    actor::Actor<M> actor_handle,
    M message
) {
    return notify_accept_done(&op, &actor_handle, message);
}

impl finish<AsyncTcpStream>(AsyncAccept op) {
    return finish_accept(op);
}

unsafe impl poll_done<AsyncTcpStream>(*AsyncAccept op, *AsyncTcpStream out) {
    ?*CielAsyncOp @raw_op = null;
    c::c_int snapshot_rc = snapshot_async_op(accept_handle(op), &raw_op);
    if ((snapshot_rc as i64) != 0) {
        return snapshot_rc;
    }
    if (raw_op == null) {
        return 5 as c::c_int;
    }
    ?*CielAsyncFd @raw = null;
    c::c_int rc = unsafe { ciel_async_tcp_finish_accept(unsafe { raw_op as *CielAsyncOp }, &raw) };
    if ((rc as i64) == 0) {
        if (raw == null) {
            return 5 as c::c_int;
        }
        c::c_int register_rc = unsafe {
            register_finished_async_fd_out(unsafe { raw as *CielAsyncFd }, accept_handle_mut(op), stream_handle_mut(out))
        };
        if ((register_rc as i64) != 0) {
            return register_rc;
        }
    }
    return rc;
}

