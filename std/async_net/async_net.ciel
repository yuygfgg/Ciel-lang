// Re-exports Result for async TCP APIs.
export import /std/result;

import /std/async as async;
import /std/async/core as async_core;
import /std/async/core;
import /std/async/internal/adapter;
import /std/actor as actor;
import /std/buf as buf;
import /std/bytes as bytes;
import /std/c as c;
import /std/message;
import /std/meta;
import /std/net as net;
import /std/resource;
import /std/resource as resource;
import /std/storage as storage;

unsafe extern "C" {
    opaque struct CielBufferedReader;
    opaque struct CielAsyncTcpListener;
    opaque struct CielSocketAddr;

    ?*CielAsyncTcpListener ciel_async_tcp_listen(*CielSocketAddr addr);
    c::c_int ciel_async_tcp_listener_addr(*CielAsyncTcpListener listener, *?*CielSocketAddr out);
    c::c_int ciel_async_tcp_close_listener(*CielAsyncTcpListener listener);
    ?*CielAsyncOp ciel_async_tcp_accept(*CielAsyncTcpListener listener);
    ?*CielAsyncOp ciel_async_tcp_connect(*CielSocketAddr addr);
    c::c_int ciel_async_tcp_finish_accept(*CielAsyncOp op, *?*CielAsyncFd out);
    c::c_int ciel_async_tcp_finish_connect(*CielAsyncOp op, *?*CielAsyncFd out);
    c::c_int ciel_async_tcp_notify_accept(*CielAsyncOp op, *CielActor actor, *void message);
    c::c_int ciel_async_tcp_notify_connect(*CielAsyncOp op, *CielActor actor, *void message);
    c::c_int ciel_async_tcp_stream_local_addr(*CielAsyncFd stream, *?*CielSocketAddr out);
    c::c_int ciel_async_tcp_stream_peer_addr(*CielAsyncFd stream, *?*CielSocketAddr out);
    c::c_int ciel_async_tcp_shutdown_read(*CielAsyncFd stream);
    c::c_int ciel_async_tcp_shutdown_write(*CielAsyncFd stream);

    c::c_int ciel_async_fd_retain(*CielAsyncFd fd);
    ?*CielAsyncOp ciel_async_tcp_read_bytes(*CielAsyncFd fd, usize max_len);
    ?*CielAsyncOp ciel_async_tcp_read_into(*CielAsyncFd fd, *u8 data, usize cap);
    ?*CielAsyncOp ciel_async_tcp_write_bytes(*CielAsyncFd fd, *const u8 data, usize len);
    ?*CielBufferedReader ciel_async_tcp_buffered_reader_new(*CielAsyncFd fd, usize capacity);
    ?*CielAsyncFd ciel_async_tcp_buffered_reader_into_read_half(*CielBufferedReader reader);
    ?*CielAsyncOp ciel_async_tcp_read_buffered(*CielBufferedReader reader, usize max_len);
    ?*CielAsyncOp ciel_async_tcp_read_exact_buffered(*CielBufferedReader reader, usize len);

    c::c_int ciel_resource_register_async_listener_handle(
        *CielAsyncTcpListener listener,
        *u64 out_owner_id,
        *u64 out_resource_id,
        *u64 out_generation
    );
    c::c_int ciel_resource_async_listener_snapshot_handle(
        u64 owner_id,
        u64 resource_id,
        u64 generation,
        *?*CielAsyncTcpListener out
    );
}

// Runtime-backed async TCP listener handle.
export resource unsafe struct AsyncTcpListener {
    resource::Handle handle;
}

// Runtime-backed async TCP stream handle.
export resource unsafe struct AsyncTcpStream {
    resource::Handle handle;
}

// Read half of an async TCP stream.
export resource unsafe struct AsyncTcpReadHalf {
    resource::Handle handle;
}

// Write half of an async TCP stream.
export resource unsafe struct AsyncTcpWriteHalf {
    resource::Handle handle;
}

// Split async TCP stream halves.
export resource unsafe struct AsyncTcpSplit {
    AsyncTcpReadHalf read;
    AsyncTcpWriteHalf write;
}

// Cancel-safe buffered reader over an async TCP read half.
export resource unsafe struct BufferedStreamReader {
    ?*CielBufferedReader handle;
    resource::Handle fd_handle;
}

// Buffered read half plus write half produced from one async TCP stream.
export resource unsafe struct AsyncTcpBufferedSplit {
    BufferedStreamReader reader;
    AsyncTcpWriteHalf write;
}

// Runtime operation token for an in-flight async accept.
export resource unsafe struct AsyncAccept {
    resource::Handle handle;
}

// Runtime operation token for an in-flight async connect.
export resource unsafe struct AsyncConnect {
    resource::Handle handle;
}

// Runtime operation token for an in-flight async TCP read.
export resource unsafe struct AsyncTcpRead {
    resource::Handle handle;
}

// Runtime operation token for an in-flight async TCP read into an owned buffer.
export resource unsafe struct AsyncTcpReadInto {
    resource::Handle handle;
}

// Runtime operation token for an in-flight async TCP write.
export resource unsafe struct AsyncTcpWrite {
    resource::Handle handle;
}

// Runtime operation token for an in-flight buffered TCP read.
export resource unsafe struct AsyncBufferedRead {
    resource::Handle handle;
}

unsafe derive async_frame_opt_in_marker<AsyncTcpListener>;
unsafe derive async_frame_opt_in_marker<AsyncTcpStream>;
unsafe derive async_frame_opt_in_marker<AsyncTcpReadHalf>;
unsafe derive async_frame_opt_in_marker<AsyncTcpWriteHalf>;
unsafe derive async_frame_opt_in_marker<AsyncTcpSplit>;
unsafe derive async_frame_opt_in_marker<BufferedStreamReader>;
unsafe derive async_frame_opt_in_marker<AsyncTcpBufferedSplit>;
unsafe derive async_frame_opt_in_marker<AsyncAccept>;
unsafe derive async_frame_opt_in_marker<AsyncConnect>;
unsafe derive async_frame_opt_in_marker<AsyncTcpRead>;
unsafe derive async_frame_opt_in_marker<AsyncTcpReadInto>;
unsafe derive async_frame_opt_in_marker<AsyncTcpWrite>;
unsafe derive async_frame_opt_in_marker<AsyncBufferedRead>;

// Result of read_into: returned reusable buffer plus number of bytes filled.
export struct ReadIntoResult {
    buf::ByteBuf buffer;
    usize read;
}

// Errors produced by async TCP operation-token APIs.
export enum AsyncNetError {
    Runtime(i64),
    BytesError(bytes::BytesError),
    MessageClone(Error),
    Async(AsyncError),
    Timeout,
    WriteZero,
}

derive Message<AsyncNetError>;

impl format_error(*const AsyncNetError error) {
    switch (*error) {
        case Runtime(_):
            return "async network runtime error";
        case BytesError(inner):
            return format_error(&inner);
        case MessageClone(inner):
            return format_error(&inner);
        case Async(inner):
            return format_error(&inner);
        case Timeout:
            return "async network timeout";
        case WriteZero:
            return "tcp write returned zero";
    }
}

unsafe derive cancel_safe_marker<AsyncAccept>;

unsafe derive cancel_safe_marker<AsyncConnect>;

unsafe derive cancel_safe_marker<AsyncBufferedRead>;

unsafe impl clone_message(*const ReadIntoResult value) {
    buf::ByteBuf cloned = clone_message(&value->buffer)?;
    return Ok({ buffer: cloned, read: value->read });
}

AsyncNetError runtime_error() {
    c::c_int code = unsafe { c::ciel_errno() };
    if ((code as i64) == 0) {
        return Runtime(5);
    }
    return Runtime(code as i64);
}

Result<Out, AsyncNetError> async_result<Out>(Result<Out, AsyncError> result) {
    switch (result) {
        case Ok(value):
            return Ok(value);
        case Err(error):
            return Err(Async(error));
    }
}

Result<Out, AsyncNetError> timeout_result<Out>(Result<Result<Out, AsyncNetError>, AsyncError> result) {
    switch (result) {
        case Ok(value):
            return value;
        case Err(error):
            switch (error) {
                case Timeout:
                    return Err(Timeout);
                case Runtime(_):
                    return Err(Async(error));
                case ChannelClosed:
                    return Err(Async(error));
                case MessageClone(_):
                    return Err(Async(error));
                case Operation(_):
                    return Err(Async(error));
            }
    }
}

Result<bytes::Bytes, AsyncNetError> bytes_value_result(Result<bytes::Bytes, bytes::BytesError> result) {
    switch (result) {
        case Ok(value):
            return Ok(value);
        case Err(error):
            return Err(AsyncNetError::BytesError(error));
    }
}

