    }
    return Ok;
}

// Sends message to actor_handle when a TCP read-into operation completes.
export Result<void, AsyncNetError> notify_read_into_done<M: Message>(
    *const AsyncTcpReadInto op,
    *const actor::Actor<M> actor_handle,
    M message
) = .notify_done {
    *void boxed = box_message(message)?;
    c::c_int rc = unsafe { ciel_async_notify_read(raw_read_into(op)?, actor_handle->handle as *CielActor, boxed) };
    if ((rc as i64) != 0) {
        return Err(Runtime(rc as i64));
    }
    return Ok;
}

// Sends message to actor_handle when a TCP write operation completes.
export Result<void, AsyncNetError> notify_write_done<M: Message>(
    *const AsyncTcpWrite op,
    *const actor::Actor<M> actor_handle,
    M message
) = .notify_done {
    *void boxed = box_message(message)?;
    c::c_int rc = unsafe { ciel_async_notify_write(raw_write(op)?, actor_handle->handle as *CielActor, boxed) };
    if ((rc as i64) != 0) {
        return Err(Runtime(rc as i64));
    }
    return Ok;
}

// Finishes a completed accept operation and returns the accepted stream.
export Result<AsyncTcpStream, AsyncNetError> finish_accept(AsyncAccept @op) = .finish {
    ?*CielAsyncFd @raw = null;
    c::c_int rc = unsafe { ciel_async_tcp_finish_accept(raw_accept(&op)?, &raw) };
    if ((rc as i64) != 0) {
        return Err(Runtime(rc as i64));
    }
    if (raw == null) {
        return Err(Runtime(5));
    }
    return Ok(stream_from_handle(register_finished_async_fd(unsafe { raw as *CielAsyncFd }, accept_handle_mut(&op))?));
}

// Finishes a completed connect operation and returns the connected stream.
export Result<AsyncTcpStream, AsyncNetError> finish_connect(AsyncConnect @op) = .finish {
    ?*CielAsyncFd @raw = null;
    c::c_int rc = unsafe { ciel_async_tcp_finish_connect(raw_connect(&op)?, &raw) };
    if ((rc as i64) != 0) {
        return Err(Runtime(rc as i64));
    }
    if (raw == null) {
        return Err(Runtime(5));
    }
    return Ok(stream_from_handle(register_finished_async_fd(unsafe { raw as *CielAsyncFd }, connect_handle_mut(&op))?));
}

// Finishes a completed TCP read operation and returns owned Bytes.
export Result<bytes::Bytes, AsyncNetError> finish_read(AsyncTcpRead @op) = .finish {
    ?*u8 @raw = null;
    usize @len = 0;
    usize @cap = 0;
    c::c_int rc = unsafe { ciel_async_finish_read(raw_read(&op)?, &raw, &len, &cap) };
    if ((rc as i64) != 0) {
        return Err(Runtime(rc as i64));
    }
    c::c_int close_rc = close_handle(read_handle_mut(&op));
    if ((close_rc as i64) != 0) {
        return Err(Runtime(close_rc as i64));
    }
    return bytes_from_runtime(raw, len);
}

// Finishes a completed TCP read-into operation and returns the buffer plus bytes read.
export Result<ReadIntoResult, AsyncNetError> finish_read_into(AsyncTcpReadInto @op) = .finish {
    ?*u8 @raw = null;
    usize @len = 0;
    usize @cap = 0;
    c::c_int rc = unsafe { ciel_async_finish_read(raw_read_into(&op)?, &raw, &len, &cap) };
    if ((rc as i64) != 0) {
        return Err(Runtime(rc as i64));
    }
    c::c_int close_rc = close_handle(read_into_handle_mut(&op));
    if ((close_rc as i64) != 0) {
        return Err(Runtime(close_rc as i64));
    }
    buf::ByteBuf buffer = byte_buf_from_runtime(raw, len, cap)?;
    return Ok({ buffer: buffer, read: len });
}

// Finishes a completed TCP write operation and returns bytes written.
export Result<usize, AsyncNetError> finish_write(AsyncTcpWrite @op) = .finish {
    usize @written = 0;
    c::c_int rc = unsafe { ciel_async_finish_write(raw_write(&op)?, &written) };
    if ((rc as i64) != 0) {
        return Err(Runtime(rc as i64));
    }
    c::c_int close_rc = close_handle(write_handle_mut(&op));
    if ((close_rc as i64) != 0) {
        return Err(Runtime(close_rc as i64));
    }
    return Ok(written);
}

// Cancels a pending accept operation.
export Result<void, AsyncNetError> cancel_accept(AsyncAccept @op) = .cancel {
    c::c_int rc = close_handle(accept_handle_mut(&op));
    if ((rc as i64) != 0) {
        return Err(Runtime(rc as i64));
    }
    return Ok;
}

// Cancels a pending connect operation.
export Result<void, AsyncNetError> cancel_connect(AsyncConnect @op) = .cancel {
    c::c_int rc = close_handle(connect_handle_mut(&op));
    if ((rc as i64) != 0) {
        return Err(Runtime(rc as i64));
    }
    return Ok;
}

// Cancels a pending raw TCP read operation.
export Result<void, AsyncNetError> cancel_read(AsyncTcpRead @op) = .cancel {
    c::c_int rc = close_handle(read_handle_mut(&op));
    if ((rc as i64) != 0) {
        return Err(Runtime(rc as i64));
    }
    return Ok;
}

// Cancels a pending raw TCP read-into operation.
export Result<void, AsyncNetError> cancel_read_into(AsyncTcpReadInto @op) = .cancel {
    c::c_int rc = close_handle(read_into_handle_mut(&op));
    if ((rc as i64) != 0) {
        return Err(Runtime(rc as i64));
    }
    return Ok;
}

// Cancels a pending raw TCP write operation.
export Result<void, AsyncNetError> cancel_write(AsyncTcpWrite @op) = .cancel {
    c::c_int rc = close_handle(write_handle_mut(&op));
    if ((rc as i64) != 0) {
        return Err(Runtime(rc as i64));
    }
    return Ok;
}

// Cancels a pending buffered read operation without discarding preserved bytes.
export Result<void, AsyncNetError> cancel_buffered_read(AsyncBufferedRead @op) = .cancel {
    c::c_int rc = close_handle(buffered_read_handle_mut(&op));
    if ((rc as i64) != 0) {
        return Err(Runtime(rc as i64));
    }
    return Ok;
}

unsafe impl abort_future(*AsyncAccept op) {
    cancel_accept(*op)?;
    return Ok;
}

unsafe impl abort_future(*AsyncConnect op) {
    cancel_connect(*op)?;
    return Ok;
}

unsafe impl abort_future(*AsyncTcpRead op) {
    cancel_read(*op)?;
    return Ok;
}

unsafe impl abort_future(*AsyncTcpReadInto op) {
    cancel_read_into(*op)?;
    return Ok;
}

unsafe impl abort_future(*AsyncTcpWrite op) {
    cancel_write(*op)?;
    return Ok;
}

unsafe impl abort_future(*AsyncBufferedRead op) {
    cancel_buffered_read(*op)?;
    return Ok;
}

impl<M: Message> notify_done(
    AsyncAccept op,
    actor::Actor<M> actor_handle,
    M message
) {
    notify_accept_done(&op, &actor_handle, message)?;
    return Ok;
}

impl finish<AsyncTcpStream>(AsyncAccept op) {
    return Ok(finish_accept(op)?);
}

unsafe impl poll_done<AsyncTcpStream>(*AsyncAccept op, *AsyncTcpStream out) {
    ?*CielAsyncOp @raw_op = null;
    c::c_int snapshot_rc = snapshot_async_op(accept_handle(op), &raw_op);
    if ((snapshot_rc as i64) != 0) {
        return snapshot_rc;
    }
    if (raw_op == null) {
        return 5 as c::c_int;
    }
    ?*CielAsyncFd @raw = null;
    c::c_int rc = unsafe { ciel_async_tcp_finish_accept(unsafe { raw_op as *CielAsyncOp }, &raw) };
    if ((rc as i64) == 0) {
        if (raw == null) {
            return 5 as c::c_int;
        }
        c::c_int register_rc = unsafe {
            register_finished_async_fd_out(unsafe { raw as *CielAsyncFd }, accept_handle_mut(op), stream_handle_mut(out))
        };
        if ((register_rc as i64) != 0) {
            return register_rc;
        }
    }
    return rc;
}

impl<M: Message> notify_done(
    AsyncConnect op,
    actor::Actor<M> actor_handle,
    M message
) {
    notify_connect_done(&op, &actor_handle, message)?;
