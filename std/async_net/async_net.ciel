// Re-exports Result for async TCP APIs.
export import /std/result;

// Re-exports Bytes for async TCP payloads.
export import /std/async/bytes;
import /std/async as async;
import /std/async/core as async_core;
import /std/async/core;
import /std/async/internal/adapter;
import /std/actor as actor;
import /std/c as c;
import /std/message;
import /std/meta;
import /std/net as net;

unsafe extern "C" {
    opaque struct CielActor;
    opaque struct CielAsyncFd;
    opaque struct CielAsyncOp;
    opaque struct CielBufferedReader;
    opaque struct CielAsyncTcpListener;
    opaque struct CielBytes;
    opaque struct CielSocketAddr;

    c::c_int ciel_errno();
    ?*void ciel_actor_box_copy(usize size, usize align, *const void source);

    ?*CielAsyncTcpListener ciel_async_tcp_listen(*CielSocketAddr addr);
    c::c_int ciel_async_tcp_listener_addr(*CielAsyncTcpListener listener, *?*CielSocketAddr out);
    c::c_int ciel_async_tcp_close_listener(*CielAsyncTcpListener listener);
    ?*CielAsyncOp ciel_async_tcp_accept(*CielAsyncTcpListener listener);
    ?*CielAsyncOp ciel_async_tcp_connect(*CielSocketAddr addr);
    c::c_int ciel_async_tcp_finish_accept(*CielAsyncOp op, *?*CielAsyncFd out);
    c::c_int ciel_async_tcp_finish_connect(*CielAsyncOp op, *?*CielAsyncFd out);
    c::c_int ciel_async_tcp_notify_accept(*CielAsyncOp op, *CielActor actor, *void message);
    c::c_int ciel_async_tcp_notify_connect(*CielAsyncOp op, *CielActor actor, *void message);
    c::c_int ciel_async_tcp_stream_local_addr(*CielAsyncFd stream, *?*CielSocketAddr out);
    c::c_int ciel_async_tcp_stream_peer_addr(*CielAsyncFd stream, *?*CielSocketAddr out);
    c::c_int ciel_async_tcp_shutdown_read(*CielAsyncFd stream);
    c::c_int ciel_async_tcp_shutdown_write(*CielAsyncFd stream);

    c::c_int ciel_async_close(*CielAsyncFd fd);
    ?*CielAsyncOp ciel_async_tcp_read_bytes(*CielAsyncFd fd, usize max_len);
    ?*CielAsyncOp ciel_async_tcp_read_into(*CielAsyncFd fd, *CielBytes bytes);
    ?*CielAsyncOp ciel_async_tcp_write_bytes(*CielAsyncFd fd, *CielBytes bytes);
    ?*CielBufferedReader ciel_async_tcp_buffered_reader_new(*CielAsyncFd fd, usize capacity);
    ?*CielAsyncFd ciel_async_tcp_buffered_reader_into_read_half(*CielBufferedReader reader);
    ?*CielAsyncOp ciel_async_tcp_read_buffered(*CielBufferedReader reader, usize max_len);
    ?*CielAsyncOp ciel_async_tcp_read_exact_buffered(*CielBufferedReader reader, usize len);
    c::c_int ciel_async_notify_read(*CielAsyncOp op, *CielActor actor, *void message);
    c::c_int ciel_async_notify_write(*CielAsyncOp op, *CielActor actor, *void message);
    c::c_int ciel_async_finish_read(*CielAsyncOp op, *?*CielBytes out);
    c::c_int ciel_async_finish_write(*CielAsyncOp op, *usize written);
    c::c_int ciel_async_cancel(*CielAsyncOp op);
}

// Runtime-backed async TCP listener handle.
export struct AsyncTcpListener {
    *void handle;
}

// Runtime-backed async TCP stream handle.
export struct AsyncTcpStream {
    *void handle;
}

// Read half of an async TCP stream.
export struct AsyncTcpReadHalf {
    *void handle;
}

// Write half of an async TCP stream.
export struct AsyncTcpWriteHalf {
    *void handle;
}

// Split async TCP stream halves.
export struct AsyncTcpSplit {
    AsyncTcpReadHalf read;
    AsyncTcpWriteHalf write;
}

// Cancel-safe buffered reader over an async TCP read half.
export struct BufferedStreamReader {
    *void handle;
}

// Runtime operation token for an in-flight async accept.
export struct AsyncAccept {
    *void handle;
}

// Runtime operation token for an in-flight async connect.
export struct AsyncConnect {
    *void handle;
}

// Runtime operation token for an in-flight async TCP read.
export struct AsyncTcpRead {
    *void handle;
}

// Runtime operation token for an in-flight async TCP write.
export struct AsyncTcpWrite {
    *void handle;
}

// Runtime operation token for an in-flight buffered TCP read.
export struct AsyncBufferedRead {
    *void handle;
}

// Result of read_into: returned buffer plus number of bytes filled.
export struct ReadIntoResult {
    Bytes bytes;
    usize read;
}

unsafe impl clone_message(*const AsyncTcpListener value) {
    return Ok(*value);
}

unsafe impl clone_message(*const AsyncTcpStream value) {
    return Ok(*value);
}

unsafe impl clone_message(*const AsyncTcpReadHalf value) {
    return Ok(*value);
}

unsafe impl clone_message(*const AsyncTcpWriteHalf value) {
    return Ok(*value);
}

unsafe impl clone_message(*const AsyncTcpSplit value) {
    return Ok(*value);
}

unsafe impl clone_message(*const BufferedStreamReader value) {
    return Ok(*value);
}

unsafe impl clone_message(*const AsyncAccept value) {
    return Ok(*value);
}

unsafe impl clone_message(*const AsyncConnect value) {
    return Ok(*value);
}

unsafe impl clone_message(*const AsyncTcpRead value) {
    return Ok(*value);
}

unsafe impl clone_message(*const AsyncTcpWrite value) {
    return Ok(*value);
}

unsafe impl clone_message(*const AsyncBufferedRead value) {
    return Ok(*value);
}

unsafe impl share_handle_marker(*const AsyncTcpListener value) {
    return true;
}

unsafe impl share_handle_marker(*const AsyncTcpStream value) {
    return true;
}

unsafe impl share_handle_marker(*const AsyncTcpReadHalf value) {
    return true;
}

unsafe impl share_handle_marker(*const AsyncTcpWriteHalf value) {
    return true;
}

unsafe impl share_handle_marker(*const AsyncTcpSplit value) {
    return true;
}

unsafe impl share_handle_marker(*const BufferedStreamReader value) {
    return true;
}

unsafe impl share_handle_marker(*const AsyncAccept value) {
    return true;
}

unsafe impl share_handle_marker(*const AsyncConnect value) {
    return true;
}

unsafe impl share_handle_marker(*const AsyncTcpRead value) {
    return true;
}

unsafe impl share_handle_marker(*const AsyncTcpWrite value) {
    return true;
}

unsafe impl share_handle_marker(*const AsyncBufferedRead value) {
    return true;
}

unsafe impl raw_operation(*const AsyncAccept op) {
    return op->handle;
}

unsafe impl raw_operation(*const AsyncConnect op) {
    return op->handle;
}

unsafe impl raw_operation(*const AsyncTcpRead op) {
    return op->handle;
}

unsafe impl raw_operation(*const AsyncTcpWrite op) {
    return op->handle;
}

unsafe impl raw_operation(*const AsyncBufferedRead op) {
    return op->handle;
}

unsafe impl cancel_safe_marker(*const AsyncAccept op) {
    return true;
}

unsafe impl cancel_safe_marker(*const AsyncConnect op) {
    return true;
}

unsafe impl cancel_safe_marker(*const AsyncBufferedRead op) {
    return true;
}

unsafe impl clone_message(*const ReadIntoResult value) {
    Bytes cloned = clone_message(&value->bytes)?;
    return Ok({ bytes: cloned, read: value->read });
}

unsafe impl share_handle_marker(*const ReadIntoResult value) {
    return true;
}

Error runtime_error() {
    c::c_int code = unsafe { ciel_errno() };
    if ((code as i64) == 0) {
        return code_error(5);
    }
    return code_error(code as i64);
}

*CielSocketAddr raw_addr(net::SocketAddr addr) {
    return unsafe { addr.handle as *CielSocketAddr };
}

net::SocketAddr addr_from_raw(*CielSocketAddr raw) {
    return unsafe { { handle: raw as *void } };
}

*CielAsyncTcpListener raw_listener(AsyncTcpListener listener) {
    return unsafe { listener.handle as *CielAsyncTcpListener };
}

*CielAsyncFd raw_stream(AsyncTcpStream stream) {
    return unsafe { stream.handle as *CielAsyncFd };
}

*CielAsyncFd raw_read_half(AsyncTcpReadHalf half) {
    return unsafe { half.handle as *CielAsyncFd };
}

*CielAsyncFd raw_write_half(AsyncTcpWriteHalf half) {
    return unsafe { half.handle as *CielAsyncFd };
}

*CielBufferedReader raw_buffered_reader(BufferedStreamReader reader) {
    return unsafe { reader.handle as *CielBufferedReader };
}

*CielAsyncOp raw_accept(AsyncAccept op) {
    return unsafe { op.handle as *CielAsyncOp };
}

*CielAsyncOp raw_connect(AsyncConnect op) {
    return unsafe { op.handle as *CielAsyncOp };
}

*CielAsyncOp raw_read(AsyncTcpRead op) {
    return unsafe { op.handle as *CielAsyncOp };
}

*CielAsyncOp raw_write(AsyncTcpWrite op) {
    return unsafe { op.handle as *CielAsyncOp };
}

*CielAsyncOp raw_buffered_read(AsyncBufferedRead op) {
    return unsafe { op.handle as *CielAsyncOp };
}

*CielBytes raw_bytes(Bytes bytes) {
    return unsafe { bytes.handle as *CielBytes };
}

Result<*void, Error> box_message<M: Message>(M message) {
    M local = message;
    M cloned = clone_message(&local)?;
    ?*void boxed = unsafe { ciel_actor_box_copy(type_size<M>(), type_align<M>(), &cloned as *const void) };
    if (boxed == null) {
        return Err(code_error(5));
    }
    return Ok(boxed);
}

// Opens an async TCP listener bound to addr.
export Result<AsyncTcpListener, Error> listen_async(net::SocketAddr addr) = .listen_async {
    ?*CielAsyncTcpListener raw = unsafe { ciel_async_tcp_listen(raw_addr(addr)) };
    if (raw == null) {
        return Err(runtime_error());
    }
    return Ok({ handle: raw as *void });
}

// Returns the local address bound to an async listener.
export Result<net::SocketAddr, Error> listener_addr(AsyncTcpListener listener) = .addr {
    ?*CielSocketAddr @raw = null;
    c::c_int rc = unsafe { ciel_async_tcp_listener_addr(raw_listener(listener), &raw) };
    if ((rc as i64) != 0) {
        return Err(code_error(rc as i64));
    }
    if (raw == null) {
        return Err(code_error(5));
    }
    return Ok(addr_from_raw(unsafe { raw as *CielSocketAddr }));
}

// Closes an async listener handle.
export Result<void, Error> close_listener(AsyncTcpListener listener) = .close {
    c::c_int rc = unsafe { ciel_async_tcp_close_listener(raw_listener(listener)) };
    if ((rc as i64) != 0) {
        return Err(code_error(rc as i64));
    }
    return Ok;
}

// Starts an async accept operation and returns its low-level token.
export Result<AsyncAccept, Error> accept_async(AsyncTcpListener listener) = .accept_async {
    ?*CielAsyncOp raw = unsafe { ciel_async_tcp_accept(raw_listener(listener)) };
    if (raw == null) {
        return Err(runtime_error());
    }
    return Ok({ handle: raw as *void });
}

// Starts an async connect operation and returns its low-level token.
export Result<AsyncConnect, Error> connect_async(net::SocketAddr addr) = .connect_async {
    ?*CielAsyncOp raw = unsafe { ciel_async_tcp_connect(raw_addr(addr)) };
    if (raw == null) {
        return Err(runtime_error());
    }
    return Ok({ handle: raw as *void });
}

// Closes an async stream handle.
export Result<void, Error> close_stream(AsyncTcpStream stream) = .close {
    c::c_int rc = unsafe { ciel_async_close(raw_stream(stream)) };
    if ((rc as i64) != 0) {
        return Err(code_error(rc as i64));
    }
    return Ok;
}

// Splits a stream into read and write halves that share the same runtime stream.
export Result<AsyncTcpSplit, Error> split(AsyncTcpStream stream) = .split {
    *void handle = stream.handle;
    return Ok({
        read: { handle: handle },
        write: { handle: handle },
    });
}

// Shuts down the read half of a stream.
export Result<void, Error> shutdown_read(AsyncTcpStream stream) = .shutdown_read {
    c::c_int rc = unsafe { ciel_async_tcp_shutdown_read(raw_stream(stream)) };
    if ((rc as i64) != 0) {
        return Err(code_error(rc as i64));
    }
    return Ok;
}

// Shuts down a split read half.
export Result<void, Error> shutdown_read_half(AsyncTcpReadHalf half) = .shutdown_read {
    c::c_int rc = unsafe { ciel_async_tcp_shutdown_read(raw_read_half(half)) };
    if ((rc as i64) != 0) {
        return Err(code_error(rc as i64));
    }
    return Ok;
}

// Shuts down the write half of a stream.
export Result<void, Error> shutdown_write(AsyncTcpStream stream) = .shutdown_write {
    c::c_int rc = unsafe { ciel_async_tcp_shutdown_write(raw_stream(stream)) };
    if ((rc as i64) != 0) {
        return Err(code_error(rc as i64));
