impl transfer_to_parent(*const AsyncTcpListener value) {
    AsyncTcpListener @local = unsafe { *value };
    resource::Handle handle = unsafe { resource::transfer_handle_to_parent_in_place(listener_handle_mut(&local))? };
    return Ok(listener_from_handle(handle));
}

impl transfer_to_parent(*const AsyncTcpStream value) {
    AsyncTcpStream @local = unsafe { *value };
    resource::Handle handle = unsafe { resource::transfer_handle_to_parent_in_place(stream_handle_mut(&local))? };
    return Ok(stream_from_handle(handle));
}

