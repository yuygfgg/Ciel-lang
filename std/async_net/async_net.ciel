unsafe impl poll_done<ReadIntoResult>(*AsyncTcpRead op, *ReadIntoResult out) {
    ?*CielAsyncOp @raw_op = null;
    c::c_int snapshot_rc = snapshot_async_op(read_handle(op), &raw_op);
    if ((snapshot_rc as i64) != 0) {
        return snapshot_rc;
    }
    if (raw_op == null) {
        return 5 as c::c_int;
    }
    ?*CielBytes @raw = null;
    c::c_int rc = unsafe { ciel_async_finish_read(unsafe { raw_op as *CielAsyncOp }, &raw) };
    if ((rc as i64) == 0) {
        if (raw == null) {
            return 5 as c::c_int;
        }
        Bytes bytes = { handle: raw as *void };
        out->bytes = bytes;
        out->read = bytes_len(bytes);
        c::c_int close_rc = close_handle(read_handle_mut(op));
        if ((close_rc as i64) != 0) {
            return close_rc;
        }
    }
    return rc;
}

