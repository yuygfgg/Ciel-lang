Result<resource::Handle, Error> register_async_fd(*CielAsyncFd raw) {
    u64 @owner_id = 0;
    u64 @resource_id = 0;
    u64 @generation = 0;
    c::c_int rc = unsafe { ciel_resource_register_async_fd_handle(raw, &owner_id, &resource_id, &generation) };
    if ((rc as i64) != 0) {
        return Err(code_error(rc as i64));
    }
    return Ok(handle_from_parts(owner_id, resource_id, generation));
}

Result<resource::Handle, Error> register_async_fd_shared(*CielAsyncFd raw) {
    c::c_int retain_rc = unsafe { ciel_async_fd_retain(raw) };
    if ((retain_rc as i64) != 0) {
        return Err(code_error(retain_rc as i64));
    }
    Result<resource::Handle, Error> result = register_async_fd(raw);
    switch (result) {
        case Ok(handle):
            return Ok(handle);
        case Err(error):
            _ close_rc = unsafe { ciel_async_close(raw) };
            return Err(error);
    }
}

Result<resource::Handle, Error> register_async_listener(*CielAsyncTcpListener raw) {
    u64 @owner_id = 0;
    u64 @resource_id = 0;
    u64 @generation = 0;
    c::c_int rc = unsafe { ciel_resource_register_async_listener_handle(raw, &owner_id, &resource_id, &generation) };
    if ((rc as i64) != 0) {
        return Err(code_error(rc as i64));
    }
    return Ok(handle_from_parts(owner_id, resource_id, generation));
}

Result<resource::Handle, Error> register_async_op(*CielAsyncOp raw) {
    u64 @owner_id = 0;
    u64 @resource_id = 0;
    u64 @generation = 0;
    c::c_int rc = unsafe { ciel_resource_register_async_op_handle(raw, &owner_id, &resource_id, &generation) };
    if ((rc as i64) != 0) {
        return Err(code_error(rc as i64));
    }
    return Ok(handle_from_parts(owner_id, resource_id, generation));
}

c::c_int close_handle(*resource::Handle handle) {
    c::c_int rc = unsafe {
        ciel_resource_close_handle(
            unsafe { handle->owner_id },
            unsafe { handle->resource_id },
            unsafe { handle->generation }
        )
    };
    unsafe { handle->owner_id = 0; };
    unsafe { handle->resource_id = 0; };
    unsafe { handle->generation = 0; };
    return rc;
}

Result<resource::Handle, Error> register_async_fd_owned(*CielAsyncFd raw) {
    Result<resource::Handle, Error> result = register_async_fd(raw);
    switch (result) {
        case Ok(handle):
            return Ok(handle);
        case Err(error):
            _ close_rc = unsafe { ciel_async_close(raw) };
            return Err(error);
    }
}

Result<resource::Handle, Error> register_async_listener_owned(*CielAsyncTcpListener raw) {
    Result<resource::Handle, Error> result = register_async_listener(raw);
    switch (result) {
        case Ok(handle):
            return Ok(handle);
        case Err(error):
            _ close_rc = unsafe { ciel_async_tcp_close_listener(raw) };
            return Err(error);
    }
}

Result<resource::Handle, Error> register_async_op_owned(*CielAsyncOp raw) {
    Result<resource::Handle, Error> result = register_async_op(raw);
    switch (result) {
        case Ok(handle):
            return Ok(handle);
        case Err(error):
            _ cancel_rc = unsafe { ciel_async_cancel(raw) };
            return Err(error);
    }
}

Result<resource::Handle, Error> register_finished_async_fd(
    *CielAsyncFd raw,
    *resource::Handle op_handle
) {
    Result<resource::Handle, Error> result = register_async_fd(raw);
    switch (result) {
        case Ok(handle):
            c::c_int close_rc = close_handle(op_handle);
            if ((close_rc as i64) != 0) {
                return Err(code_error(close_rc as i64));
            }
            return Ok(handle);
        case Err(error):
            _ close_fd_rc = unsafe { ciel_async_close(raw) };
            _ close_op_rc = close_handle(op_handle);
            return Err(error);
    }
}

unsafe c::c_int register_finished_async_fd_out(
    *CielAsyncFd raw,
    *resource::Handle op_handle,
    *resource::Handle out
) {
    u64 @owner_id = 0;
    u64 @resource_id = 0;
    u64 @generation = 0;
    c::c_int register_rc = unsafe {
        ciel_resource_register_async_fd_handle(raw, &owner_id, &resource_id, &generation)
    };
    if ((register_rc as i64) != 0) {
        _ close_fd_rc = unsafe { ciel_async_close(raw) };
        _ close_op_rc = close_handle(op_handle);
        return register_rc;
    }
    unsafe { *out = handle_from_parts(owner_id, resource_id, generation); };
    c::c_int close_rc = close_handle(op_handle);
    if ((close_rc as i64) != 0) {
        return close_rc;
    }
    return 0 as c::c_int;
}

Result<*CielAsyncFd, Error> raw_async_fd(*const resource::Handle handle) {
    ?*CielAsyncFd @raw = null;
    c::c_int rc = unsafe {
        ciel_resource_async_fd_snapshot_handle(
            unsafe { handle->owner_id },
            unsafe { handle->resource_id },
            unsafe { handle->generation },
            &raw
        )
    };
    if ((rc as i64) != 0) {
        return Err(code_error(rc as i64));
    }
    if (raw == null) {
        return Err(code_error(5));
    }
    return Ok(unsafe { raw as *CielAsyncFd });
}

Result<*CielAsyncTcpListener, Error> raw_listener(*const AsyncTcpListener listener) {
    *const resource::Handle handle = listener_handle(listener);
    ?*CielAsyncTcpListener @raw = null;
    c::c_int rc = unsafe {
        ciel_resource_async_listener_snapshot_handle(
            unsafe { handle->owner_id },
            unsafe { handle->resource_id },
            unsafe { handle->generation },
            &raw
        )
    };
    if ((rc as i64) != 0) {
        return Err(code_error(rc as i64));
    }
    if (raw == null) {
        return Err(code_error(5));
    }
    return Ok(unsafe { raw as *CielAsyncTcpListener });
}

Result<*CielAsyncFd, Error> raw_stream(*const AsyncTcpStream stream) {
    return raw_async_fd(stream_handle(stream));
}

Result<*CielAsyncFd, Error> raw_read_half(*const AsyncTcpReadHalf half) {
    return raw_async_fd(read_half_handle(half));
}

Result<*CielAsyncFd, Error> raw_write_half(*const AsyncTcpWriteHalf half) {
    return raw_async_fd(write_half_handle(half));
}

Result<*CielBufferedReader, Error> raw_buffered_reader(*const BufferedStreamReader reader) {
    ?*CielBufferedReader raw = unsafe { reader->handle };
    if (raw == null) {
        return Err(code_error(5));
    }
    return Ok(raw);
}

c::c_int snapshot_async_op(*const resource::Handle handle, *?*CielAsyncOp out) {
    c::c_int rc = unsafe {
        ciel_resource_async_op_snapshot_handle(
            unsafe { handle->owner_id },
            unsafe { handle->resource_id },
            unsafe { handle->generation },
            out
        )
    };
    return rc;
}

Result<*CielAsyncOp, Error> raw_async_op(*const resource::Handle handle) {
    ?*CielAsyncOp @raw = null;
    c::c_int rc = snapshot_async_op(handle, &raw);
    if ((rc as i64) != 0) {
        return Err(code_error(rc as i64));
    }
    if (raw == null) {
        return Err(code_error(5));
    }
    return Ok(unsafe { raw as *CielAsyncOp });
}

?*void raw_async_op_or_null(*const resource::Handle handle) {
    ?*CielAsyncOp @raw = null;
    c::c_int rc = snapshot_async_op(handle, &raw);
    if ((rc as i64) != 0 || raw == null) {
        return raw as ?*void;
    }
    return raw as ?*void;
}

unsafe impl raw_operation(*const AsyncAccept op) {
    return raw_async_op_or_null(accept_handle(op));
}

unsafe impl raw_operation(*const AsyncConnect op) {
    return raw_async_op_or_null(connect_handle(op));
}

unsafe impl raw_operation(*const AsyncTcpRead op) {
    return raw_async_op_or_null(read_handle(op));
}

unsafe impl raw_operation(*const AsyncTcpWrite op) {
    return raw_async_op_or_null(write_handle(op));
}

unsafe impl raw_operation(*const AsyncBufferedRead op) {
    return raw_async_op_or_null(buffered_read_handle(op));
}

Result<*CielAsyncOp, Error> raw_accept(*const AsyncAccept op) {
    return raw_async_op(accept_handle(op));
}

Result<*CielAsyncOp, Error> raw_connect(*const AsyncConnect op) {
    return raw_async_op(connect_handle(op));
}

Result<*CielAsyncOp, Error> raw_read(*const AsyncTcpRead op) {
    return raw_async_op(read_handle(op));
}

Result<*CielAsyncOp, Error> raw_write(*const AsyncTcpWrite op) {
    return raw_async_op(write_handle(op));
}

Result<*CielAsyncOp, Error> raw_buffered_read(*const AsyncBufferedRead op) {
    return raw_async_op(buffered_read_handle(op));
}

*CielBytes raw_bytes(Bytes bytes) {
    return unsafe { bytes.handle as *CielBytes };
}

Result<*void, Error> box_message<M: Message>(M message) {
    M local = message;
    M cloned = clone_message(&local)?;
    ?*void boxed = unsafe { ciel_actor_box_copy(type_size<M>(), type_align<M>(), &cloned as *const void) };
    if (boxed == null) {
        return Err(code_error(5));
    }
    return Ok(boxed);
}

// Opens an async TCP listener bound to addr.
export Result<AsyncTcpListener, Error> listen_async(net::SocketAddr addr) = .listen_async {
    ?*CielAsyncTcpListener raw = unsafe { ciel_async_tcp_listen(raw_addr(addr)) };
    if (raw == null) {
        return Err(runtime_error());
    }
    return Ok(listener_from_handle(register_async_listener_owned(unsafe { raw as *CielAsyncTcpListener })?));
}

// Returns the local address bound to an async listener.
export Result<net::SocketAddr, Error> listener_addr(*const AsyncTcpListener listener) = .addr {
    ?*CielSocketAddr @raw = null;
    c::c_int rc = unsafe { ciel_async_tcp_listener_addr(raw_listener(listener)?, &raw) };
    if ((rc as i64) != 0) {
        return Err(code_error(rc as i64));
    }
    if (raw == null) {
        return Err(code_error(5));
    }
    return Ok(addr_from_raw(unsafe { raw as *CielSocketAddr }));
}

// Closes an async listener handle.
export Result<void, Error> close_listener(AsyncTcpListener @listener) = .close {
    c::c_int rc = close_handle(listener_handle_mut(&listener));
    if ((rc as i64) != 0) {
        return Err(code_error(rc as i64));
    }
    return Ok;
}

// Starts an async accept operation and returns its low-level token.
export Result<AsyncAccept, Error> accept_async(*const AsyncTcpListener listener) = .accept_async {
    ?*CielAsyncOp raw = unsafe { ciel_async_tcp_accept(raw_listener(listener)?) };
    if (raw == null) {
        return Err(runtime_error());
    }
    return Ok(accept_from_handle(register_async_op_owned(unsafe { raw as *CielAsyncOp })?));
}

// Starts an async connect operation and returns its low-level token.
export Result<AsyncConnect, Error> connect_async(net::SocketAddr addr) = .connect_async {
    ?*CielAsyncOp raw = unsafe { ciel_async_tcp_connect(raw_addr(addr)) };
    if (raw == null) {
        return Err(runtime_error());
    }
    return Ok(connect_from_handle(register_async_op_owned(unsafe { raw as *CielAsyncOp })?));
}

// Closes an async stream handle.
export Result<void, Error> close_stream(AsyncTcpStream @stream) = .close {
    c::c_int rc = close_handle(stream_handle_mut(&stream));
    if ((rc as i64) != 0) {
        return Err(code_error(rc as i64));
    }
    return Ok;
}

// Splits a stream into read and write halves that share the same runtime stream.
export Result<AsyncTcpSplit, Error> split(AsyncTcpStream @stream) = .split {
    *CielAsyncFd raw = raw_stream(&stream)?;
    resource::Handle write_handle_value = register_async_fd_shared(raw)?;
    resource::Handle read_handle_value =
        unsafe { resource::take_handle_in_place(stream_handle_mut(&stream)) };
    return Ok(unsafe { {
        read: read_half_from_handle(read_handle_value),
        write: write_half_from_handle(write_handle_value),
    } });
}

// Splits a stream and wraps the read half in a cancel-safe buffered reader.
export Result<AsyncTcpBufferedSplit, Error> buffered_split(
    AsyncTcpStream @stream,
    usize capacity
) = .buffered_split {
    AsyncTcpSplit @split_value = split(stream)?;
    ?*CielBufferedReader raw =
        unsafe { ciel_async_tcp_buffered_reader_new(raw_read_half(&split_value.read)?, capacity) };
    if (raw == null) {
        return Err(runtime_error());
    }
    resource::Handle read_handle_value = unsafe {
        resource::take_handle_in_place(read_half_handle_mut(&split_value.read))
    };
    resource::Handle write_handle_value = unsafe {
        resource::take_handle_in_place(write_half_handle_mut(&split_value.write))
    };
    return Ok(unsafe { {
        reader: unsafe { { handle: raw, fd_handle: read_handle_value } },
        write: write_half_from_handle(write_handle_value),
    } });
}

// Shuts down the read half of a stream.
export Result<void, Error> shutdown_read(*const AsyncTcpStream stream) = .shutdown_read {
    c::c_int rc = unsafe { ciel_async_tcp_shutdown_read(raw_stream(stream)?) };
    if ((rc as i64) != 0) {
        return Err(code_error(rc as i64));
    }
    return Ok;
}

// Shuts down a split read half.
export Result<void, Error> shutdown_read_half(*const AsyncTcpReadHalf half) = .shutdown_read {
    c::c_int rc = unsafe { ciel_async_tcp_shutdown_read(raw_read_half(half)?) };
    if ((rc as i64) != 0) {
        return Err(code_error(rc as i64));
    }
    return Ok;
}

// Shuts down the write half of a stream.
export Result<void, Error> shutdown_write(*const AsyncTcpStream stream) = .shutdown_write {
    c::c_int rc = unsafe { ciel_async_tcp_shutdown_write(raw_stream(stream)?) };
    if ((rc as i64) != 0) {
        return Err(code_error(rc as i64));
    }
    return Ok;
}

// Shuts down a split write half.
export Result<void, Error> shutdown_write_half(*const AsyncTcpWriteHalf half) = .shutdown_write {
    c::c_int rc = unsafe { ciel_async_tcp_shutdown_write(raw_write_half(half)?) };
    if ((rc as i64) != 0) {
        return Err(code_error(rc as i64));
    }
    return Ok;
}

// Returns the local address of an async stream.
export Result<net::SocketAddr, Error> stream_local_addr(*const AsyncTcpStream stream) = .local_addr {
    ?*CielSocketAddr @raw = null;
    c::c_int rc = unsafe { ciel_async_tcp_stream_local_addr(raw_stream(stream)?, &raw) };
    if ((rc as i64) != 0) {
        return Err(code_error(rc as i64));
    }
