    }
    if (raw_op == null) {
        return 5 as c::c_int;
    }
    ?*CielAsyncFd @raw = null;
    c::c_int rc = unsafe { ciel_async_tcp_finish_connect(unsafe { raw_op as *CielAsyncOp }, &raw) };
    if ((rc as i64) == 0) {
        if (raw == null) {
            return 5 as c::c_int;
        }
        c::c_int register_rc = unsafe {
            register_finished_async_fd_out(unsafe { raw as *CielAsyncFd }, connect_handle_mut(op), stream_handle_mut(out))
        };
        if ((register_rc as i64) != 0) {
