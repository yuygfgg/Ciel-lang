}

unsafe impl poll_done<ReadIntoResult>(*AsyncTcpReadInto op, *ReadIntoResult out) {
    ?*CielAsyncOp @raw_op = null;
    c::c_int snapshot_rc = snapshot_async_op(read_into_handle(op), &raw_op);
    if ((snapshot_rc as i64) != 0) {
        return snapshot_rc;
    }
    if (raw_op == null) {
        return 5 as c::c_int;
    }
    ?*u8 @raw = null;
    usize @len = 0;
    usize @cap = 0;
    c::c_int rc =
        unsafe { ciel_async_finish_read(unsafe { raw_op as *CielAsyncOp }, &raw, &len, &cap) };
    if ((rc as i64) == 0) {
        if (raw == null) {
            return 5 as c::c_int;
        }
        []u8 view = unsafe { storage::raw_from_ptr<u8>(unsafe { raw as *void }, cap) };
        storage::RawStorage<u8> raw_storage = unsafe { { storage: view } };
        out->buffer = unsafe { { storage: raw_storage, len: len } };
        out->read = len;
        c::c_int close_rc = close_handle(read_into_handle_mut(op));
        if ((close_rc as i64) != 0) {
            return close_rc;
        }
    }
    return rc;
}

