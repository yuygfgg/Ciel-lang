impl<T: wire::encode_value<Writer>> wire::encode_value(
    *const option::Option<T> value,
    *Writer writer
) {
    switch (*value) {
        case option::None:
            return push_chars(unsafe { &writer->out }, "null", 0);
        case option::Some(inner):
            return wire::encode_value(&inner, writer);
    }
}

impl<T: wire::decode_value<Reader>> wire::decode_value(
    meta::Type<option::Option<T>> target,
    *Reader reader
) {
    skip_ws(reader);
    if (!at_end(reader) && peek(reader) == 'n') {
        consume_literal(reader, "null")?;
        return Ok(option::None);
    }
    T value = wire::decode_value(meta::type_tag<T>(), reader)?;
    return Ok(option::Some(value));
}

impl<T> wire::encode_value(*const [0]T value, *Writer writer) {
    return push_chars(unsafe { &writer->out }, "[]", 0);
}

impl<T: wire::encode_value<Writer>> wire::encode_value(*const [1]T value, *Writer writer) {
    []const T items = (*value)[..];
    return write_slice_as_array(items, writer);
