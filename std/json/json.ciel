impl<T: wire::encode_value<Writer>> wire::encode_value(
    *const vec::Vec<T> value,
    *Writer writer
) {
    push_byte(unsafe { &writer->out }, '[' as u8, 0)?;
    []const T items = vec::vec_slice<T>(value);
    usize @i = 0;
    while (i < items.len) {
        if (i > 0) {
            push_byte(unsafe { &writer->out }, ',' as u8, 0)?;
        }
        T item = items[i];
        wire::encode_value(&item, writer)?;
        i = i + 1;
    }
    return push_byte(unsafe { &writer->out }, ']' as u8, 0);
}

impl<T: wire::decode_value<Reader>> wire::decode_value(
    meta::Type<vec::Vec<T>> target,
    *Reader reader
) {
    skip_ws(reader);
    usize start = unsafe { reader->offset };
    if (at_end(reader)) {
        return Err(error_at(wire::Eof, start, "expected JSON array"));
    }
    if (peek(reader) != '[') {
        return Err(error_at(wire::TypeMismatch, start, "expected JSON array"));
    }
    advance(reader);
    vec::Vec<T> @out;
    switch (vec::vec_new<T>(0)) {
        case Ok(value):
            out = value;
        case Err(_):
            return Err(storage_error(start));
    }
    skip_ws(reader);
    if (!at_end(reader) && peek(reader) == ']') {
        advance(reader);
        return Ok(out);
    }
    while (true) {
        T @item;
        switch (wire::decode_value(meta::type_tag<T>(), reader)) {
            case Ok(decoded):
                item = decoded;
            case Err(error):
                return Err(prepend_index_path(error, vec::vec_len<T>(&out))?);
        }
        switch (vec::vec_push<T>(&out, item)) {
            case Ok:
                {}
            case Err(_):
                return Err(storage_error(unsafe { reader->offset }));
        }
        skip_ws(reader);
        if (at_end(reader)) {
            return Err(error_at(wire::Eof, unsafe { reader->offset }, "unterminated array"));
        }
        if (peek(reader) == ',') {
            advance(reader);
            skip_ws(reader);
        } else if (peek(reader) == ']') {
            advance(reader);
            return Ok(out);
        } else {
            return Err(error_at(wire::Syntax, unsafe { reader->offset }, "expected array separator"));
        }
    }
}

impl<K: map::map_key + json_object_key, V: wire::encode_value<Writer>> wire::encode_value(
    *const map::HashMap<K, V> value,
    *Writer writer
) {
    push_byte(unsafe { &writer->out }, '{' as u8, 0)?;
    map::hash_map_for_each_index<K, V, wire::WireError>(value, |index, key, item| {
        if (index > 0) {
            push_byte(unsafe { &writer->out }, ',' as u8, 0)?;
        }
        text::Text name = encode_object_key(key)?;
        write_string_text(unsafe { &writer->out }, name)?;
        push_byte(unsafe { &writer->out }, ':' as u8, 0)?;
        wire::encode_value(item, writer)?;
        return Ok;
    })?;
    return push_byte(unsafe { &writer->out }, '}' as u8, 0);
}

impl<K: map::map_key + json_object_key, V: wire::decode_value<Reader>> wire::decode_value(
    meta::Type<map::HashMap<K, V>> target,
    *Reader reader
) {
    Value value = read_value(reader)?;
    []const Value members = object_members(&value)?;
    map::HashMap<K, V> @out;
    switch (map::hash_map_new<K, V>()) {
        case Ok(map_value):
            out = map_value;
        case Err(_):
            return Err(storage_error(0));
    }
    usize @i = 0;
    while (i < members.len) {
        text::Text @name;
        switch (members[i]) {
            case String(raw_name):
                name = raw_name;
            case Null:
                return Err(error_at(wire::InvalidValue, 0, "invalid JSON object key"));
            case Bool(_):
                return Err(error_at(wire::InvalidValue, 0, "invalid JSON object key"));
            case Number(_):
                return Err(error_at(wire::InvalidValue, 0, "invalid JSON object key"));
            case Array(_):
                return Err(error_at(wire::InvalidValue, 0, "invalid JSON object key"));
            case Object(_):
                return Err(error_at(wire::InvalidValue, 0, "invalid JSON object key"));
        }
        K key = decode_object_key(meta::type_tag<K>(), name)?;
        Value member_value = members[i + 1];
        V @decoded;
        switch (decode_json_slot(meta::type_tag<V>(), meta::type_tag<V>(), &member_value)) {
            case Ok(item):
                decoded = item;
            case Err(error):
                []const char path_name = text_slice_or_storage(name)?;
                return Err(prepend_field_path(error, path_name)?);
        }
        switch (map::hash_map_insert<K, V>(&out, key, decoded)) {
            case Ok(result):
                switch (result) {
                    case map::InsertResult::Inserted:
                        {}
                    case map::InsertResult::Replaced(_):
                        return Err(error_at(wire::DuplicateField, 0, "duplicate JSON object field"));
                }
            case Err(_):
                return Err(storage_error(0));
        }
        i = i + 2;
    }
    return Ok(out);
}
