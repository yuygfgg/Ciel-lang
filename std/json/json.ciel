impl<T> wire::decode_value(meta::Type<[0]T> target, *Reader reader) {
    Value value = read_value(reader)?;
    array_values_exact(&value, 0)?;
    meta::ArrayNil repr = {};
    return Ok(meta::from_repr<[0]T>(repr));
}

impl<T: wire::decode_value<Reader>> wire::decode_value(meta::Type<[1]T> target, *Reader reader) {
    Value value = read_value(reader)?;
    []const Value values = array_values_exact(&value, 1)?;
    T item0 = decode_array_item<T, T>(values, 0)?;
    return Ok([item0]);
}

impl<T: wire::decode_value<Reader>> wire::decode_value(meta::Type<[2]T> target, *Reader reader) {
    Value value = read_value(reader)?;
    []const Value values = array_values_exact(&value, 2)?;
    T item0 = decode_array_item<T, T>(values, 0)?;
    T item1 = decode_array_item<T, T>(values, 1)?;
    return Ok([item0, item1]);
}

impl<T: wire::decode_value<Reader>> wire::decode_value(meta::Type<[3]T> target, *Reader reader) {
    Value value = read_value(reader)?;
    []const Value values = array_values_exact(&value, 3)?;
    T item0 = decode_array_item<T, T>(values, 0)?;
    T item1 = decode_array_item<T, T>(values, 1)?;
    T item2 = decode_array_item<T, T>(values, 2)?;
    return Ok([item0, item1, item2]);
}

impl<T: wire::decode_value<Reader>> wire::decode_value(meta::Type<[4]T> target, *Reader reader) {
    Value value = read_value(reader)?;
    []const Value values = array_values_exact(&value, 4)?;
    T item0 = decode_array_item<T, T>(values, 0)?;
    T item1 = decode_array_item<T, T>(values, 1)?;
    T item2 = decode_array_item<T, T>(values, 2)?;
    T item3 = decode_array_item<T, T>(values, 3)?;
    return Ok([item0, item1, item2, item3]);
}

impl<T: wire::decode_value<Reader>> wire::decode_value(meta::Type<[5]T> target, *Reader reader) {
    Value value = read_value(reader)?;
    []const Value values = array_values_exact(&value, 5)?;
    T item0 = decode_array_item<T, T>(values, 0)?;
