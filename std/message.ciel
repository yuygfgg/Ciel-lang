export import /std/error;
export import /std/result;
import /std/meta;
import /std/meta as meta;

export unsafe interface<T> Result<T, Error> clone_message(*const T value);
export interface Message = clone_message;

unsafe impl clone_message(*const void value) {
    return Ok;
}

unsafe impl clone_message(*const bool value) {
    return Ok(*value);
}

unsafe impl clone_message(*const char value) {
    return Ok(*value);
}

unsafe impl clone_message(*const i8 value) {
    return Ok(*value);
}

unsafe impl clone_message(*const i16 value) {
    return Ok(*value);
}

unsafe impl clone_message(*const i32 value) {
    return Ok(*value);
}

unsafe impl clone_message(*const i64 value) {
    return Ok(*value);
}

unsafe impl clone_message(*const u8 value) {
    return Ok(*value);
}

unsafe impl clone_message(*const u16 value) {
    return Ok(*value);
}

unsafe impl clone_message(*const u32 value) {
    return Ok(*value);
}

unsafe impl clone_message(*const u64 value) {
    return Ok(*value);
}

unsafe impl clone_message(*const usize value) {
    return Ok(*value);
}

unsafe impl clone_message(*const f32 value) {
    return Ok(*value);
}

unsafe impl clone_message(*const f64 value) {
    return Ok(*value);
}

unsafe impl clone_message(*const Error value) {
    return Ok(*value);
}

unsafe impl<T: Message, E: Message> clone_message(*const Result<T, E> value) {
    switch (*value) {
        case Ok(ok):
            T copied = clone_message(&ok)?;
            return Ok(Ok(copied));
        case Err(err):
            E copied = clone_message(&err)?;
            return Ok(Err(copied));
    }
}

unsafe impl<F: CielFnValue> clone_message(*const F value) {
    return Ok(*value);
}

unsafe impl<C: ClosureValue> clone_message(*const C value) {
    meta::Repr<C> repr = meta::into_repr(value);
    meta::Repr<C> copied = clone_message(&repr)?;
    return Ok(meta::from_repr<C>(copied));
}

unsafe impl clone_message(*const meta::HNil value) {
    return Ok({});
}

unsafe impl<T: Message> clone_message(*const meta::Field<T> value) {
    T copied = clone_message(&value->value)?;
    return Ok({ name: value->name, value: copied });
}

unsafe impl<Head: Message, Tail: Message> clone_message(*const meta::HCons<Head, Tail> value) {
    Head head = clone_message(&value->head)?;
    Tail tail = clone_message(&value->tail)?;
    return Ok({ head: head, tail: tail });
}

unsafe impl<T: Message> clone_message(*const meta::Payload<T> value) {
    T copied = clone_message(&value->value)?;
    return Ok({ index: value->index, value: copied });
}

unsafe impl<P: Message> clone_message(*const meta::Variant<P> value) {
    P payload = clone_message(&value->payload)?;
    return Ok({ name: value->name, payload: payload });
}

unsafe impl clone_message(*const meta::CoNil value) {
    switch (*value) {
    }
}

unsafe impl<Head: Message, Tail: Message> clone_message(*const meta::Coproduct<Head, Tail> value) {
    switch (*value) {
        case meta::This(head):
            Head copied = clone_message(&head)?;
            return Ok(meta::This(copied));
        case meta::Next(tail):
            Tail copied = clone_message(&tail)?;
            return Ok(meta::Next(copied));
    }
}

unsafe impl clone_message(*const meta::ArrayNil value) {
    return Ok({});
}

unsafe impl<T: Message> clone_message(*const meta::ArrayChunk1<T> value) {
    T item0 = clone_message(&value->item0)?;
    return Ok({ item0: item0 });
}

unsafe impl<T: Message> clone_message(*const meta::ArrayChunk2<T> value) {
    T item0 = clone_message(&value->item0)?;
    T item1 = clone_message(&value->item1)?;
    return Ok({ item0: item0, item1: item1 });
}

