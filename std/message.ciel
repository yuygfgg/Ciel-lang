unsafe impl<L: Message, R: Message> clone_message(*const meta::ArrayCat<L, R> value) {
    L left = clone_message(&value->left)?;
    R right = clone_message(&value->right)?;
    return Ok({ left: left, right: right });
}

// Reserved marker: policy is defined by explicit library/runtime implementations.
export unsafe interface<T> bool share_handle_marker(*const T value);
export interface ShareHandle = share_handle_marker;

// Reserved marker: policy is defined by explicit library/runtime implementations.
export unsafe interface<T> bool thread_local_marker(*const T value);
export interface ThreadLocal = thread_local_marker;
