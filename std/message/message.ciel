unsafe impl<L: Message, R: Message> clone_message(
    *const meta::ArrayCat<L, R> value
) {
    meta::ArrayCatView<L, R> view = meta::array_cat_view(value);
    L left = clone_message(view.left)?;
    R right = clone_message(view.right)?;
    return Ok(unsafe { { left: left, right: right } });
}
