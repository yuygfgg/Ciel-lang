    return unsafe { { left: &value->left, right: &value->right } };
}

export ArrayNil array_nil() {
    return {};
}

// Compiler-recognized intrinsic building a borrowed structural representation
// from a visible value layout.
export RefRepr<T> as_ref_repr<T>(*const T value);

// Compiler-recognized intrinsic building an owned structural representation by
// copying from a visible value.
export Repr<T> into_repr<T>(*const T value);

// Compiler-recognized intrinsic reconstructing a visible value from its owned
// structural representation.
export T from_repr<T>(Repr<T> value);

// Compiler-recognized intrinsic building an instance-free schema from a visible
// value layout.
export Schema<T> schema<T>();
