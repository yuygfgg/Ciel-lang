// Concatenates two fixed-size array representation subtrees.
export struct ArrayCat<L, R> {
    L left;
    R right;
}

// Builds a borrowed structural representation from a visible value layout.
export RefRepr<T> as_ref_repr<T>(*const T value);

// Builds an owned structural representation by copying from a visible value.
export Repr<T> into_repr<T>(*const T value);

// Reconstructs a visible value from its owned structural representation.
export T from_repr<T>(Repr<T> value);
