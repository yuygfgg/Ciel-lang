// Compiler-recognized intrinsic returning the size in bytes of the concrete
// type argument.
export usize type_size<T>();

// Compiler-recognized intrinsic returning the alignment in bytes of the
// concrete type argument.
export usize type_align<T>();

// Compiler-recognized intrinsic returning whether the concrete type argument's
// runtime representation may contain GC-managed pointers and therefore needs
// scanned storage.
export bool type_needs_gc_scan<T>();

// Zero-sized type witness used by APIs that need a type as an input value.
// The compiler treats std meta::Type<T> as a phantom ABI witness: the type
// checker keeps T, but generated code uses one shared representation.
export struct Type<T> {}

// Constructs a zero-sized type witness for APIs that need a type as a value.
export Type<T> type_tag<T>() {
    return {};
}

// Read-only structural representation marker for a visible type.
// Type checking normalizes this marker to the ordinary SOP types below.
export unsafe struct RefRepr<T> {}

// Owned structural representation marker for a visible type.
// Type checking normalizes this marker to the ordinary SOP types below.
export unsafe struct Repr<T> {}

// Instance-free structural schema marker for a visible type.
// Type checking normalizes this marker to the ordinary schema node types below.
export unsafe struct Schema<T> {}

// Compiler-provided marker fact for Ciel ABI function-pointer values.
// User code cannot implement this interface directly.
export interface<T> bool ciel_fn_value_marker(*const T value);

// Constraint alias for Ciel ABI function-pointer values.
export interface CielFnValue = ciel_fn_value_marker;

// Compiler-provided marker fact for concrete closure instance values.
// User code cannot implement this interface directly.
export interface<T> bool closure_value_marker(*const T value);

// Constraint alias for concrete closure instance values.
export interface ClosureValue = closure_value_marker;

// Empty product-list node used in structural representations.
export struct HNil {}

// Product-list cons node used in structural representations.
export unsafe struct HCons<H, T> {
    H head;
    T tail;
}

// Safe read-only view of a product-list cons node.
export struct HConsView<H, T> {
    *const H head;
    *const T tail;
}

// Borrowed named struct field in a RefRepr product.
export unsafe struct FieldRef<T> {
    []const char name;
    *const T value;
}

// Safe read-only view of a borrowed named struct field.
export struct FieldRefView<T> {
    []const char name;
    *const T value;
}

// Owned named struct field in a Repr product.
export unsafe struct Field<T> {
    []const char name;
    T value;
}

// Safe read-only view of an owned named struct field.
export struct FieldView<T> {
    []const char name;
    *const T value;
}

// Instance-free named struct field schema.
export unsafe struct FieldSchema<T, R> {
    []const char name;
    Type<T> source_ty;
    Type<R> repr_ty;
}

// Safe read-only view of a named struct field schema.
export struct FieldSchemaView<T, R> {
    []const char name;
    Type<T> source_ty;
    Type<R> repr_ty;
}

// Borrowed positional enum payload in a RefRepr sum variant.
export unsafe struct PayloadRef<T> {
    usize index;
    *const T value;
}

// Safe read-only view of a borrowed positional enum payload.
export struct PayloadRefView<T> {
    usize index;
    *const T value;
}

// Owned positional enum payload in a Repr sum variant.
export unsafe struct Payload<T> {
    usize index;
    T value;
}

// Safe read-only view of an owned positional enum payload.
export struct PayloadView<T> {
    usize index;
    *const T value;
}

// Instance-free positional enum payload schema.
export unsafe struct PayloadSchema<T, R> {
    usize index;
    Type<T> source_ty;
    Type<R> repr_ty;
}

// Safe read-only view of a positional enum payload schema.
export struct PayloadSchemaView<T, R> {
    usize index;
    Type<T> source_ty;
    Type<R> repr_ty;
}

// Empty sum-list node used in structural representations.
export enum CoNil {}

// Sum-list cons node used in structural representations.
export enum Coproduct<H, T> {
    This(H),
    Next(T),
}

// Borrowed named enum variant in a RefRepr sum.
export unsafe struct VariantRef<P> {
    []const char name;
    P payload;
}

// Safe read-only view of a borrowed named enum variant.
export struct VariantRefView<P> {
    []const char name;
    *const P payload;
}

// Owned named enum variant in a Repr sum.
export unsafe struct Variant<P> {
    []const char name;
    P payload;
}

// Safe read-only view of an owned named enum variant.
export struct VariantView<P> {
    []const char name;
    *const P payload;
}

// Instance-free fixed-size array element schema.
export unsafe struct ElementSchema<T, R> {
    Type<T> source_ty;
    Type<R> repr_ty;
}

// Safe read-only view of a fixed-size array element schema.
export struct ElementSchemaView<T, R> {
    Type<T> source_ty;
    Type<R> repr_ty;
}

// Instance-free named enum variant schema.
export unsafe struct VariantSchema<P> {
    []const char name;
    P payload;
}

// Safe read-only view of a named enum variant schema.
export struct VariantSchemaView<P> {
    []const char name;
    *const P payload;
}

// Empty fixed-size array representation node.
export struct ArrayNil {}

