// Returns the size in bytes of the concrete type argument.
export usize type_size<T>();

// Returns the alignment in bytes of the concrete type argument.
export usize type_align<T>();

// Returns whether the concrete type argument's runtime representation may
// contain GC-managed pointers and therefore needs scanned storage.
export bool type_needs_gc_scan<T>();

// Zero-sized type witness used by APIs that need a type as an input value.
export struct Type<T> {}

// Read-only structural representation marker for a visible type.
// Type checking normalizes this marker to the ordinary SOP types below.
export struct RefRepr<T> {}

// Owned structural representation marker for a visible type.
// Type checking normalizes this marker to the ordinary SOP types below.
export struct Repr<T> {}

// Compiler-provided marker fact for Ciel ABI function-pointer values.
// User code cannot implement this interface directly.
export interface<T> bool ciel_fn_value_marker(*const T value);

// Constraint alias for Ciel ABI function-pointer values.
export interface CielFnValue = ciel_fn_value_marker;

// Compiler-provided marker fact for concrete closure instance values.
// User code cannot implement this interface directly.
export interface<T> bool closure_value_marker(*const T value);

// Constraint alias for concrete closure instance values.
export interface ClosureValue = closure_value_marker;

// Empty product-list node used in structural representations.
export struct HNil {}

// Product-list cons node used in structural representations.
export struct HCons<H, T> {
    H head;
    T tail;
}

// Borrowed named struct field in a RefRepr product.
export struct FieldRef<T> {
    []const char name;
    *const T value;
}

// Owned named struct field in a Repr product.
export struct Field<T> {
    []const char name;
    T value;
}

// Borrowed positional enum payload in a RefRepr sum variant.
export struct PayloadRef<T> {
    usize index;
    *const T value;
}

// Owned positional enum payload in a Repr sum variant.
export struct Payload<T> {
    usize index;
    T value;
}

// Empty sum-list node used in structural representations.
export enum CoNil {}

// Sum-list cons node used in structural representations.
export enum Coproduct<H, T> {
    This(H),
    Next(T),
}

// Borrowed named enum variant in a RefRepr sum.
export struct VariantRef<P> {
    []const char name;
    P payload;
}

// Owned named enum variant in a Repr sum.
export struct Variant<P> {
    []const char name;
    P payload;
}

// Empty fixed-size array representation node.
export struct ArrayNil {}

// Fixed-size array representation node for one element.
export struct ArrayChunk1<T> {
    T item0;
}

// Fixed-size array representation node for two elements.
export struct ArrayChunk2<T> {
    T item0;
    T item1;
}

