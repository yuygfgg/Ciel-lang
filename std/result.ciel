export import /std/result/core;
export import /std/error;
import /std/panic;

export T expect<T, E>(Result<T, E> value, []const char message) {
    switch (value) {
        case Ok(result):
            return result;
        case Err(error):
            panic(message);
    }
}

export T must<T, E>(Result<T, E> value) {
    return expect(value, "must failed");
}
