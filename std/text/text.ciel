// Re-exports Result for Text operations.
export import /std/result;
import /std/bytes as bytes;
import /std/iter as iter;
import /std/message;
import /std/storage as storage;

// Immutable runtime-backed text value stored as owned bytes.
export struct Text {
    bytes::Bytes bytes;
}

struct TextCharIter {
    []const u8 data;
    usize index;
}

// Errors produced by Text operations.
export enum TextError {
    Bytes(bytes::BytesError),
    Storage,
    ShortCopy,
}

impl format_error(*const TextError error) {
    switch (*error) {
        case Bytes(inner):
            return format_error(&inner);
        case Storage:
            return "text storage allocation failed";
        case ShortCopy:
            return "short text copy";
    }
}

unsafe impl clone_message(*const Text value) {
    bytes::Bytes copied = clone_message(&value->bytes)?;
    return Ok({ bytes: copied });
}

unsafe impl share_handle_marker(*const Text value) {
    return true;
}

impl iter::next<char>(*TextCharIter iter) {
    if (iter->index >= iter->data.len) {
        return iter::Done;
    }
    char value = iter->data[iter->index] as char;
    iter->index = iter->index + 1;
    return iter::Item(value);
}

// Returns an empty Text value.
export Result<Text, TextError> text_empty() {
    switch (bytes::bytes_empty()) {
        case Ok(value):
            return Ok({ bytes: value });
        case Err(error):
            return Err(Bytes(error));
    }
}

// Copies a character slice into an owned Text value.
export Result<Text, TextError> text_copy([]const char text) {
    switch (bytes::bytes_from_text(text)) {
        case Ok(value):
            return Ok({ bytes: value });
        case Err(error):
            return Err(Bytes(error));
    }
}

// Returns the byte length of the Text value.
export usize text_len(Text text) = .len {
    return bytes::bytes_len(text.bytes);
}

// Returns a cloned owned Bytes handle for the Text contents.
export Result<bytes::Bytes, TextError> text_to_bytes(Text text) = .to_bytes {
    return Ok(text.bytes);
}

// Iterates the stored UTF-8 bytes as char code units; this is not Unicode scalar decoding.
export _: iter::Iterator<char> text_chars(Text text) = .chars {
    TextCharIter out = { data: bytes::bytes_const_slice(text.bytes), index: 0 };
    return out;
}

// Copies Text contents into a mutable character slice allocation.
export Result<[]char, TextError> text_to_chars(Text text) = .to_chars {
    usize len = text_len(text);
    storage::RawStorage<char> @raw_storage;
    switch (unsafe { storage::raw_zeroed<char>(len) }) {
        case Ok(storage):
            raw_storage = storage;
        case Err(_):
            return Err(Storage);
    }
    []char out = unsafe { storage::raw_slice<char>(&raw_storage) };
    usize @copied = 0;
    switch (bytes::bytes_copy_to_chars(text.bytes, out)) {
        case Ok(value):
            copied = value;
        case Err(error):
            return Err(Bytes(error));
    }
    if (copied != len) {
        return Err(ShortCopy);
    }
    return Ok(out);
}

// Copies Text contents into a read-only character slice.
export Result<[]const char, TextError> text_to_slice(Text text) = .slice {
    []char chars = text_to_chars(text)?;
    return Ok(chars);
}
