// ciel-test: run
// expect-exit: 0
// expect-stdout: ABXO

import /std/async as async;
import /std/async_time as async_time;
import /std/lib;

#c_include "stdio.h"

unsafe extern "C" {
    i32 putchar(i32 ch);
}

void mark(i32 ch) {
    unsafe { putchar(ch) };
}

async Result<bool, Error> keep_looping(
    i32 value
) {
    await async_time::sleep_ms(0)?;
    return Ok(value < 3);
}

async Result<i32, Error> next_i(i32 value) {
    await async_time::sleep_ms(0)?;
    return Ok(value + 1);
}

async Result<void, Error> run_loop() {
    defer mark(79);
    for (i32 @i = 0; await keep_looping(i)?; i = await next_i(i)?) {
        defer mark((65 as i32) + i);
        await async_time::sleep_ms(0)?;
        if (i == 0) {
            continue;
        }
        if (i == 1) {
            break;
        }
    }
    mark(88);
    return Ok;
}

i32 main() {
    must(async::block_on(run_loop()));
    return 0;
}
