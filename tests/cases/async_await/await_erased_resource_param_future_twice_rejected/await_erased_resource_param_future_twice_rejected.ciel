// ciel-test: error
// expect-error: use of moved resource `future`

import /std/async as async;
import /std/io as io;
import /std/result;

async Result<void, Error> close_later(io::File @file) {
    io::close(file)?;
    return Ok;
}

async Result<void, Error> bad([]const char path) {
    io::File file = io::open_read(path)?;
    async::Future<Result<void, Error>> future = close_later(file);
    await future?;
    await future?;
    return Ok;
}

i32 main() {
    return 0;
}
