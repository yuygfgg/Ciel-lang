// ciel-test: run
// expect-exit: 0
// expect-stdout: AB

import /std/async as async;
import /std/async_time as async_time;
import /std/panic;
import /std/result;

#c_include "stdio.h"

unsafe extern "C" {
    i32 putchar(i32 ch);
}

void mark(i32 ch) {
    unsafe { putchar(ch) };
}

async Result<usize, Error> marked_delay(i32 ch, usize value) {
    mark(ch);
    await async_time::sleep_ms(0)?;
    return Ok(value);
}

async Result<usize, Error> ordered() {
    usize first = await marked_delay(65, 2)?;
    usize second = await marked_delay(66, first + 3)?;
    return Ok(first + second);
}

i32 main() {
    if (must(async::block_on(ordered())) != 7) {
        return 1;
    }
    return 0;
}
