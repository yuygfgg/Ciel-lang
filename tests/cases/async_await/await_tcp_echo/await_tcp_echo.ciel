// ciel-test: run
// expect-exit: 0
// expect-stdout: 4

import /std/async as async;
import /std/async_net as anet;
import /std/bytes as bytes;
import /std/io as io;
import /std/net as net;
import /std/result;

bool same_prefix([]u8 got, []const u8 want) {
    if (got.len < want.len) {
        return false;
    }
    usize @i = 0;
    while (i < want.len) {
        if (got[i] != want[i]) {
            return false;
        }
        i = i + 1;
    }
    return true;
}

async Result<usize, Error> serve_once(anet::AsyncTcpListener listener) {
    anet::AsyncTcpStream @server = await anet::accept(&listener)?;
    anet::close_listener(listener)?;
    bytes::Bytes inbound = await anet::read(&server, 8)?;
    if (bytes::bytes_len(inbound) != 4) {
        return Err(code_error(40));
    }
    server = await anet::write_all(server, inbound)?;

    bytes::Bytes eof = await anet::read(&server, 8)?;
    usize eof_len = bytes::bytes_len(eof);
    anet::close_stream(server)?;
    return Ok(eof_len);
}

async Result<usize, Error> run_client(net::SocketAddr bound) {
    anet::AsyncTcpStream @client = await anet::connect(bound)?;
    [4]u8 payload = [112 as u8, 105 as u8, 110 as u8, 103 as u8];
    bytes::Bytes out = bytes::bytes_copy(payload[..])?;
    client = await anet::write_all(client, out)?;

    bytes::Bytes echoed = await anet::read(&client, 8)?;
    if (bytes::bytes_len(echoed) != 4) {
        return Err(code_error(41));
    }
    [4]u8 @got = [0;];
    usize copied = bytes::bytes_copy_to(echoed, got[..])?;
    if (copied != 4 || !same_prefix(got[..], payload[..])) {
        return Err(code_error(42));
    }

    anet::shutdown_write(&client)?;
    anet::close_stream(client)?;
    return Ok(copied);
}

async Result<usize, Error> drive() {
    anet::AsyncTcpListener listener =
        anet::listen_async(net::parse_addr("127.0.0.1:0")?)?;
    net::SocketAddr bound = anet::listener_addr(&listener)?;

    async::Task<usize> server = async::spawn<usize>(serve_once(listener))?;
    usize copied = await run_client(bound)?;
    usize eof_len = await server?;
    return Ok(copied + eof_len);
}

i32 main() {
    must(io::print_value(must(async::block_on(drive()))));
    return 0;
}
