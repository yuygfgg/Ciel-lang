// ciel-test: error
// expect-error: use of moved resource `future`

import /std/async as async;
import /std/io as io;
import /std/result;

async Result<io::File, Error> open_file([]const char path) {
    return io::open_read(path);
}

Result<void, Error> bad([]const char path) {
    _ future = open_file(path);
    io::File first = async::block_on(future)?;
    io::close(first)?;
    io::File second = async::block_on(future)?;
    io::close(second)?;
    return Ok;
}

i32 main() {
    return 0;
}
