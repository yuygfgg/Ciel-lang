// ciel-test: run
// expect-exit: 0
// expect-stdout: 2

import /std/async as async;
import /std/async_net as anet;
import /std/bytes as bytes;
import /std/io as io;
import /std/net as net;
import /std/result;

async Result<usize, Report> ready_value() {
    return Ok(1);
}

async Result<usize, Report> delayed_write(
    anet::AsyncTcpListener listener,
    async::Receiver<usize> release
) {
    anet::AsyncTcpStream @server = await anet::accept(&listener)?;
    anet::close_listener(listener)?;
    _ signal = await async::recv<usize>(release)?;
    [2]u8 payload = [120 as u8, 121 as u8];
    bytes::Bytes out = bytes::bytes_copy(payload[..])?;
    server = await anet::write_all(server, out)?;
    anet::shutdown_write(&server)?;
    anet::close_stream(server)?;
    return Ok(2);
}

Result<usize, Report> bytes_len_result(
    Result<bytes::Bytes, anet::AsyncNetError> result
) {
    bytes::Bytes bytes = result?;
    return Ok(bytes::bytes_len(bytes));
}

async Result<usize, Report> drive() {
    anet::AsyncTcpListener listener = anet::listen_async(
        net::parse_addr("127.0.0.1:0")?
    )?;
    net::SocketAddr bound = anet::listener_addr(&listener)?;
    async::ChannelPair<usize> write_release = async::channel<usize>(1)?;
    async::Task<usize, Report> server = async::spawn<usize>(
        delayed_write(listener, write_release.receiver)
    )?;

    anet::AsyncTcpStream client = await anet::connect(bound)?;
    anet::AsyncTcpSplit halves = anet::split(client)?;
    anet::BufferedStreamReader reader = anet::buffered_reader_from_split(
        halves, 4
    )?;

    Result<usize, Report> picked = await select {
        case bytes = anet::read_buffered(&reader, 2):
            bytes_len_result(bytes);
        case ready = ready_value():
            ready;
    };
    if (picked? != 1) {
        return Err(code_error(100));
    }

    await async::send<usize>(write_release.sender, 1)?;
    bytes::Bytes bytes = await anet::read_buffered(&reader, 2)?;
    usize written = await server?;
    if (written != 2) {
        return Err(code_error(101));
    }
    return Ok(bytes::bytes_len(bytes));
}

i32 main() {
    must(io::print_value(must(async::block_on(drive()))));
    return 0;
}
