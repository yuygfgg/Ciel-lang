// ciel-test: run
// expect-exit: 0
// expect-stdout: 2

import /std/async as async;
import /std/async_net as anet;
import /std/async_time as async_time;
import /std/io as io;
import /std/net as net;
import /std/result;

async Result<usize, Error> ready_value() {
    return Ok(1);
}

async Result<usize, Error> delayed_write(anet::AsyncTcpListener listener) {
    anet::AsyncTcpStream server = await anet::accept(listener)?;
    await async_time::sleep_ms(20)?;
    [2]u8 payload = [120 as u8, 121 as u8];
    anet::Bytes out = anet::bytes_copy(payload[..])?;
    await anet::write_all(server, out)?;
    anet::shutdown_write(server)?;
    anet::close_stream(server)?;
    return Ok(2);
}

Result<usize, Error> bytes_len_result(Result<anet::Bytes, Error> result) {
    anet::Bytes bytes = result?;
    return Ok(anet::bytes_len(bytes));
}

async Result<usize, Error> drive() {
    anet::AsyncTcpListener listener =
        anet::listen_async(net::parse_addr("127.0.0.1:0")?)?;
    net::SocketAddr bound = anet::listener_addr(listener)?;
    async::Task<usize> server = async::spawn<usize>(delayed_write(listener))?;

    anet::AsyncTcpStream client = await anet::connect(bound)?;
    anet::AsyncTcpSplit halves = anet::split(client)?;
    anet::BufferedStreamReader reader = anet::buffered_reader(halves.read, 4)?;

    Result<usize, Error> picked = await select {
        case bytes = anet::read_buffered(reader, 2): bytes_len_result(bytes);
        case ready = ready_value(): ready;
    };
    if (picked? != 1) {
        return Err(code_error(100));
    }

    anet::Bytes bytes = await anet::read_buffered(reader, 2)?;
    usize written = await server?;
    anet::close_listener(listener)?;
    if (written != 2) {
        return Err(code_error(101));
    }
    return Ok(anet::bytes_len(bytes));
}

i32 main() {
    must(io::print_value(must(async::block_on(drive()))));
    return 0;
}
