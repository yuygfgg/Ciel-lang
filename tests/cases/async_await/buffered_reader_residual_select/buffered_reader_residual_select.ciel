// ciel-test: run
// expect-exit: 0
// expect-stdout: 4

import /std/async as async;
import /std/async_net as anet;
import /std/async_time as async_time;
import /std/bytes as bytes;
import /std/io as io;
import /std/net as net;
import /std/result;

Result<usize, Error> bytes_len_result(Result<bytes::Bytes, anet::AsyncNetError> result) {
    bytes::Bytes bytes = result?;
    return Ok(bytes::bytes_len(bytes));
}

Result<usize, Error> timeout_tag(Result<void, async::AsyncError> result) {
    result?;
    return Ok(99);
}

async Result<usize, Error> write_payload(
    anet::AsyncTcpListener listener,
    async::Sender<usize> write_done
) {
    anet::AsyncTcpStream @server = await anet::accept(&listener)?;
    anet::close_listener(listener)?;
    [4]u8 payload = [97 as u8, 98 as u8, 99 as u8, 100 as u8];
    bytes::Bytes out = bytes::bytes_copy(payload[..])?;
    server = await anet::write_all(server, out)?;
    await async::send<usize>(write_done, 1)?;
    anet::shutdown_write(&server)?;
    anet::close_stream(server)?;
    return Ok(4);
}

async Result<usize, Error> drive() {
    anet::AsyncTcpListener listener =
        anet::listen_async(net::parse_addr("127.0.0.1:0")?)?;
    net::SocketAddr bound = anet::listener_addr(&listener)?;
    async::ChannelPair<usize> write_done = async::channel<usize>(1)?;
    async::Task<usize, Error> server =
        async::spawn<usize>(write_payload(listener, write_done.sender))?;

    anet::AsyncTcpStream client = await anet::connect(bound)?;
    anet::AsyncTcpSplit halves = anet::split(client)?;
    anet::BufferedStreamReader reader = anet::buffered_reader_from_split(halves, 4)?;
    _ ready = await async::recv<usize>(write_done.receiver)?;

    bytes::Bytes first = await anet::read_buffered(&reader, 2)?;
    if (bytes::bytes_len(first) != 2) {
        return Err(code_error(80));
    }

    Result<usize, Error> picked = await select {
        case bytes = anet::read_buffered(&reader, 2): bytes_len_result(bytes);
        case slept = async_time::sleep_ms(20): timeout_tag(slept);
    };
    usize second_len = picked?;
    if (second_len != 2) {
        return Err(code_error(81));
    }

    bytes::Bytes eof = await anet::read_buffered(&reader, 2)?;
    if (bytes::bytes_len(eof) != 0) {
        return Err(code_error(82));
    }
    anet::AsyncTcpReadHalf half = anet::into_read_half(reader)?;
    anet::shutdown_read_half(&half)?;
    usize written = await server?;
    return Ok(bytes::bytes_len(first) + second_len + (written - 4));
}

i32 main() {
    must(io::print_value(must(async::block_on(drive()))));
    return 0;
}
