// ciel-test: run
// expect-exit: 0
// expect-stdout: 3

import /std/lib;
import /std/bytes as bytes;

i32 main() {
    [3]u8 payload = [120 as u8, 121 as u8, 122 as u8];
    bytes::Bytes value = must(bytes::bytes_copy(payload[..]));
    if (bytes::bytes_len(value) != 3) {
        return 1;
    }
    must(print_value(bytes::bytes_len(value)));
    return 0;
}
