// ciel-test: run
// expect-exit: 0
// expect-stdout: 5

import /std/async as async;
import /std/io;
import /std/panic;
import /std/result;

async Result<usize, Report> pending_send(
    async::Sender<usize> sender,
    async::Sender<usize> ready
) {
    await async::send<usize>(ready, 1)?;
    await async::send<usize>(sender, 2)?;
    return Ok(1);
}

async Result<usize, Report> drive() {
    async::ChannelPair<usize> pair = async::channel<usize>(1)?;
    async::ChannelPair<usize> ready = async::channel<usize>(1)?;
    async::try_send<usize>(pair.sender, 1)?;
    async::Task<usize, Report> task = async::spawn<usize>(
        pending_send(pair.sender, ready.sender)
    )?;
    _ sender_ready = await async::recv<usize>(ready.receiver)?;
    async::close_receiver<usize>(pair.receiver)?;
    Result<usize, Report> result = await task;
    switch (result) {
        case Err(_):
            return Ok(5);
        case Ok(_):
            return Ok(1);
    }
}

i32 main() {
    must(print_value(must(async::block_on(drive()))));
    return 0;
}
