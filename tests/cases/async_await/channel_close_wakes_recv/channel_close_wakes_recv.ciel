// ciel-test: run
// expect-exit: 0
// expect-stdout: 3

import /std/async as async;
import /std/io;
import /std/panic;
import /std/result;

async Result<usize, Report> wait_closed(
    async::Receiver<usize> receiver,
    async::Sender<usize> ready
) {
    await async::send<usize>(ready, 1)?;
    switch (await async::recv<usize>(receiver)) {
        case Err(_):
            return Ok(3);
        case Ok(_):
            return Ok(1);
    }
}

async Result<usize, Report> drive() {
    async::ChannelPair<usize> pair = async::channel<usize>(1)?;
    async::ChannelPair<usize> ready = async::channel<usize>(1)?;
    async::Task<usize, Report> waiter = async::spawn<usize>(
        wait_closed(pair.receiver, ready.sender)
    )?;
    _ waiter_ready = await async::recv<usize>(ready.receiver)?;
    async::close<usize>(pair.sender)?;
    return await waiter;
}

i32 main() {
    must(print_value(must(async::block_on(drive()))));
    return 0;
}
