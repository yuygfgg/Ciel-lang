// ciel-test: run
// expect-exit: 0
// expect-stdout: 13

import /std/async as async;
import /std/async_time as async_time;
import /std/io;
import /std/panic;
import /std/result;

Result<usize, Error> send_reserved(
    Result<async::SendPermit<usize>, async::AsyncError> result
) {
    async::SendPermit<usize> permit = result?;
    async::permit_send<usize>(permit, 99)?;
    return Ok(9);
}

Result<usize, Error> timer_value(
    Result<void, async::AsyncError> result
) {
    result?;
    return Ok(2);
}

async Result<usize, Error> drive() {
    async::ChannelPair<usize> pair = async::channel<usize>(1)?;
    async::try_send<usize>(pair.sender, 1)?;
    Result<usize, Error> picked = await select {
        case permit = async::reserve<usize>(pair.sender):
            send_reserved(permit);
        case slept = async_time::sleep_ms(1):
            timer_value(slept);
    };
    if (picked? != 2) {
        return Err(code_error(70));
    }
    usize first = await async::recv<usize>(pair.receiver)?;
    async::try_send<usize>(pair.sender, 3)?;
    usize second = await async::recv<usize>(pair.receiver)?;
    async::close<usize>(pair.sender)?;
    async::close_receiver<usize>(pair.receiver)?;
    return Ok(first * 10 + second);
}

i32 main() {
    must(print_value(must(async::block_on(drive()))));
    return 0;
}
