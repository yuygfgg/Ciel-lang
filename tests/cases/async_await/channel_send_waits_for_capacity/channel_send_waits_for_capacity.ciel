// ciel-test: run
// expect-exit: 0
// expect-stdout: 43

import /std/async as async;
import /std/async_time as async_time;
import /std/io;
import /std/panic;
import /std/result;

async Result<usize, Error> send_after_space(async::Sender<usize> sender) {
    await async::send<usize>(sender, 9)?;
    return Ok(4);
}

async Result<usize, Error> drive() {
    async::ChannelPair<usize> pair = async::channel<usize>(1)?;
    async::try_send<usize>(pair.sender, 3)?;
    async::Task<usize> sender = async::spawn<usize>(send_after_space(pair.sender))?;
    await async_time::sleep_ms(1)?;
    usize first = await async::recv<usize>(pair.receiver)?;
    usize task_value = await sender?;
    usize second = await async::recv<usize>(pair.receiver)?;
    async::close_receiver<usize>(pair.receiver)?;
    return Ok(first * 10 + task_value + second);
}

i32 main() {
    must(print_value(must(async::block_on(drive()))));
    return 0;
}
