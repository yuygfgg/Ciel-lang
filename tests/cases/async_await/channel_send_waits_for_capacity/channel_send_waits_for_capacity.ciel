// ciel-test: run
// expect-exit: 0
// expect-stdout: 43

import /std/async as async;
import /std/io;
import /std/panic;
import /std/result;

async Result<usize, Report> send_after_space(
    async::Sender<usize> sender,
    async::Sender<usize> ready
) {
    await async::send<usize>(ready, 1)?;
    await async::send<usize>(sender, 9)?;
    return Ok(4);
}

async Result<usize, Report> drive() {
    async::ChannelPair<usize> pair = async::channel<usize>(1)?;
    async::ChannelPair<usize> ready = async::channel<usize>(1)?;
    async::try_send<usize>(pair.sender, 3)?;
    async::Task<usize, Report> sender = async::spawn<usize>(
        send_after_space(pair.sender, ready.sender)
    )?;
    _ sender_ready = await async::recv<usize>(ready.receiver)?;
    usize first = await async::recv<usize>(pair.receiver)?;
    usize task_value = await sender?;
    usize second = await async::recv<usize>(pair.receiver)?;
    async::close_receiver<usize>(pair.receiver)?;
    return Ok(first * 10 + task_value + second);
}

i32 main() {
    must(print_value(must(async::block_on(drive()))));
    return 0;
}
