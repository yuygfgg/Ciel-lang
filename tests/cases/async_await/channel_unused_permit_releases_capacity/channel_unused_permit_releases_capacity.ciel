// ciel-test: run
// expect-exit: 0

import /std/async as async;
import /std/error;

async Result<void, Report> reserve_and_return(
    async::Sender<usize> sender
) {
    async::SendPermit<usize> permit = await async::reserve<usize>(sender)?;
    return Ok;
}

async Result<usize, Report> drive() {
    async::ChannelPair<usize> pair = async::channel<usize>(1)?;
    await reserve_and_return(pair.sender)?;
    async::try_send<usize>(pair.sender, 41)?;
    usize value = await async::recv<usize>(pair.receiver)?;
    async::close<usize>(pair.sender)?;
    async::close_receiver<usize>(pair.receiver)?;
    return Ok(value);
}

i32 main() {
    switch (async::block_on(drive())) {
        case Ok(value):
            if (value == 41) {
                return 0;
            }
            return 1;
        case Err(_):
            return 2;
    }
}
