// ciel-test: run
// expect-exit: 0
// expect-stdout: 19

import /std/async;
import /std/async_time as async_time;
import /std/io;
import /std/panic;
import /std/result;

struct Wrapped<T> {
    Future<T> inner;
}

unsafe impl<T> awaitable_future<T>(*const Wrapped<T> awaitable) {
    return awaitable->inner.handle;
}

unsafe impl<T> abort_future(*Wrapped<T> awaitable) {
    Future<T> inner = awaitable->inner;
    return abort_future(&inner);
}

async Result<usize, Error> compute(usize value) {
    await async_time::sleep_ms(0)?;
    return Ok(value + 3);
}

async Result<usize, Error> await_wrapped(usize value) {
    Wrapped<Result<usize, Error>> wrapped = { inner: compute(value) };
    return await wrapped;
}

i32 main() {
    Wrapped<Result<usize, Error>> wrapped = { inner: compute(5) };
    Task<usize> task = must(spawn<usize>(wrapped));
    usize from_spawn = must(block_on(task));
    usize from_await = must(block_on(await_wrapped(8)));
    must(print_value(from_spawn + from_await));
    return 0;
}
