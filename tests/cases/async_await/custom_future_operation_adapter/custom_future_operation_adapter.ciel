// ciel-test: run
// expect-exit: 0
// expect-stdout: 5
// run-arg: @tmp/custom_future_operation_adapter.txt

import /std/async as async;
import /std/async;
import /std/async/adapter;
import /std/async_io as aio;
import /std/c as c;
import /std/env as env;
import /std/io as io;
import /std/result;

unsafe extern "C" {
    opaque struct CielAsyncOp;
    opaque struct CielBytes;

    c::c_int ciel_async_finish_read(*CielAsyncOp op, *?*CielBytes out);
}

struct WrappedRead {
    aio::AsyncRead inner;
}

unsafe impl raw_operation(*const WrappedRead op) {
    return op->inner.handle;
}

unsafe impl poll_done<aio::Bytes>(WrappedRead op, *aio::Bytes out) {
    ?*CielBytes @raw = null;
    c::c_int rc = unsafe {
        ciel_async_finish_read(unsafe { op.inner.handle as *CielAsyncOp }, &raw)
    };
    if ((rc as i64) == 0) {
        if (raw == null) {
            return 5 as c::c_int;
        }
        out->handle = raw as *void;
    }
    return rc;
}

unsafe impl abort_future(*WrappedRead op) {
    return aio::cancel_read(op->inner);
}

async Result<usize, Error> read_with_wrapper(aio::AsyncFd file) {
    aio::AsyncRead read = aio::read_bytes_async(file, 16)?;
    WrappedRead wrapped = { inner: read };
    aio::Bytes bytes = await async::future_from_op<WrappedRead, aio::Bytes>(wrapped)?;
    return Ok(aio::bytes_len(bytes));
}

i32 main() {
    []const char path = must(env::arg(1));
    must(io::with_create<void>(path, |file| {
        io::write_text(file, "hello")?;
        return Ok;
    }));
    aio::AsyncFd file = must(aio::open_async_read(path));
    usize len = must(async::block_on(read_with_wrapper(file)));
    must(aio::close_async(file));
    must(io::print_value(len));
    return 0;
}
