// ciel-test: error
// expect-error: cannot erase resource-affine future state

import /std/async as async;
import /std/io as io;
import /std/result;

async Result<void, Error> close_later(io::File @file) {
    io::close(file)?;
    return Ok;
}

async Result<void, Error> drive(async::Future<Result<void, Error>> future) {
    await future?;
    return Ok;
}

async Result<void, Error> bad([]const char path) {
    io::File file = io::open_read(path)?;
    await drive(close_later(file))?;
    return Ok;
}

i32 main() {
    return 0;
}
