// ciel-test: dependency

import /std/meta as meta;

export struct Packet {
    []const u8 data;
}

export usize len(meta::Repr<Packet> repr) {
    meta::HConsView<meta::Field<[]const u8>, meta::HNil> repr_view = meta::hcons_view(&repr);
    meta::FieldView<[]const u8> field = meta::field_view(repr_view.head);
    return (*field.value).len;
}
