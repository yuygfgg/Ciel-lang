// ciel-test: dependency

import /std/meta as meta;

export struct Packet {
    i64 id;
}

export i64 read_id(meta::RefRepr<Packet> repr) {
    meta::HConsView<meta::FieldRef<i64>, meta::HNil> repr_view = meta::hcons_view(&repr);
    meta::FieldRefView<i64> field = meta::field_ref_view(repr_view.head);
    return *field.value;
}
