// ciel-test: error
// expect-error: non-static borrowed read-only slice type `[]const usize`

import /std/async as async;
import /std/async_time as async_time;
import /std/result;

async Result<usize, Error> read_first([]const usize view) {
    return Ok(view[0]);
}

async Result<usize, Error> bad_future() {
    [1]usize values = [41;];
    async::Future<Result<usize, Error>> future = read_first(values[..]);
    await async_time::sleep_ms(0)?;
    return await future;
}

i32 main() {
    return 0;
}
