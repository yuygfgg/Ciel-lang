// ciel-test: error
// expect-error: is not async-frame-safe across `await`
// expect-error: borrowed structural meta representation

import /std/async as async;
import /std/async_time as async_time;
import /std/meta as meta;
import /std/result;

struct Packet {
    i64 id;
}

i64 read_id(meta::RefRepr<Packet> repr) {
    meta::HConsView<meta::FieldRef<i64>, meta::HNil> repr_view = meta::to_view(
        &repr
    );
    meta::FieldRefView<i64> field = meta::to_view(repr_view.head);
    return *field.value;
}

async Result<i64, Error> broken() {
    Packet packet = { id: 1234 };
    meta::RefRepr<Packet> repr = meta::as_ref_repr(&packet);
    await async_time::sleep_ms(0)?;
    return Ok(read_id(repr));
}

i32 main() {
    i64 n = must(async::block_on(broken()));
    return (n - 1234) as i32;
}
