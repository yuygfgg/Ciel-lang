// ciel-test: run
// expect-exit: 0

import /std/async as async;
import /std/async_time as async_time;
import /std/meta as meta;
import /std/result;

struct Packet {
    i64 id;
}

async Result<usize, Error> broken() {
    meta::Schema<Packet> schema = meta::schema<Packet>();
    await async_time::sleep_ms(0)?;
    meta::HConsView<meta::FieldSchema<i64, i64>, meta::HNil> schema_view =
        meta::hcons_view(&schema);
    meta::FieldSchemaView<i64, i64> field = meta::field_schema_view(
        schema_view.head
    );
    return Ok(field.name.len);
}

i32 main() {
    usize n = must(async::block_on(broken()));
    if (n == 0) {
        return 1;
    }
    return 0;
}
