// ciel-test: run
// expect-exit: 0
// expect-stdout: 28

import /std/async as async;
import /std/async_time as async_time;
import /std/io;
import /std/panic;
import /std/result;

async Result<usize, Error> add_after_two_awaits(usize value) {
    await async_time::sleep_ms(0)?;
    await async_time::sleep_ms(1)?;
    return Ok(value + 3);
}

async Result<usize, Error> nested_loop_branch_sum(usize limit) {
    usize @i = 0;
    usize @sum = 0;
    while (i < limit) {
        if ((i % 2) == 0) {
            await async_time::sleep_ms(0)?;
            sum = sum + i;
        } else {
            await async_time::sleep_ms(0)?;
            sum = sum + (i * 2);
        }
        i = i + 1;
    }
    return Ok(sum);
}

async Result<usize, Error> outer() {
    usize first = await add_after_two_awaits(4)?;
    usize second = await nested_loop_branch_sum(4)?;
    await async_time::sleep_ms(0)?;
    return Ok(first + second + 11);
}

i32 main() {
    must(print_value(must(async::block_on(outer()))));
    return 0;
}
