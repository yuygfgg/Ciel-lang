// ciel-test: error
// expect-error: mutable slice type

import /std/async as async;
import /std/async_time as async_time;
import /std/result;

async Result<usize, Error> main_async() {
    []i64 view = [1, 2, 3];
    await async_time::sleep_ms(0)?;
    return Ok(view.len);
}

i32 main() {
    Result<usize, Error> value = async::block_on(main_async());
    switch (value) {
        case Ok(_):
            return 0;
        case Err(_):
            return 1;
    }
}
