// ciel-test: error
// expect-error: is not async-frame-safe across `await`
// expect-error: resource-affine type

import /std/async_time as async_time;
import /std/io as io;
import /std/option as option;
import /std/result;

async Result<void, Error> keep_option([]const char path) {
    option::Option<io::File> maybe = option::Some(io::open_read(path)?);
    await async_time::sleep_ms(0)?;
    switch (maybe) {
        case option::Some(file):
            io::close(file)?;
        case option::None:
            {}
    }
    return Ok;
}

i32 main() {
    return 0;
}
