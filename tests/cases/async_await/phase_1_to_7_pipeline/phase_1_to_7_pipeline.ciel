// ciel-test: run
// expect-exit: 0
// expect-stdout: 71

import /std/async as async;
import /std/async_time as async_time;
import /std/io;
import /std/message;
import /std/panic;
import /std/result;

struct Packet {
    usize value;
}

derive Message<Packet>;

Result<usize, Report> packet_value(
    Result<Packet, async::AsyncError> result
) {
    Packet packet = result?;
    return Ok(packet.value);
}

async Result<Packet, Report> build_packet(
    usize seed
) {
    await async_time::sleep_ms(0)?;
    return Ok({ value: seed + 1 });
}

async Result<usize, Report> produce(
    async::Sender<Packet> sender, usize seed
) {
    Packet packet = await build_packet(seed)?;
    await async::send<Packet>(sender, packet)?;
    return Ok(packet.value + 10);
}

async Result<usize, Report> delayed(
    usize value, u64 ms
) {
    await async_time::sleep_ms(ms)?;
    return Ok(value);
}

async Result<usize, Report> controlled(
    async::Sender<usize> ready,
    async::Receiver<usize> release,
    usize value
) {
    await async::send<usize>(ready, value)?;
    _ signal = await async::recv<usize>(release)?;
    return Ok(value);
}

async Result<usize, Report> drive() {
    async::ChannelPair<Packet> pair = async::channel<Packet>(1)?;
    async::Task<usize, Report> producer = async::spawn<usize>(
        produce(pair.sender, 5)
    )?;

    Packet first = await async::recv<Packet>(pair.receiver)?;
    usize producer_value = await producer?;

    async::Task<usize, Report> fast = async::spawn<usize>(delayed(7, 1))?;
    Result<usize, Report> picked = await select {
        case packet = async::recv<Packet>(pair.receiver):
            packet_value(packet);
        case done = fast:
            done;
    };
    usize selected = picked?;

    async::try_send<Packet>(pair.sender, { value: 8 })?;
    Packet second = await async::recv<Packet>(pair.receiver)?;

    async::TaskGroup<usize, Report> group = async::task_group<usize, Report>()?;
    async::ChannelPair<usize> slow_ready = async::channel<usize>(1)?;
    async::ChannelPair<usize> quick_ready = async::channel<usize>(1)?;
    async::ChannelPair<usize> slow_release = async::channel<usize>(1)?;
    async::ChannelPair<usize> quick_release = async::channel<usize>(1)?;
    async::Task<usize, Report> slow = async::spawn<usize>(
        controlled(slow_ready.sender, slow_release.receiver, 4)
    )?;
    async::Task<usize, Report> quick = async::spawn<usize>(
        controlled(quick_ready.sender, quick_release.receiver, 3)
    )?;
    async::group_add<usize>(&group, slow)?;
    async::group_add<usize>(&group, quick)?;
    _ slow_started = await async::recv<usize>(slow_ready.receiver)?;
    _ quick_started = await async::recv<usize>(quick_ready.receiver)?;
    await async::send<usize>(quick_release.sender, 1)?;
    usize quick_value = await quick?;
    if (quick_value != 3) {
        return Err(code_error(70));
    }
    usize first_group = await async::group_next<usize>(&group)?;
    await async::send<usize>(slow_release.sender, 1)?;
    usize second_group = await async::group_next<usize>(&group)?;
    async::group_close<usize>(&group)?;

    Result<Result<void, async::AsyncError>, async::AsyncError> timed = await async::timeout(
        async_time::sleep_ms(0), 100
    );
    Result<void, async::AsyncError> inner = timed?;
    inner?;

    return Ok(
        first.value +
        producer_value +
        selected +
        second.value +
        first_group * 10 +
        second_group
    );
}

i32 main() {
    must(print_value(must(async::block_on(drive()))));
    return 0;
}
