// ciel-test: error
// expect-error: use of moved resource `future`

import /std/async_time as async_time;
import /std/result;

async Result<usize, Error> compute(usize value) {
    await async_time::sleep_ms(0)?;
    return Ok(value + 1);
}

async Result<void, Error> bad() {
    _ future = compute(1);
    usize first = await future?;
    usize second = await future?;
    if (first == second) {
        return Err(text_error("unreachable"));
    }
    return Ok;
}

i32 main() {
    return 0;
}
