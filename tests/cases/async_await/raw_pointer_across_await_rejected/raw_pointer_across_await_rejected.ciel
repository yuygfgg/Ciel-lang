// ciel-test: error
// expect-error: is not async-frame-safe across `await`
// expect-error: raw pointer type

import /std/async as async;
import /std/async_time as async_time;
import /std/result;

async Result<i64, Error> main_async() {
    i64 value = 10;
    *i64 ptr = &value;
    await async_time::sleep_ms(0)?;
    return Ok(*ptr);
}

i32 main() {
    Result<i64, Error> value = async::block_on(main_async());
    switch (value) {
        case Ok(_):
            return 0;
        case Err(_):
            return 1;
    }
}
