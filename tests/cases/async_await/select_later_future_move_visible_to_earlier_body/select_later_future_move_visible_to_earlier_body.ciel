// ciel-test: error
// expect-error: use of moved resource `later`

import /std/async as async;
import /std/async_time as async_time;
import /std/result;

async Result<usize, Error> after(u64 ms, usize value) {
    await async_time::sleep_ms(ms)?;
    return Ok(value);
}

bool consume_future(
    async::Future<Result<usize, Error>> future
) {
    return true;
}

async Result<bool, Error> bad() {
    async::Future<Result<usize, Error>> later = after(1, 7);
    bool picked = await biased select {
        case slept = async_time::sleep_ms(0):
            consume_future(later);
        case value = later:
            true;
    };
    return Ok(picked);
}

i32 main() {
    return 0;
}
