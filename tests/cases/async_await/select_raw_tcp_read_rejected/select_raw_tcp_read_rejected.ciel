// ciel-test: error
// expect-error: does not implement `cancel_safe_marker`

import /std/async as async;
import /std/async_net as anet;
import /std/result;

async Result<anet::Bytes, Error> bad_select(anet::AsyncTcpStream stream) {
    anet::AsyncTcpRead op = anet::read_bytes(stream, 16)?;
    return await select {
        case bytes = async::future_from_op<anet::AsyncTcpRead, anet::Bytes>(op): bytes;
    };
}

i32 main() {
    return 0;
}
