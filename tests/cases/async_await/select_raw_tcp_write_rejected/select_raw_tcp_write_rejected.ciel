// ciel-test: error
// expect-error: does not implement `cancel_safe_marker`

import /std/async as async;
import /std/async_net as anet;
import /std/result;

async Result<usize, Error> bad_select(anet::AsyncTcpStream stream, anet::Bytes data) {
    anet::AsyncTcpWrite op = anet::write_bytes(stream, data)?;
    return await select {
        case written = async::future_from_op(op): written;
    };
}

i32 main() {
    return 0;
}
