// ciel-test: run
// expect-exit: 0
// expect-stdout: 1

import /std/async as async;
import /std/async_net as anet;
import /std/async_time as async_time;
import /std/io as io;
import /std/net as net;
import /std/result;

Result<usize, Error> tag_stream(Result<anet::AsyncTcpStream, anet::AsyncNetError> result, usize value) {
    anet::AsyncTcpStream stream = result?;
    anet::close_stream(stream)?;
    return Ok(value);
}

Result<usize, Error> tag_sleep(Result<void, async::AsyncError> result, usize value) {
    result?;
    return Ok(value);
}

async Result<usize, Error> ready_task() {
    return Ok(4);
}

async Result<usize, Error> drive() {
    anet::AsyncTcpListener listener =
        anet::listen_async(net::parse_addr("127.0.0.1:0")?)?;
    net::SocketAddr bound = anet::listener_addr(&listener)?;
    async::Task<usize> task = async::spawn<usize>(ready_task())?;

    Result<usize, Error> picked = await select {
        case connected = anet::connect(bound): tag_stream(connected, 1);
        case accepted = anet::accept(&listener): tag_stream(accepted, 2);
        case slept = async_time::sleep_ms(5): tag_sleep(slept, 3);
        case done = task: done;
    };
    usize winner = picked?;
    if (winner < 1 || winner > 4) {
        return Err(code_error(70));
    }
    async::cancel(&task)?;
    anet::close_listener(listener)?;
    return Ok(1);
}

i32 main() {
    must(io::print_value(must(async::block_on(drive()))));
    return 0;
}
