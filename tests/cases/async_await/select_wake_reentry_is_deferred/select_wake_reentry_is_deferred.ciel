// ciel-test: run
// expect-exit: 0

import /std/async;
import /std/async as async;
import /std/async_time as async_time;
import /std/error;
import /std/panic;
import /std/result;

resource unsafe struct Selectable<T> {
    Future<T> inner;
}

unsafe impl<T> awaitable_future<T>(*const Selectable<T> future) {
    return awaitable_future<T>(unsafe { &future->inner });
}

unsafe derive<T> cancel_safe_marker<Selectable<T>>;

unsafe impl<T> abort_future(*Selectable<T> future) {
    abort_future(unsafe { &future->inner })?;
    return Ok;
}

async Result<usize, Report> consume_after_trigger(
    async::Receiver<usize> trigger,
    async::Receiver<usize> data
) {
    _ released = await async::recv<usize>(trigger)?;
    return Ok(await async::recv<usize>(data)?);
}

async Result<void, Report> release_select(
    async::Sender<usize> trigger
) {
    await async_time::sleep_ms(10)?;
    await async::send<usize>(trigger, 1)?;
    return Ok;
}

Result<usize, Report> reject_reservation(
    Result<async::SendPermit<usize>, async::AsyncError> reserved
) {
    async::SendPermit<usize> permit = reserved?;
    async::permit_send<usize>(permit, 99)?;
    return Err(code_error(91));
}

async Result<usize, Report> drive() {
    async::ChannelPair<usize> trigger = async::channel<usize>(1)?;
    async::ChannelPair<usize> data = async::channel<usize>(1)?;
    async::try_send<usize>(data.sender, 7)?;

    async::Task<void, Report> releaser = async::spawn<void>(
        release_select(trigger.sender)
    )?;
    Selectable<Result<usize, Report>> consumer = unsafe {
        { inner: consume_after_trigger(trigger.receiver, data.receiver) }
    };
    Result<usize, Report> selected = await biased select {
        case value = consumer:
            value;
        case reserved = async::reserve<usize>(data.sender):
            reject_reservation(reserved);
    };
    await releaser?;
    return selected;
}

i32 main() {
    if (must(async::block_on(drive())) != 7) {
        return 1;
    }
    return 0;
}
