// ciel-test: run
// expect-exit: 0
// run-arg: @tmp/async_await_select_winner_resource_binding_returns.txt

import /std/async as async;
import /std/async_time as async_time;
import /std/env as env;
import /std/io as io;
import /std/result;

async Result<io::File, Error> open_file() {
    []const char path = env::arg(1)?;
    return Ok(io::open_read(path)?);
}

async Result<io::File, Error> select_file() {
    return await biased select {
        case file = open_file(): file;
        case slept = async_time::sleep_ms(10000): Err(text_error("timer won"));
    };
}

i32 main() {
    []const char path = must(env::arg(1));
    must(io::with_create<void>(path, |file| {
        io::write_text(&file, "select-return")?;
        return Ok;
    }));

    io::File file = must(async::block_on(select_file()));
    [16]u8 @buffer = [0;];
    usize n = must(io::read(&file, buffer[..]));
    if (n != 13) {
        return 1;
    }
    must(io::close(file));
    return 0;
}
