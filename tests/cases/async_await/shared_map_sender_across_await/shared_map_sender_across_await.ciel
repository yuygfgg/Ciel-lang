// ciel-test: run
// expect-exit: 0
// expect-stdout: 42

import /std/async as async;
import /std/async_time as async_time;
import /std/io;
import /std/map as map;
import /std/message;
import /std/panic;
import /std/result;
import /std/shared_map as shared_map;

enum Event {
    Value(usize),
}

unsafe impl clone_message(*const Event value) {
    return Ok(*value);
}

async Result<void, Error> dispatch_after_yield(
    shared_map::SharedMap<u32, async::Sender<Event>> registry,
    u32 key,
    usize value
) {
    await async_time::sleep_ms(0)?;
    _ found = shared_map::shared_map_get(registry, key)?;
    switch (found) {
        case shared_map::SharedMapFound(sender):
            await async::send<Event>(sender, Value(value))?;
        case shared_map::SharedMapMissing:
            return Err(text_error("missing shared map entry"));
    }
    return Ok;
}

async Result<usize, Error> drive() {
    shared_map::SharedMap<u32, async::Sender<Event>> registry =
        shared_map::shared_map_new<u32, async::Sender<Event>>()?;
    async::ChannelPair<Event> pair = async::channel<Event>(1)?;
    _ inserted = shared_map::shared_map_insert(registry, 7, pair.sender)?;
    switch (inserted) {
        case map::Inserted:
            {}
        case map::Replaced(_):
            return Err(text_error("unexpected replacement"));
    }

    _ task = async::spawn<void>(dispatch_after_yield(registry, 7, 42))?;
    Event event = await async::recv<Event>(pair.receiver)?;
    await task?;

    switch (event) {
        case Value(value):
            return Ok(value);
    }
}

i32 main() {
    must(print_value(must(async::block_on(drive()))));
    return 0;
}
