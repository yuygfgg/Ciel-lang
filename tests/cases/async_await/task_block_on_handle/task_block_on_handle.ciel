// ciel-test: run
// expect-exit: 0
// expect-stdout: 31

import /std/async as async;
import /std/async_time as async_time;
import /std/io;
import /std/panic;
import /std/result;

i32 main() {
    async::Task<usize> task = must(async::spawn<usize>(async || {
        await async_time::sleep_ms(1)?;
        return Ok(31);
    }));
    must(print_value(must(async::block_on(task))));
    return 0;
}
