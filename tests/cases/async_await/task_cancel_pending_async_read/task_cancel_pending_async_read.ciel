// ciel-test: run
// expect-exit: 0
// expect-stdout: 7

import /std/async as async;
import /std/async_io as aio;
import /std/async_time as async_time;
import /std/c as c;
import /std/io as io;
import /std/os/fd as fd;
import /std/panic;
import /std/result;

#c_include "unistd.h"

unsafe extern "C" {
    c::c_int pipe(*c::c_int fds);
    c::c_int close(c::c_int fd);
}

Result<aio::AsyncFd, Error> pipe_read_end(*c::c_int write_fd_out) {
    [2]c::c_int @fds = [0 as c::c_int;];
    c::c_int rc = unsafe { pipe(&fds[0]) };
    if ((rc as i64) != 0) {
        return Err(code_error(5));
    }
    *write_fd_out = fds[1];
    fd::RawFd raw = unsafe { fd::from_raw_fd(fds[0]) };
    return unsafe { aio::async_from_raw_fd(raw) };
}

async Result<usize, Error> read_until_cancelled(aio::AsyncFd read_fd) {
    aio::Bytes inbound = await aio::read_bytes(&read_fd, 8)?;
    aio::close_async(read_fd)?;
    return Ok(aio::bytes_len(inbound));
}

Result<usize, Error> drive() {
    c::c_int @write_fd = -1 as c::c_int;
    aio::AsyncFd read_fd = pipe_read_end(&write_fd)?;
    async::Task<usize> task = async::spawn<usize>(read_until_cancelled(read_fd))?;
    async::block_on(async_time::sleep_ms(10))?;
    async::cancel<usize>(&task)?;
    if (!async::is_finished<usize>(&task)?) {
        return Err(code_error(71));
    }
    _ close_writer = unsafe { close(write_fd) };
    switch (async::block_on(task)) {
        case Err(_):
            return Ok(7);
        case Ok(_):
            return Err(code_error(72));
    }
}

i32 main() {
    switch (drive()) {
        case Ok(value):
            must(io::print_value(value));
            return 0;
        case Err(_):
            return 4;
    }
}
