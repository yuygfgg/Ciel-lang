// ciel-test: run
// expect-exit: 0
// expect-stdout: 7

import /std/async as async;
import /std/async_net as anet;
import /std/async_time as async_time;
import /std/bytes as bytes;
import /std/io as io;
import /std/net as net;
import /std/panic;
import /std/result;

async Result<usize, Report> read_until_cancelled(
    anet::AsyncTcpListener listener
) {
    anet::AsyncTcpStream @stream = await anet::accept(&listener)?;
    anet::close_listener(listener)?;
    [1]u8 ready = [82 as u8];
    bytes::Bytes signal = bytes::bytes_copy(ready[..])?;
    stream = await anet::write_all(stream, signal)?;
    bytes::Bytes inbound = await anet::read(&stream, 8)?;
    anet::close_stream(stream)?;
    return Ok(bytes::bytes_len(inbound));
}

async Result<anet::AsyncTcpStream, Report> connect_and_wait_ready(
    net::SocketAddr bound
) {
    anet::AsyncTcpStream client = await anet::connect(bound)?;
    bytes::Bytes signal = await anet::read(&client, 1)?;
    if (bytes::bytes_len(signal) != 1) {
        return Err(code_error(70));
    }
    return Ok(client);
}

Result<usize, Report> drive() {
    net::SocketAddr requested = net::parse_addr("127.0.0.1:0")?;
    anet::AsyncTcpListener listener = anet::listen_async(requested)?;
    net::SocketAddr bound = anet::listener_addr(&listener)?;
    async::Task<usize, Report> task = async::spawn<usize>(
        read_until_cancelled(listener)
    )?;
    anet::AsyncTcpStream client = async::block_on(
        connect_and_wait_ready(bound)
    )?;

    async::block_on(async_time::sleep_ms(10))?;
    async::cancel<usize>(&task)?;
    if (!async::is_finished<usize>(&task)?) {
        return Err(code_error(71));
    }
    Result<usize, Report> result = async::block_on(task);
    _ close_client = anet::close_stream(client);
    switch (result) {
        case Err(_):
            return Ok(7);
        case Ok(_):
            return Err(code_error(72));
    }
}

i32 main() {
    switch (drive()) {
        case Ok(value):
            must(io::print_value(value));
            return 0;
        case Err(_):
            return 4;
    }
}
