// ciel-test: run
// expect-exit: 0

import /std/async as async;
import /std/async_time as async_time;
import /std/channel as channel;
import /std/error;
import /std/panic;
import /std/result;

async Result<void, Report> run_until_released(
    async::Sender<usize> ready,
    channel::Channel<usize> release
) {
    async::try_send<usize>(ready, 1)?;
    // Keep the task poll active without burning a CPU core.
    _ released = channel::channel_recv<usize>(&release)?;
    return Ok;
}

async Result<void, Report> drive() {
    channel::Channel<usize> release = channel::make_channel<usize>()?;
    async::ChannelPair<usize> ready = async::channel<usize>(1)?;
    async::Task<void, Report> task = async::spawn<void>(
        run_until_released(ready.sender, release)
    )?;

    Result<usize, async::AsyncError> started_result = await async::recv<usize>(
        ready.receiver
    );
    Result<void, async::AsyncError> cancel_result = async::cancel<void, Report>(
        &task
    );
    Result<bool, async::AsyncError> finished_status =
        async::is_finished<void, Report>(&task);
    Result<void, channel::ChannelError> release_result =
        channel::channel_send<usize>(&release, 1);
    Result<Result<void, Report>, async::AsyncError> completion = await async::timeout(
        task, 1000
    );
    Result<void, channel::ChannelError> close_result =
        channel::channel_close<usize>(&release);

    _ started = started_result?;
    cancel_result?;
    bool finished_while_running = finished_status?;
    release_result?;
    close_result?;
    if (finished_while_running) {
        return Err(code_error(1));
    }
    switch (completion) {
        case Err(_):
            return Err(code_error(3));
        case Ok(result):
            switch (result) {
                case Ok:
                    return Err(code_error(2));
                case Err(_):
                    return Ok;
            }
    }
    return Err(code_error(4));
}

i32 main() {
    must(async::block_on(drive()));
    return 0;
}
