// ciel-test: run
// expect-exit: 0

import /std/async as async;
import /std/error;
import /std/panic;
import /std/result;

async Result<usize, Report> ready_value() {
    return Ok(9);
}

async Result<void, Report> drive() {
    async::TaskGroup<usize, Report> group = async::task_group<usize, Report>()?;
    async::Task<usize, Report> task = async::spawn<usize>(ready_value())?;
    async::group_add<usize, Report>(&group, task)?;
    if ((await task?) != 9) {
        return Err(code_error(1));
    }
    async::group_close<usize, Report>(&group)?;
    if ((await async::group_next<usize, Report>(&group))? != 9) {
        return Err(code_error(2));
    }
    return Ok;
}

i32 main() {
    must(async::block_on(drive()));
    return 0;
}
