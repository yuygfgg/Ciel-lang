// ciel-test: run
// expect-exit: 0
// expect-stdout: 39

import /std/async as async;
import /std/async_time as async_time;
import /std/io;
import /std/panic;
import /std/result;

async Result<usize, Error> after(u64 ms, usize value) {
    await async_time::sleep_ms(ms)?;
    return Ok(value);
}

async Result<usize, Error> drive() {
    async::TaskGroup<usize> group = async::task_group<usize>()?;
    async::Task<usize> slow = async::spawn<usize>(after(20, 9))?;
    async::Task<usize> fast = async::spawn<usize>(after(1, 3))?;
    async::group_add<usize>(&group, slow)?;
    async::group_add<usize>(&group, fast)?;
    usize first = await async::group_next<usize>(&group)?;
    usize second = await async::group_next<usize>(&group)?;
    async::group_close<usize>(&group)?;
    return Ok(first * 10 + second);
}

i32 main() {
    must(print_value(must(async::block_on(drive()))));
    return 0;
}
