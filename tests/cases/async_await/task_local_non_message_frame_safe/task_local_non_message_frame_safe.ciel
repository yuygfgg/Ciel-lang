// ciel-test: run
// expect-exit: 0
// expect-stdout: 6

import /std/async as async;
import /std/async_time as async_time;
import /std/io;
import /std/panic;
import /std/result;

struct LocalState {
    async::Future<Result<void, Error>> pending;
    usize value;
}

async Result<usize, Error> join_task(async::Task<usize> task) {
    return await task;
}

i32 main() {
    async::Task<usize> task = must(async::spawn<usize>(async || {
        LocalState state = {
            pending: async_time::sleep_ms(1),
            value: 6,
        };
        await state.pending?;
        return Ok(state.value);
    }));
    must(print_value(must(async::block_on(join_task(task)))));
    return 0;
}
