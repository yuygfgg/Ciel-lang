// ciel-test: run
// expect-exit: 0
// expect-stdout: 6

import /std/async as async;
import /std/async_time as async_time;
import /std/io;
import /std/panic;
import /std/result;

async Result<usize, Error> join_task(async::Task<usize> task) {
    return await task;
}

i32 main() {
    async::Task<usize> task = must(async::spawn<usize>(async || {
        async::Future<Result<void, async::AsyncError>> pending = async_time::sleep_ms(1);
        usize value = 6;
        await pending?;
        return Ok(value);
    }));
    must(print_value(must(async::block_on(join_task(task)))));
    return 0;
}
