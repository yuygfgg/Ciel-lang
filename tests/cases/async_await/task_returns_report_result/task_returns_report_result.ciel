// ciel-test: run
// expect-exit: 0
// expect-stdout: 1

import /std/async as async;
import /std/error/basic as basic;
import /std/io;
import /std/panic;
import /std/result;

Result<usize, Error> fail_locally() {
    return Err(basic::code_error(77));
}

async Result<usize, Report> fail_in_task() {
    usize value = fail_locally()?;
    return Ok(value);
}

i32 main() {
    async::Task<usize, Report> task = must(
        async::spawn<usize, Report>(fail_in_task())
    );
    switch (async::block_on(task)) {
        case Err(_):
            must(print_value(1));
        case Ok(_):
            return 2;
    }
    return 0;
}
