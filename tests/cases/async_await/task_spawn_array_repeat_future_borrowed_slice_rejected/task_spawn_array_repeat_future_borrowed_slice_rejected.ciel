// ciel-test: error
// expect-error: `async::spawn` future state does not implement `Message`
// expect-error: future state `futures` state `element *` state `view` has borrowed read-only slice type `[]const i64`

import /std/async as async;
import /std/result;

async Result<usize, Report> len_later(
    []const i64 view
) {
    return Ok(view.len);
}

async Result<usize, Report> keep_array(
    [1]async::Future<Result<usize, Report>> futures
) {
    return Ok(0);
}

i32 main() {
    [3]i64 values = [1, 2, 3];
    [1]async::Future<Result<usize, Report>> futures = [len_later(values[..]);];
    _ task = must(async::spawn<usize>(keep_array(futures)));
    return 0;
}
