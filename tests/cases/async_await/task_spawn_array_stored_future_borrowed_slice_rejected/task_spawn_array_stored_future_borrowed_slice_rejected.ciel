// ciel-test: error
// expect-error: `async::spawn` future state does not implement `Message`
// expect-error: future state `futures` state `element 0` state `view` has borrowed read-only slice type `[]const i64`

import /std/async as async;
import /std/result;

async Result<usize, Error> len_later([]const i64 view) {
    return Ok(view.len);
}

async Result<usize, Error> keep_array([1]async::Future<Result<usize, Error>> futures) {
    return Ok(0);
}

async::Task<usize> spawn_array_future() {
    [3]i64 values = [1, 2, 3];
    [1]async::Future<Result<usize, Error>> futures = [len_later(values[..])];
    return must(async::spawn<usize>(keep_array(futures)));
}

i32 main() {
    _ task = spawn_array_future();
    return 0;
}
