// ciel-test: error
// expect-error: `async::spawn` future state does not implement `Message`
// expect-error: future state `view` has borrowed read-only slice type `[]const i64`

import /std/async as async;
import /std/result;

async Result<usize, Error> len_later([]const i64 view) {
    return Ok(view.len);
}

async::Task<usize, Error> spawn_assigned_future() {
    [3]i64 values = [1, 2, 3];
    async::Future<Result<usize, Error>> future;
    future = len_later(values[..]);
    return must(async::spawn<usize>(future));
}

i32 main() {
    _ task = spawn_assigned_future();
    return 0;
}
