// ciel-test: error
// expect-error: `async::spawn` async closure must not take parameters

import /std/async as async;
import /std/result;

i32 main() {
    Result<async::Task<usize, Report>, Report> task =
        async::spawn<usize, Report>(
            async |usize value| {
                return Ok(value);
            }
        );
    return 0;
}
