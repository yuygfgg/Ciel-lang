// ciel-test: error
// expect-error: `async::spawn` future state does not implement `Message`
// expect-error: future state `view` has borrowed read-only slice type `[]const i64`

import /std/async as async;
import /std/result;

enum FutureChoice {
    One(async::Future<Result<usize, Error>>),
    Empty,
}

async Result<usize, Error> len_later([]const i64 view) {
    return Ok(view.len);
}

async::Task<usize> spawn_enum_payload_future() {
    [3]i64 values = [1, 2, 3];
    FutureChoice choice = One(len_later(values[..]));
    switch (choice) {
        case One(future):
            return must(async::spawn<usize>(future));
        case Empty:
            return must(async::spawn<usize>(async || {
                return Ok(0);
            }));
    }
    return must(async::spawn<usize>(async || {
        return Ok(1);
    }));
}

i32 main() {
    _ task = spawn_enum_payload_future();
    return 0;
}
