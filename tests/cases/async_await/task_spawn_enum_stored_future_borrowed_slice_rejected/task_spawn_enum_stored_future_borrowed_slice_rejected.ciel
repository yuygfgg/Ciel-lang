// ciel-test: error
// expect-error: `async::spawn` future state does not implement `Message`
// expect-error: future state `choice` state `One#0` state `view` has borrowed read-only slice type `[]const i64`

import /std/async as async;
import /std/result;

enum FutureChoice {
    One(async::Future<Result<usize, Error>>),
    Empty,
}

async Result<usize, Error> len_later([]const i64 view) {
    return Ok(view.len);
}

async Result<usize, Error> keep_choice(FutureChoice choice) {
    return Ok(0);
}

async::Task<usize> spawn_enum_future() {
    [3]i64 values = [1, 2, 3];
    FutureChoice choice = One(len_later(values[..]));
    return must(async::spawn<usize>(keep_choice(choice)));
}

i32 main() {
    _ task = spawn_enum_future();
    return 0;
}
