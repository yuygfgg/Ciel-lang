// ciel-test: run
// expect-exit: 0
// run-arg: @tmp/async_await_spawn_existing_future_resource.txt

import /std/async as async;
import /std/env as env;
import /std/io as io;
import /std/panic;
import /std/result;
import /std/text as text;

async Result<usize, Error> read_one(io::File file) {
    [1]u8 @buffer = [0;];
    usize n = io::read(&file, buffer[..])?;
    io::close(file)?;
    return Ok(n);
}

i32 main() {
    []const char path = must(env::arg(1));
    must(io::with_create<void>(path, |file| {
        io::write_text(&file, "x")?;
        return Ok;
    }));

    text::Text owned_path = must(text::text_copy(path));
    io::File file = must(io::open_read(must(text::text_to_slice(owned_path))));
    async::Future<Result<usize, Error>> future = read_one(file);
    async::Task<usize> task = must(async::spawn<usize>(future));
    if (must(async::block_on(task)) != 1) {
        return 1;
    }
    return 0;
}
