// ciel-test: error
// expect-error: `async::spawn` future state does not implement `Message`
// expect-error: opaque future state

import /std/async as async;
import /std/result;

async Result<usize, Error> len_later([]const i64 view) {
    return Ok(view.len);
}

void spawn_future(async::Future<Result<usize, Error>> future) {
    _ task = must(async::spawn<usize>(future));
}

i32 main() {
    [3]i64 values = [1, 2, 3];
    spawn_future(len_later(values[..]));
    return 0;
}
