// ciel-test: error
// expect-error: `async::spawn` requires a direct async closure or Awaitable<Result<T, E>>

import /std/async as async;
import /std/result;

i32 main() {
    Result<async::Task<usize, Error>, Error> task = async::spawn<usize, Error>(
        || {
            return Ok(1);
        }
    );
    return 0;
}
