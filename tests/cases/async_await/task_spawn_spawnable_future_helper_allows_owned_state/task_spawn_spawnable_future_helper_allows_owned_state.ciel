// ciel-test: run
// expect-exit: 0

import /std/async as async;
import /std/message;
import /std/result;

async Result<usize, Error> compute(usize value) {
    return Ok(value + 1);
}

async::Task<T> spawn_future<T: Message, A: async::SpawnableFuture<Result<T, Error>>>(
    A future
) {
    return must(async::spawn<T>(future));
}

i32 main() {
    async::Task<usize> task = spawn_future<usize>(compute(40));
    if (must(async::block_on(task)) != 41) {
        return 1;
    }
    return 0;
}
