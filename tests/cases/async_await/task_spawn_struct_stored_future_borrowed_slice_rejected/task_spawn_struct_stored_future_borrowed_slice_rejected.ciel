// ciel-test: error
// expect-error: `async::spawn` future state does not implement `Message`
// expect-error: future state `box` state `inner` state `view` has borrowed read-only slice type `[]const i64`

import /std/async as async;
import /std/result;

resource struct FutureBox {
    async::Future<Result<usize, Error>> inner;
}

async Result<usize, Error> len_later([]const i64 view) {
    return Ok(view.len);
}

async Result<usize, Error> keep_box(FutureBox box) {
    return Ok(0);
}

async::Task<usize, Error> spawn_boxed_future() {
    [3]i64 values = [1, 2, 3];
    FutureBox box = { inner: len_later(values[..]) };
    return must(async::spawn<usize>(keep_box(box)));
}

i32 main() {
    _ task = spawn_boxed_future();
    return 0;
}
