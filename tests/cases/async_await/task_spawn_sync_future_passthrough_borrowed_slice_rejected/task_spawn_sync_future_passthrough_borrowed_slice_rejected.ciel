// ciel-test: error
// expect-error: `async::spawn` future state does not implement `Message`
// expect-error: future state `argument 0` state `view` has borrowed read-only slice type `[]const i64`

import /std/async as async;
import /std/result;

async Result<usize, Error> len_later([]const i64 view) {
    return Ok(view.len);
}

async::Future<Result<usize, Error>> pass(async::Future<Result<usize, Error>> future) {
    return future;
}

async::Task<usize, Error> spawn_borrowed_slice() {
    [3]i64 values = [1, 2, 3];
    return must(async::spawn<usize>(pass(len_later(values[..]))));
}

i32 main() {
    _ task = spawn_borrowed_slice();
    return 0;
}
