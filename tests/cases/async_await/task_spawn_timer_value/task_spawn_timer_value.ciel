// ciel-test: run
// expect-exit: 0
// expect-stdout: 42

import /std/async as async;
import /std/async_time as async_time;
import /std/io;
import /std/panic;
import /std/result;

async Result<usize, Report> join_task(
    async::Task<usize, Report> task
) {
    usize value = await task?;
    return Ok(value + 1);
}

i32 main() {
    async::Task<usize, Report> task = must(
        async::spawn<usize, Report>(
            async || {
                await async_time::sleep_ms(1)?;
                return Ok(41);
            }
        )
    );
    must(print_value(must(async::block_on(join_task(task)))));
    return 0;
}
