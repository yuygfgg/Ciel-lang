// ciel-test: error
// expect-error: `async::spawn` future state does not implement `Message`
// expect-error: future state `view` has borrowed read-only slice type `[]const i64`

import /std/async as async;
import /std/result;

async Result<usize, Error> len_later(
    []const i64 view
) {
    return Ok(view.len);
}

i32 main() {
    [3]i64 values = [1, 2, 3];
    Result<async::Future<Result<_, Error>>, Error> result = Ok(
        len_later(values[..])
    );
    switch (result) {
        case Ok(future):
            _ task = must(async::spawn<usize>(future));
        case Err(_):
            return 1;
    }
    return 0;
}
