// ciel-test: error
// expect-error: `async::spawn` future state does not implement `Message`
// expect-error: borrowed read-only slice type `[]const i64`

import /std/async as async;
import /std/result;

async Result<usize, Report> len_later(
    []const i64 view
) {
    return Ok(view.len);
}

i32 main() {
    [3]i64 values = [1, 2, 3];
    Result<async::Future<Result<_, Report>>, Report> result = Ok(
        len_later(values[..])
    );
    _ task = must(async::spawn<usize>(must(result)));
    return 0;
}
