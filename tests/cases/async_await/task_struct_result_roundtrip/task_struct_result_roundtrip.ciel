// ciel-test: run
// expect-exit: 0
// expect-stdout: 12

import /std/async as async;
import /std/async_time as async_time;
import /std/io;
import /std/panic;
import /std/result;

struct Config {
    usize base;
    usize extra;
}

async Result<usize, Error> collect(
    async::Task<Config, Error> task
) {
    Config first = await task?;
    Config second = await task?;
    return Ok(first.base + second.extra);
}

i32 main() {
    async::Task<Config, Error> task = must(
        async::spawn<Config, Error>
        (async || {
            await async_time::sleep_ms(1)?;
            return Ok({ base: 5, extra: 7 });
        })
    );
    must(print_value(must(async::block_on(collect(task)))));
    return 0;
}
