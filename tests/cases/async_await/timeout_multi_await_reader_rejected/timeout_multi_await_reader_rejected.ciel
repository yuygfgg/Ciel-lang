// ciel-test: error
// expect-error: does not implement `cancel_safe_marker`

import /std/async as async;
import /std/async_time as async_time;
import /std/result;

async Result<usize, Error> multi_await() {
    await async_time::sleep_ms(0)?;
    await async_time::sleep_ms(0)?;
    return Ok(1);
}

i32 main() {
    _ timed = async::timeout(multi_await(), 1);
    return 0;
}
