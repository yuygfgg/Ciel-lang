// ciel-test: error
// expect-error: does not implement `cancel_safe_marker`

import /std/async as async;
import /std/async_io as aio;
import /std/result;

async Result<void, Error> bad_timeout(aio::AsyncFd file) {
    aio::AsyncRead op = aio::read_bytes_async(file, 16)?;
    _ timed = async::timeout(
        async::future_from_op(op),
        1
    );
    return Ok;
}

i32 main() {
    return 0;
}
