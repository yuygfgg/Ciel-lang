// ciel-test: compile

import /std/async as async;
import /std/async_net as anet;
import /std/net as net;
import /std/result;

async Result<void, Error> accept_once(anet::AsyncTcpListener listener) {
    anet::AsyncTcpStream server = await anet::accept(&listener)?;
    anet::close_listener(listener)?;
    anet::close_stream(server)?;
    return Ok;
}

async Result<usize, Error> connect_once() {
    anet::AsyncTcpListener listener =
        anet::listen_async(net::parse_addr("127.0.0.1:0")?)?;
    net::SocketAddr bound = anet::listener_addr(&listener)?;
    async::Task<void> accept_task = async::spawn<void>(accept_once(listener))?;
    Result<anet::AsyncTcpStream, Error> connected =
        await async::timeout(anet::connect(bound), 100)?;
    anet::AsyncTcpStream stream = connected?;
    anet::close_stream(stream)?;
    await accept_task?;
    return Ok(1);
}

i32 main() {
    return 0;
}
