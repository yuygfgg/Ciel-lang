// ciel-test: error
// expect-error: does not implement `cancel_safe_marker`

import /std/async as async;
import /std/async_net as anet;
import /std/result;

async Result<void, Error> bad_timeout(anet::AsyncTcpStream stream, anet::Bytes data) {
    anet::AsyncTcpWrite op = anet::write_bytes(stream, data)?;
    _ timed = async::timeout(
        async::future_from_op(op),
        1
    );
    return Ok;
}

i32 main() {
    return 0;
}
