// ciel-test: compile
// expect-c-contains: typedef struct Point Point;
// expect-c-contains: static int64_t ciel_
// expect-c-contains: return (int)ciel_

struct Point {
    i64 x;
    i64 y;
}

i64 add(i64 a, i64 b) {
    return a + b;
}

i64 main() {
    Point p = { x: 1, y: 2 };
    i64 total = add(p.x, p.y);
    return total;
}
