// ciel-test: run
// expect-exit: 0
// expect-stdout: 15

import /std/lib;

enum Command<T> {
    Add(T),
    Flush(void),
}

enum Event<T> {
    Total(T),
    Closed(void),
}

struct State<T> {
    Channel<Result<Event<T>, Report>> out;
    T total;
}

unsafe impl<T: Message> clone_message(*const Command<T> value) {
    return Ok(*value);
}

unsafe impl<T: Message> clone_message(*const Event<T> value) {
    return Ok(*value);
}

unsafe impl<T: Message> clone_message(*const State<T> value) {
    return Ok(*value);
}

i64 main() {
    Channel<Result<Event<i64>, Report>> out = must(
        make_channel<Result<Event<i64>, Report>>()
    );
    State<i64> initial = { out: out, total: 0 };

    Actor<Command<i64>> actor = must(
        spawn_actor_cloned<State<i64>, Command<i64>>(
            initial, |State<i64> state, Command<i64> command| {
                State<i64> @next = state;
                switch (command) {
                    case Add(value):
                        next.total =
                            next.total + value;
                        return Ok(next);
                    case Flush(marker):
                        marker;
                        Result<Event<i64>, Report> total_event = Ok(
                            Total(next.total)
                        );
                        Result<Event<i64>, Report> closed_event = Ok(Closed);
                        channel_send(&next.out, total_event)?;
                        channel_send(&next.out, closed_event)?;
                        return Ok(next);
                }
            }
        )
    );

    must(send(&actor, Add(9)));
    must(send(&actor, Add(6)));
    must(send(&actor, Flush));

    Result<Event<i64>, Report> first = must(channel_recv(&out));
    Result<Event<i64>, Report> second = must(channel_recv(&out));
    must(join(&actor));
    must(channel_close(&out));

    i64 @total = 0;
    switch (must(first)) {
        case Total(value):
            total = total + value;
        case Closed(marker):
            marker;
    }
    switch (must(second)) {
        case Total(value):
            total = total + value;
        case Closed(marker):
            marker;
    }

    must(print("{}", [total]));
    return 0;
}
