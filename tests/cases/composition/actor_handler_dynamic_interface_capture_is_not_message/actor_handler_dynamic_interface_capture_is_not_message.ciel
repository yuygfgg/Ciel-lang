// ciel-test: error
// expect-error: closure conversion requires
// expect-error: implement `clone_message`

import /std/lib;

interface<T> i64 measure(*T value);

struct Counter {
    i64 value;
}

impl measure(*Counter counter) {
    return counter->value;
}

i64 main() {
    Counter counter = { value: 4 };
    measure measured = &counter;
    Actor<i64> actor = must(
        spawn_actor_cloned<i64, i64>(
            0, |i64 state, i64 msg| {
                return Ok(state + msg + measure(measured));
            }
        )
    );
    must(join(&actor));
    return 0;
}
