// ciel-test: run
// expect-exit: 12

enum Operation {
    Apply(i64 |(i64)|),
    Identity,
}

i64 run(Operation operation, i64 value) {
    switch (operation) {
        case Apply(f):
            return f(value);
        case Identity:
            return value;
    }
}

i64 main() {
    i64 base = 5;
    Operation operation = Apply(|x| x + base);
    base = 100;
    return run(operation, 7);
}
