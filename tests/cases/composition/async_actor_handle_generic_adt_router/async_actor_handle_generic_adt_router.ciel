// ciel-test: run
// expect-exit: 0
// expect-stdout: 9

import /std/lib;

struct Route<M> {
    Actor<M> target;
    M message;
}

enum RouterMsg<M> {
    RouteTo(Route<M>),
    Done(void),
}

impl<M: Message> clone_message(*const Route<M> value) {
    return Ok(*value);
}

impl<M: Message> clone_message(*const RouterMsg<M> value) {
    return Ok(*value);
}

Result<void, Error> accept_shared<T: ShareHandle>(T value) {
    T local = value;
    if (share_handle_marker(&local)) {
        return Ok;
    }
    return Err(code_error(1));
}

Result<i64, Error> sink(i64 state, i64 msg) {
    print_value(msg)?;
    return Ok(state + msg);
}

i64 main() {
    Actor<i64> target = must(spawn_actor<i64, i64>(0, sink));
    must(accept_shared(target));

    Channel<i64> done = must(make_channel<i64>());
    Actor<RouterMsg<i64>> router = must(spawn_actor<i64, RouterMsg<i64>>(0, |i64 state, RouterMsg<i64> msg| {
        Channel<i64> local_done = done;
        switch (msg) {
            case RouteTo(route):
                Actor<i64> local_target = route.target;
                send(&local_target, route.message)?;
                return Ok(state + 1);
            case Done(marker):
                marker;
                channel_send(&local_done, state)?;
                return Ok(state);
        }
    }));

    Route<i64> route = { target: target, message: 9 };
    must(send(&router, RouteTo(route)));
    must(send(&router, Done));

    i64 routed = must(channel_recv(&done));
    must(join(&router));
    must(join(&target));
    must(channel_close(&done));
    if (routed != 1) {
        return 2;
    }
    return 0;
}
