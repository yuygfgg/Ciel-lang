// ciel-test: run
// expect-exit: 7

import /std/lib;

struct Token {
    void tag;
    i64 value;
}

enum Event<T> {
    Item(T),
    Done(void),
}

unsafe impl clone_message(*const Token value) {
    return Ok(*value);
}

unsafe impl<T: Message> clone_message(*const Event<T> value) {
    return Ok(*value);
}

Result<void, Error> post<T: Message>(
    *const Channel<Event<T>> channel, T value
) {
    channel_send(channel, Item(value))?;
    return Ok;
}

i64 main() {
    Channel<Event<Token>> channel = must(make_channel<Event<Token>>());
    Token token = { value: 7 };
    must(post(&channel, token));

    Event<Token> event = must(channel_recv(&channel));
    must(channel_close(&channel));
    switch (event) {
        case Item(item):
            return item.value;
        case Done(marker):
            marker;
            return 0;
    }
}
