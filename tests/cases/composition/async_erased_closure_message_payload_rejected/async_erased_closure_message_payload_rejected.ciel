// ciel-test: error
// expect-error: actor message type
// expect-error: does not implement `Message`

import /std/lib;

enum Work<T> {
    Apply(T, T |(T)|),
    Stop(void),
}

Result<i64, Error> handle(i64 state, Work<i64> work) {
    switch (work) {
        case Apply(value, op):
            return Ok(state + op(value));
        case Stop(marker):
            marker;
            return Ok(state);
    }
}

i64 main() {
    Actor<Work<i64>> actor = must(
        spawn_actor_cloned<i64, Work<i64>>(0, handle)
    );
    must(join(&actor));
    return 0;
}
