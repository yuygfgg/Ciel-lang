// ciel-test: error
// expect-error: closure conversion requires
// expect-error: implement `clone_message`

import /std/lib;
import /std/os/fd as fd;

struct Env {
    fd::RawFd raw;
    Channel<i64> out;
}

i64 main() {
    Env env = { raw: fd::stdout(), out: must(make_channel<i64>()) };
    Actor<i64> actor = must(spawn_actor_cloned<i64, i64>(0, |i64 state, i64 msg| {
        Env local_env = env;
        channel_send(&local_env.out, unsafe { fd::raw_fd(local_env.raw) } as i64)?;
        return Ok(state + msg);
    }));
    must(join(&actor));
    return 0;
}
