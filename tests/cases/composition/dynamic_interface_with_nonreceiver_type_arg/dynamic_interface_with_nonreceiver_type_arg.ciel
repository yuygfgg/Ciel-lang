// ciel-test: run
// expect-exit: 1

interface<T, U> bool same(*T value, U other);

struct Box {
    i64 value;
}

impl same<i64>(*Box box, i64 other) {
    return box->value == other;
}

i64 check(same<i64> value, i64 target) {
    if (same(value, target)) {
        return 1;
    }
    return 0;
}

i64 main() {
    Box box = { value: 12 };
    return check(&box, 12);
}
