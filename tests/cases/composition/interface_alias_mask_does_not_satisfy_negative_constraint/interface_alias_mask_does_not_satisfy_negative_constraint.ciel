// ciel-test: error
// expect-error: forbidden capability `reset`

interface<T> i64 read(*T value);
interface<T> void reset(*T value);
interface readable = read - reset;

struct Source {
    i64 value;
}

impl read(*Source source) {
    return source->value;
}

impl reset(*Source source) {
    source->value = 0;
    return;
}

i64 use_source<T: readable + !reset>(T source, i64 |(T)| callback) {
    return callback(source);
}

i64 main() {
    Source source = { value: 12 };
    return use_source(source, |item| {
        Source local = item;
        return read(&local);
    });
}
