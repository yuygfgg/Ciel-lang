// ciel-test: run
// expect-exit: 23

struct Holder<T> {
    T value;
    void tag;
}

T |()| |(Holder<T>)| make_factory<T>() {
    return |Holder<T> holder| {
        return || {
            holder.tag;
            return holder.value;
        };
    };
}

i64 main() {
    Holder<i64> @holder = { value: 23 };
    i64 |()| |(Holder<i64>)| factory = make_factory<i64>();
    i64 |()| reader = factory(holder);
    holder.value = 99;
    return reader();
}
