// ciel-test: error
// expect-error: closure conversion requires
// expect-error: implement `clone_message`

import /std/lib;

i64 main() {
    i64 local = 3;
    *i64 ptr = &local;
    Actor<i64> actor = must(
        spawn_actor_cloned<i64, i64>(
            0, |i64 state, i64 msg| {
                return Ok(state + msg + *ptr);
            }
        )
    );
    must(join(&actor));
    return 0;
}
