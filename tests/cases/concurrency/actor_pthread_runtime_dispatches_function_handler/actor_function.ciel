// ciel-test: run
// expect-exit: 0
// expect-stdout: 45

import /std/lib;

Result<i64, Error> handle(i64 state, i64 msg) {
    print_value(msg)?;
    return Ok(state + msg);
}

i64 main() {
    Actor<i64> actor = must(spawn_actor<i64, i64>(0, handle));
    must(send(&actor, 4));
    must(send(&actor, 5));
    must(join(&actor));
    return 0;
}
