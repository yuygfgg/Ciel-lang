// ciel-test: run
// expect-exit: 0
// expect-stdout: 15

import /std/lib;
import /std/map as map;
import /std/meta as meta;

enum Command {
    Add(u32, i64),
    Flush(void),
}

struct OwnedState {
    map::HashMap<u32, i64> table;
    Channel<i64> out;
}

meta::Repr<Command> command(Command value) {
    Command local = value;
    return meta::into_repr(&local);
}

Result<OwnedState, Error> init_state(Channel<i64> out) {
    return Ok({
        table: map::hash_map_new<u32, i64>()?,
        out: out
    });
}

Result<void, Error> handle(
    *OwnedState state,
    Actor<meta::Repr<Command>> self,
    meta::Repr<Command> envelope
) {
    Command command_value = meta::from_repr<Command>(envelope);
    switch (command_value) {
        case Add(key, delta):
            if (map::hash_map_contains_key(&state->table, key)?) {
                map::hash_map_with<u32, i64, void, Error>(&state->table, key, |value| {
                    *value = *value + delta;
                    return Ok;
                })?;
            } else {
                map::hash_map_insert(&state->table, key, delta)?;
            }
            return Ok;
        case Flush(_):
            i64 total = map::hash_map_with<u32, i64, i64, Error>(&state->table, 7 as u32, |value| {
                return Ok(*value);
            })?;
            channel_send(&state->out, total)?;
            stop(&self)?;
            return Ok;
    }
}

i64 main() {
    Channel<i64> out = must(make_channel<i64>());
    Actor<meta::Repr<Command>> actor = must(spawn_actor_state<OwnedState, meta::Repr<Command>>(
        || init_state(out),
        handle
    ));
    must(send(&actor, command(Add(7 as u32, 10))));
    must(send(&actor, command(Add(7 as u32, 5))));
    must(send(&actor, command(Flush)));
    i64 total = must(channel_recv(&out));
    must(join(&actor));
    must(channel_close(&out));
    must(print("{}", [total]));
    return 0;
}
