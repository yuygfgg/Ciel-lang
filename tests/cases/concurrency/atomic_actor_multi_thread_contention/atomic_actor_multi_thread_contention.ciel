// ciel-test: run
// expect-exit: 0
// expect-stdout: 4000

import /std/lib;

struct Burst {
    Atomic<i64> counter;
    Channel<i64> ready;
    Channel<i64> start;
    i64 repeats;
}

unsafe impl clone_message(*const Burst value) {
    return Ok(*value);
}

Result<i64, Error> worker(i64 state, Burst burst) {
    Atomic<i64> counter = burst.counter;
    Channel<i64> ready = burst.ready;
    Channel<i64> start = burst.start;
    i64 repeats = burst.repeats;

    channel_send(&ready, 1)?;
    _ released = channel_recv(&start)?;

    i64 @i = 0;
    while (i < repeats) {
        atomic_fetch_add(&counter, 1, AcqRel)?;
        i = i + 1;
    }
    return Ok(state + repeats);
}

i64 main() {
    Atomic<i64> counter = must(make_atomic<i64>(0));
    Channel<i64> ready = must(make_channel<i64>());
    Channel<i64> start = must(make_channel<i64>());

    Actor<Burst> a0 = must(spawn_actor_cloned<i64, Burst>(0, worker));
    Actor<Burst> a1 = must(spawn_actor_cloned<i64, Burst>(0, worker));
    Actor<Burst> a2 = must(spawn_actor_cloned<i64, Burst>(0, worker));
    Actor<Burst> a3 = must(spawn_actor_cloned<i64, Burst>(0, worker));

    Burst burst = {
        counter: counter,
        ready: ready,
        start: start,
        repeats: 1000,
    };

    must(send(&a0, burst));
    must(send(&a1, burst));
    must(send(&a2, burst));
    must(send(&a3, burst));

    i64 @worker_index = 0;
    while (worker_index < 4) {
        _ ready_signal = must(channel_recv(&ready));
        worker_index = worker_index + 1;
    }
    worker_index = 0;
    while (worker_index < 4) {
        must(channel_send(&start, 1));
        worker_index = worker_index + 1;
    }

    must(join(&a0));
    must(join(&a1));
    must(join(&a2));
    must(join(&a3));
    must(channel_close(&ready));
    must(channel_close(&start));

    i64 total = must(atomic_load(&counter, SeqCst));
    if (total != 4000) {
        return 1;
    }
    must(print("{}", [total]));
    return 0;
}
