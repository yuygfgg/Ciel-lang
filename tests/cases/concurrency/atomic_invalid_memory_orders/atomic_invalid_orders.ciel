// ciel-test: run
// expect-exit: 0

import /std/lib;
import /std/format as format;

bool same_text([]const char left, []const char right) {
    if (left.len != right.len) {
        return false;
    }
    usize @idx = 0;
    while (idx < left.len) {
        if (left[idx] != right[idx]) {
            return false;
        }
        idx = idx + 1;
    }
    return true;
}

bool is_code(Error error, i64 expected) {
    return same_text(error_message(&error), format::i64_to_string(expected));
}

bool is_invalid_load(Result<i64, AtomicError> result) {
    switch (result) {
        case Ok(value):
            return false;
        case Err(error):
            switch (error) {
                case InvalidMemoryOrder:
                    return true;
                case Runtime(_):
                    return false;
            }
    }
}

bool is_invalid_store(Result<void, AtomicError> result) {
    switch (result) {
        case Ok:
            return false;
        case Err(error):
            switch (error) {
                case InvalidMemoryOrder:
                    return true;
                case Runtime(_):
                    return false;
            }
    }
}

bool is_invalid_compare(Result<CompareExchange<i64>, AtomicError> result) {
    switch (result) {
        case Ok(value):
            return false;
        case Err(error):
            switch (error) {
                case InvalidMemoryOrder:
                    return true;
                case Runtime(_):
                    return false;
            }
    }
}

i64 main() {
    Atomic<i64> value = must(make_atomic<i64>(1));

    if (is_invalid_load(atomic_load<i64>(&value, Release)) == false) {
        return 1;
    }
    if (is_invalid_load(atomic_load<i64>(&value, AcqRel)) == false) {
        return 2;
    }
    if (is_invalid_store(atomic_store<i64>(&value, 2, Acquire)) == false) {
        return 3;
    }
    if (is_invalid_store(atomic_store<i64>(&value, 2, AcqRel)) == false) {
        return 4;
    }
    if (is_invalid_compare(atomic_compare_exchange<i64>(&value, 1, 2, SeqCst, Release)) == false) {
        return 5;
    }
    if (is_invalid_compare(atomic_compare_exchange<i64>(&value, 1, 2, Release, Acquire)) == false) {
        return 6;
    }

    i64 still_works = must(atomic_load<i64>(&value, SeqCst));
    if (still_works != 1) {
        return 7;
    }
    return 0;
}
