// ciel-test: run
// expect-exit: 0
// expect-stdout: 42
// expect-c-contains: sizeof(int64_t), CIEL_ALIGNOF(int64_t)

import /std/lib;

i64 main() {
    Channel<i64> channel = must(make_channel<i64>());
    must(channel_send(&channel, 40));
    must(channel_send(&channel, 2));
    i64 first = must(channel_recv(&channel));
    i64 second = must(channel_recv(&channel));
    must(channel_close(&channel));
    must(print("{}", [first + second]));
    return 0;
}
