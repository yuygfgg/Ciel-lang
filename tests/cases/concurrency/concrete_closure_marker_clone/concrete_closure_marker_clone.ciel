// ciel-test: run
// expect-exit: 9

import /std/lib;

T clone_value<T: Message>(T value) {
    T local = value;
    return must(clone_message(&local));
}

i64 main() {
    i64 base = 4;
    _ closure = |i64 value| value + base;
    _ copied = clone_value(closure);
    base = 100;
    return copied(5);
}
