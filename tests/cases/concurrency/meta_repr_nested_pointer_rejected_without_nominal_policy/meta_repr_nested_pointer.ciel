// ciel-test: error
// expect-error: does not implement `clone_message`

import /std/lib;
import /std/meta as meta;

struct Inner {
    *i64 ptr;
}

struct Outer {
    Inner inner;
}

i64 main() {
    Channel<meta::Repr<Outer>> channel = must(
        make_channel<meta::Repr<Outer>>()
    );
    return 0;
}
