// ciel-test: run
// expect-exit: 0

import /std/lib;
import /std/meta as meta;

struct Handle {
    *i64 ptr;
    i64 tag;
}

struct Outer {
    Handle handle;
    i64 extra;
}

impl clone_message(*Handle value) {
    return Ok(*value);
}

i64 main() {
    i64 backing = 7;
    Outer outer = {
        handle: { ptr: &backing, tag: 5 },
        extra: 6,
    };
    Channel<meta::Repr<Outer>> channel = must(make_channel<meta::Repr<Outer>>());
    must(channel_send(&channel, meta::into_repr(outer)));
    Outer copied = meta::from_repr<Outer>(must(channel_recv(&channel)));
    must(channel_close(&channel));
    return *copied.handle.ptr + copied.handle.tag + copied.extra - 18;
}
