// ciel-test: run
// expect-exit: 0

import /std/lib;
import /std/os/fd as fd;

Result<void, Error> accept_local<T: ThreadLocal>(T value) {
    T local = value;
    if (thread_local_marker(&local)) {
        return Ok;
    }
    return Err(code_error(1));
}

i64 main() {
    fd::RawFd raw = fd::stdout();
    must(accept_local(raw));
    return 0;
}
