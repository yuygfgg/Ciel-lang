// ciel-test: error
// expect-error: closure conversion requires
// expect-error: implement `thread_local_marker`

import /std/lib;
import /std/os/fd as fd;

i64 main() {
    fd::RawFd raw = fd::stdout();
    i64 |(i64): ThreadLocal| local = |i64 value| value + (unsafe { fd::raw_fd(
        raw
    ) } as i64);
    return local(1);
}
