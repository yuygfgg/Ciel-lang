// ciel-test: error
// expect-error: does not implement `Message`

import /std/lib;
import /std/os/fd as fd;

struct LocalEnvelope {
    fd::RawFd raw;
}

i64 main() {
    LocalEnvelope envelope = { raw: fd::stdout() };
    LocalEnvelope copy = must(clone_message(&envelope));
    return unsafe { fd::raw_fd(copy.raw) } as i64;
}
