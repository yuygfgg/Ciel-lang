// ciel-test: run
// expect-exit: 0
// expect-stdout: WCASCBSD

#c_include "stdio.h"

unsafe extern "C" {
    i32 putchar(i32 ch);
}

void ciel_test_putchar(i32 ch) {
    unsafe { putchar(ch) };
}

bool stop(void marker) {
    ciel_test_putchar(87);
    return false;
}

bool keep(void marker) {
    ciel_test_putchar(67);
    return true;
}

i64 step(void marker) {
    ciel_test_putchar(83);
    return 1;
}

void cleanup(void marker) {
    ciel_test_putchar(68);
}

i32 main() {
    void marker;
    defer cleanup(marker);
    while (stop(marker)) {}
    for (i64 @i = 0; i < 2 && keep(marker); i = i + step(marker)) {
        if (i == 0) {
            ciel_test_putchar(65);
            continue;
        }
        ciel_test_putchar(66);
    }
    return 0;
}
