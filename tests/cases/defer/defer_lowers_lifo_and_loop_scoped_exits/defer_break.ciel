// ciel-test: run
// expect-exit: 0
// expect-stdout: IXO

#c_include "stdio.h"

unsafe extern "C" {
    i32 putchar(i32 ch);
}

void ciel_test_putchar(i32 ch) {
    unsafe { putchar(ch) };
}

i32 main() {
    defer ciel_test_putchar(79);
    while (true) {
        defer ciel_test_putchar(73);
        break;
    }
    ciel_test_putchar(88);
    return 0;
}
