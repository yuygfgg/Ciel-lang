// ciel-test: run
// expect-exit: 0
// run-arg: @tmp/defer_returned_resource_is_cleaned.txt

import /std/env as env;
import /std/io as io;
import /std/resource as resource;
import /std/result;

io::File deferred_open([]const char path) {
    return must(io::open_read(path));
}

Result<void, Error> register_defer([]const char path) {
    defer deferred_open(path);
    return Ok;
}

i32 main() {
    []const char path = must(env::arg(1));
    must(io::with_create<void>(path, |file| {
        io::write_text(&file, "defer-resource")?;
        return Ok;
    }));

    resource::Limits limits = {
        max_resources: 8,
        max_child_owners: 16,
        max_pending_ops: 16,
        max_descriptors: 1,
    };
    must(resource::scoped_with_limits<void, Error>(limits, || {
        register_defer(path)?;
        io::File again = io::open_read(path)?;
        io::close(again)?;
        return Ok;
    }));
    return 0;
}
