// ciel-test: compile
// expect-c-contains: switch (ciel_switch_
// expect-c-contains: case 0

enum Maybe {
    Some(i64),
    None,
}

i64 unwrap_or_zero(Maybe value) {
    switch (value) {
        case Some(x):
            return x;
        case None:
            return 0;
    }
}

i64 main() {
    return unwrap_or_zero(Some(5));
}
