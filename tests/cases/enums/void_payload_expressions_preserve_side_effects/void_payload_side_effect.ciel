// ciel-test: run
// expect-exit: 0
// expect-stdout: A

#c_include "stdio.h"

unsafe extern "C" {
    i32 putchar(i32 ch);
}

void ciel_test_putchar(i32 ch) {
    unsafe { putchar(ch) };
}

enum Event {
    Done(void),
}

void mark() {
    ciel_test_putchar(65);
}

i32 main() {
    Event event = Done(mark());
    switch (event) {
        case Done(_):
            return 0;
    }
}
