// ciel-test: run
// expect-exit: 0

import /std/error;
import /std/option as option;

struct ItemError {
    i64 code;
}

impl format_error(*const ItemError error) {
    return "item";
}

i64 main() {
    ItemError item = { code: 29 };
    Error from_value = item;
    Error from_pointer = &item;
    if (!error_is<ItemError>(&from_value)) {
        return 1;
    }
    if (!error_is<ItemError>(&from_pointer)) {
        return 2;
    }
    switch (error_downcast_ref<ItemError>(&from_pointer)) {
        case option::Some(value):
            if (value->code != 29) {
                return 3;
            }
        case option::None:
            return 4;
    }
    return 0;
}
