// ciel-test: run
// expect-exit: 17

interface<T> i64 measure(*T value);
interface<T> void seek(*T value);

struct Box {
    i64 value;
}

impl measure(*Box value) {
    return value->value;
}

i64 read_measure<T: measure + !seek>(
    *T value
) {
    return measure(value);
}

i64 main() {
    Box @box = { value: 17 };
    return read_measure(&box);
}
