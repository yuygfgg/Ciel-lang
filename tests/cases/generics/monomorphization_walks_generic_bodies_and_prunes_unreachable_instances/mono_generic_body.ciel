// ciel-test: run
// expect-exit: 31

struct Box<T> {
    T value;
}

T id<T>(T value) {
    return value;
}

T through<T>(T value) {
    return id(value);
}

T unused_generic<T>(T value) {
    return value;
}

i64 main() {
    Box<i64> box = { value: 31 };
    Box<i64> out = through(box);
    return out.value;
}
