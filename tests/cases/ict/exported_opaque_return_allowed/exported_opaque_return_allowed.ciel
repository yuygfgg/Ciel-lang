// ciel-test: run
// expect-exit: 7

enum Next<Item> {
    Item(Item),
    Done,
}

interface<I -> Item> Next<Item> next(*I iter);
interface Iterator<Item> = next<Item>;

struct Range {
    i64 value;
}

impl next<i64>(*Range iter) {
    return Item(iter->value);
}

export _: Iterator<i64> make_range() {
    Range range = { value: 7 };
    return range;
}

i64 main() {
    _ iter = make_range();
    switch (next(&iter)) {
    case Item(value):
        return value;
    case Done:
        return 0;
    }
}
