// ciel-test: run
// expect-exit: 34

enum Next<Item> {
    Item(Item),
    Done,
}

interface<I -> Item> Next<Item> next(*I iter);
interface Iterator<Item> = next<Item>;

struct Range {
    i64 value;
}

impl next<i64>(*Range iter) {
    return Item(iter->value);
}

struct Peekable<I: Iterator<Item = _>> {
    I inner;
    Item cached;
}

impl<I: Iterator<Item = _>> next<Item>(*Peekable<I> iter) {
    return Item(iter->cached);
}

i64 main() {
    Range range = { value: 13 };
    Peekable<Range> peekable = { inner: range, cached: 34 };
    switch (next(&peekable)) {
        case Item(value):
            return value;
        case Done:
            return 0;
    }
}
