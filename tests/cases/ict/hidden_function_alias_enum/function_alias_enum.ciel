// ciel-test: run
// expect-exit: 13

enum Next<Item> {
    Item(Item),
    Done,
}

interface<I -> Item> Next<Item> next(*I iter);
interface Iterator<Item> = next<Item>;

struct Range {
    i64 value;
}

impl next<i64>(*Range iter) {
    return Item(iter->value);
}

type Cached<I: Iterator<Item = _>> = Item;

enum Slot<I: Iterator<Item = _>> {
    Value(Item),
}

Item fallback<I: Iterator<Item = _>>(I iter, Item value) {
    return value;
}

i64 main() {
    Range range = { value: 12 };
    Cached<Range> cached = fallback(range, 13);
    Slot<Range> slot = Value(cached);
    switch (slot) {
    case Value(value):
        return value;
    }
}
