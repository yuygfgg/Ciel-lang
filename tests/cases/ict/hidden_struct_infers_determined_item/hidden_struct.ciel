// ciel-test: run
// expect-exit: 21

enum Next<Item> {
    Item(Item),
    Done,
}

interface<I -> Item> Next<Item> next(*I iter);
interface Iterator<Item> = next<Item>;

struct Range {
    i64 value;
}

impl next<i64>(*Range iter) {
    return Item(iter->value);
}

struct Peekable<I: Iterator<Item = _>> {
    I inner;
    Item cached;
}

i64 main() {
    Range range = { value: 21 };
    Peekable<Range> peekable = { inner: range, cached: 21 };
    return peekable.cached;
}
