// ciel-test: run
// expect-exit: 17

enum Next<Item> {
    Item(Item),
    Done,
}

interface<I -> Item> Next<Item> next(*I iter);
interface Iterator<Item> = next<Item>;

struct Range {
    i64 value;
}

impl next<i64>(*Range iter) {
    return Item(iter->value);
}

_: Iterator<i64> make_range(i64 value) {
    Range range = { value: value };
    return range;
}

i64 read_dyn(Iterator<i64> iter) {
    switch (next<i64>(iter)) {
    case Item(value):
        return value;
    case Done:
        return 0;
    }
}

i64 main() {
    Iterator<i64> iter = make_range(17);
    return read_dyn(iter);
}
