// ciel-test: error
// expect-error: opaque return function returns both `Range` and `EmptyRange`

enum Next<Item> {
    Item(Item),
    Done,
}

interface<I -> Item> Next<Item> next(*I iter);
interface Iterator<Item> = next<Item>;

struct Range {
    i64 value;
}

struct EmptyRange {}

impl next<i64>(*Range iter) {
    return Item(iter->value);
}

impl next<i64>(*EmptyRange iter) {
    return Done;
}

_: Iterator<i64> choose(bool flag) {
    if (flag) {
        Range range = { value: 1 };
        return range;
    }
    EmptyRange empty = {};
    return empty;
}

i64 main() {
    _ iter = choose(true);
    switch (next(&iter)) {
        case Item(value):
            return value;
        case Done:
            return 0;
    }
}
