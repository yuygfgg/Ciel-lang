// ciel-test: run
// expect-exit: 0

interface<T> bool a(*const T value);
interface<T> bool b(*const T value);

struct Box {
    i64 value;
}

derivable impl<T> a(*const T value) {
    return true;
}

derivable impl<T: a> b(*const T value) {
    return a(value);
}

derive b<Box>;
derive a<Box>;

i64 main() {
    Box box = { value: 1 };
    if (!b(&box)) {
        return 1;
    }
    return 0;
}
