// ciel-test: run
// expect-exit: 0

interface<T> bool a(*const T value);
interface<T> bool b(*const T value);

struct Box<T> {
    T value;
}

derivable impl<T> a(*const Box<T> value) {
    return true;
}

derivable impl<T: a> b(*const T value) {
    return a(value);
}

derive b<Box<i64>>;
derive<T> a<Box<T>>;

i64 main() {
    Box<i64> box = { value: 1 };
    if (!b(&box)) {
        return 1;
    }
    return 0;
}
