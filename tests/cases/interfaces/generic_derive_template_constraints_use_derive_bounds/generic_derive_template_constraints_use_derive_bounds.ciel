// ciel-test: run
// expect-exit: 0

interface<T> bool a(*const T value);
interface<T> bool b(*const T value);

impl a(*const i64 value) {
    return true;
}

derivable impl<T: a> b(*const T value) {
    return a(value);
}

derive<T: a> b<T>;

i64 main() {
    i64 value = 1;
    if (!b(&value)) {
        return 1;
    }
    return 0;
}
