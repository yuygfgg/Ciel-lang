// ciel-test: run
// expect-exit: 46

interface<T> i64 measure(*T value);
interface<T> void seek(*T value);
interface readable = measure - seek;

struct Box {
    i64 value;
}

impl measure(*Box value) {
    return value->value;
}

i64 generic_read<T: readable + !seek>(*T value) {
    return measure(value);
}

i64 dynamic_read(readable value) {
    return measure(value);
}

i64 main() {
    Box box = { value: 23 };
    return generic_read(&box) + dynamic_read(&box);
}
