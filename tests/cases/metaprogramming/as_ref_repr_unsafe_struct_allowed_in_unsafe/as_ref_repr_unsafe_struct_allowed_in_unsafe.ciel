// ciel-test: run
// expect-exit: 0

import /std/meta as meta;

unsafe struct Secret {
    i64 token;
}

i64 main() {
    Secret value = unsafe { { token: 7 } };
    meta::RefRepr<Secret> repr = unsafe { meta::as_ref_repr(&value) };
    meta::HConsView<meta::FieldRef<i64>, meta::HNil> repr_view =
        meta::hcons_view(&repr);
    meta::FieldRefView<i64> field = meta::field_ref_view(repr_view.head);
    return *field.value - 7;
}
