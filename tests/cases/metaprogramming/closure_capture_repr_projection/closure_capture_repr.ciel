// ciel-test: run
// expect-exit: 0

import /std/meta as meta;

interface<T> i64 count_refs(*const T value);
interface<T> i64 count_owned(*const T value);

impl count_refs(*const meta::HNil value) {
    return 0;
}

impl count_owned(*const meta::HNil value) {
    return 0;
}

impl<V, Tail: count_refs> count_refs(*const meta::HCons<meta::FieldRef<V>, Tail> value) {
    meta::HConsView<meta::FieldRef<V>, Tail> view = meta::hcons_view(value);
    return 1 + count_refs(view.tail);
}

impl<V, Tail: count_owned> count_owned(*const meta::HCons<meta::Field<V>, Tail> value) {
    meta::HConsView<meta::Field<V>, Tail> view = meta::hcons_view(value);
    return 1 + count_owned(view.tail);
}

T choose<T>(T left, T right, bool use_left) {
    if (use_left) {
        return left;
    }
    return right;
}

i64 main() {
    i64 base = 10;
    i64 delta = 1;
    _ f = |i64 x| x + base + delta;
    _ refs = meta::as_ref_repr(&f);
    _ owned = meta::into_repr(&f);
    _ rebuilt = choose(f, meta::from_repr(owned), false);
    i64 projected = count_refs(&refs) + count_owned(&owned);
    return f(5) + rebuilt(5) + projected - 36;
}
