// ciel-test: error
// expect-error: meta reflection on unsafe struct `Secret` requires unsafe block

import /std/meta as meta;

unsafe struct Secret {
    i64 token;
}

meta::Repr<T> snapshot<T>(*const T value) {
    return meta::into_repr<T>(value);
}

i64 main() {
    Secret value = unsafe { { token: 7 } };
    _ repr = snapshot<Secret>(&value);
    return 0;
}
