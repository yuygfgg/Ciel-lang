// ciel-test: run
// expect-exit: 0

import /std/meta as meta;

struct Packet {
    i64 id;
    bool ok;
}

struct Holder<T> {
    meta::Repr<T> repr;
}

i64 consume_explicit<T>(meta::Repr<T> repr) {
    return 0;
}

i64 consume_after_value<T>(T value, meta::Repr<T> repr) {
    T copy = meta::from_repr<T>(repr);
    return 0;
}

i64 read_holder(Holder<Packet> holder) {
    Packet copy = meta::from_repr<Packet>(holder.repr);
    if (copy.ok) {
        return copy.id;
    }
    return 100;
}

i64 main() {
    Packet packet = { id: 17, ok: true };
    meta::Repr<Packet> repr = meta::into_repr(&packet);
    Holder<Packet> holder = { repr: meta::into_repr(&packet) };
    return consume_explicit<Packet>(repr)
        + consume_after_value(packet, meta::into_repr(&packet))
        + read_holder(holder)
        - 17;
}
