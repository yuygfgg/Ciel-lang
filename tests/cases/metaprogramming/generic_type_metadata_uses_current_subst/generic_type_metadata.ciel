// ciel-test: run
// expect-exit: 0

import /std/lib;
import /std/meta as meta;

usize size_of<T>() {
    return meta::type_size<T>();
}

usize align_of<T>() {
    return meta::type_align<T>();
}

i32 main() {
    if (size_of<i64>() != 8) {
        return 1;
    }
    if (align_of<i64>() != 8) {
        return 2;
    }
    return 0;
}
