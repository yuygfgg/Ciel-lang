// ciel-test: run
// expect-exit: 0

import /std/meta as meta;

unsafe struct Secret {
    i64 token;
}

i64 main() {
    Secret value = unsafe { { token: 7 } };
    meta::Repr<Secret> repr = unsafe { meta::into_repr(&value) };
    Secret copy = unsafe { meta::from_repr<Secret>(repr) };
    return unsafe { copy.token } - 7;
}
