// ciel-test: run
// expect-exit: 0

import /std/meta as meta;

bool chars_eq([]const char left, []const char right) {
    if (left.len != right.len) {
        return false;
    }
    usize @i = 0;
    while (i < left.len) {
        if (left[i] != right[i]) {
            return false;
        }
        i = i + 1;
    }
    return true;
}

interface<T> i64 source_code(meta::Type<T> tag);
interface<T> i64 repr_code(meta::Type<T> tag);
interface<S> i64 count_fields(*const S schema);

impl source_code(meta::Type<u8> tag) {
    return 1;
}

impl repr_code(meta::Type<u8> tag) {
    return 10;
}

impl source_code(meta::Type<[2]i64> tag) {
    return 2;
}

impl repr_code(meta::Type<meta::ArrayChunk2<i64>> tag) {
    return 20;
}

impl count_fields(*const meta::HNil schema) {
    return 0;
}

impl<V, R, Tail: count_fields> count_fields(
    *const meta::HCons<meta::FieldSchema<V, R>, Tail> schema
) {
    meta::HConsView<meta::FieldSchema<V, R>, Tail> view = meta::hcons_view(
        schema
    );
    return 1 + count_fields(view.tail);
}

meta::Schema<T> schema_for<T>(T value) {
    return meta::schema<T>();
}

i64 bool_value(bool ok) {
    if (ok) {
        return 1;
    }
    return 0;
}

i64 main() {
    meta::Schema<[3]u8> bytes = meta::schema<[3]u8>();
    meta::ArrayChunk3View<meta::ElementSchema<u8, u8>> bytes_view =
        meta::array_chunk3_view(&bytes);
    meta::ElementSchemaView<u8, u8> bytes0 = meta::element_schema_view(
        bytes_view.item0
    );
    meta::ElementSchemaView<u8, u8> bytes1 = meta::element_schema_view(
        bytes_view.item1
    );
    if (source_code(bytes0.source_ty) != 1) {
        return 1;
    }
    if (repr_code(bytes1.repr_ty) != 10) {
        return 2;
    }

    meta::Schema<[2][2]i64> nested = meta::schema<[2][2]i64>();
    meta::ArrayChunk2View<meta::ElementSchema<[2]i64, meta::ArrayChunk2<i64>>> nested_view =
        meta::array_chunk2_view(&nested);
    meta::ElementSchemaView<[2]i64, meta::ArrayChunk2<i64>> nested0 =
        meta::element_schema_view(nested_view.item0);
    meta::ElementSchemaView<[2]i64, meta::ArrayChunk2<i64>> nested1 =
        meta::element_schema_view(nested_view.item1);
    if (source_code(nested0.source_ty) != 2) {
        return 3;
    }
    if (repr_code(nested1.repr_ty) != 20) {
        return 4;
    }

    i64 base = 8;
    bool ok = true;
    _ f = || base + bool_value(ok);
    _ closure_schema = schema_for(f);
    if (count_fields(&closure_schema) != 2) {
        return 5;
    }
    meta::HConsView<meta::FieldSchema<i64, i64>, meta::HCons<meta::FieldSchema<bool, bool>, meta::HNil>> closure_view =
        meta::hcons_view(&closure_schema);
    meta::FieldSchemaView<i64, i64> capture0 = meta::field_schema_view(
        closure_view.head
    );
    meta::HConsView<meta::FieldSchema<bool, bool>, meta::HNil> closure_tail =
        meta::hcons_view(closure_view.tail);
    meta::FieldSchemaView<bool, bool> capture1 = meta::field_schema_view(
        closure_tail.head
    );
    if (!chars_eq(capture0.name, "capture#0")) {
        return 6;
    }
    if (!chars_eq(capture1.name, "capture#1")) {
        return 7;
    }
    return f() - 9;
}
