// ciel-test: run
// expect-exit: 0

import /std/meta as meta;

struct Packet {
    i64 id;
    bool ok;
}

interface<T> i64 count_fields(*T value);

impl count_fields(*meta::HNil value) {
    return 0;
}

impl<V, Tail: count_fields> count_fields(*meta::HCons<meta::FieldRef<V>, Tail> value) {
    return 1 + count_fields(&value->tail);
}

i64 read_id(meta::RefRepr<Packet> repr) {
    return *repr.head.value;
}

i64 main() {
    Packet packet = { id: 40, ok: true };
    meta::RefRepr<Packet> refs = meta::as_ref_repr(&packet);
    meta::Repr<Packet> owned = meta::into_repr(packet);
    Packet copy = meta::from_repr<Packet>(owned);
    i64 count = count_fields(&refs);
    if (*refs.tail.head.value) {
        return read_id(refs) + copy.id + count - 82;
    }
    return 1;
}
