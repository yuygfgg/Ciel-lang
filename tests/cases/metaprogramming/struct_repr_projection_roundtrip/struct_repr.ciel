// ciel-test: run
// expect-exit: 0

import /std/meta as meta;

struct Packet {
    i64 id;
    bool ok;
}

interface<T> i64 count_fields(*const T value);

impl count_fields(*const meta::HNil value) {
    return 0;
}

impl<V, Tail: count_fields> count_fields(
    *const meta::HCons<meta::FieldRef<V>, Tail> value
) {
    meta::HConsView<meta::FieldRef<V>, Tail> view = meta::hcons_view(value);
    return 1 + count_fields(view.tail);
}

i64 read_id(meta::RefRepr<Packet> repr) {
    meta::HConsView<meta::FieldRef<i64>, meta::HCons<meta::FieldRef<bool>, meta::HNil>> repr_view =
        meta::hcons_view(&repr);
    meta::FieldRefView<i64> field = meta::field_ref_view(repr_view.head);
    return *field.value;
}

i64 main() {
    Packet packet = { id: 40, ok: true };
    meta::RefRepr<Packet> refs = meta::as_ref_repr(&packet);
    meta::Repr<Packet> owned = meta::into_repr(&packet);
    Packet copy = meta::from_repr<Packet>(owned);
    i64 count = count_fields(&refs);
    meta::HConsView<meta::FieldRef<i64>, meta::HCons<meta::FieldRef<bool>, meta::HNil>> refs_view =
        meta::hcons_view(&refs);
    meta::HConsView<meta::FieldRef<bool>, meta::HNil> tail_view =
        meta::hcons_view(refs_view.tail);
    meta::FieldRefView<bool> ok_field = meta::field_ref_view(tail_view.head);
    if (*ok_field.value) {
        return read_id(refs) + copy.id + count - 82;
    }
    return 1;
}
