// ciel-test: run
// expect-exit: 0

import /std/meta as meta;

meta::TypeId type_id_of<T>(T value) {
    return meta::type_id<T>();
}

meta::TypeId first_closure_type<T>(T value) {
    _ closure = || 1;
    return type_id_of(closure);
}

meta::TypeId second_closure_type<T>(T value) {
    _ closure = || 2;
    return type_id_of(closure);
}

meta::TypeId instantiated_closure_type<T>() {
    _ closure = || 3;
    return type_id_of(closure);
}

i64 main() {
    meta::TypeId first = first_closure_type<i64>(0);
    meta::TypeId second = second_closure_type<i64>(0);
    if (meta::type_id_eq(first, second)) {
        return 1;
    }
    meta::TypeId i64_instance = instantiated_closure_type<i64>();
    meta::TypeId u8_instance = instantiated_closure_type<u8>();
    if (meta::type_id_eq(i64_instance, u8_instance)) {
        return 2;
    }
    return 0;
}
