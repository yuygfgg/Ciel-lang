// ciel-test: run
// package-root: @repo/libs/sqlite
// allow-native-build: true
// expect-exit: 0

import /sqlite as sqlite;
import /std/message;
import /std/resource as resource;
import /std/result;
import /std/text;

struct HandleParts {
    u64 owner_id;
    u64 resource_id;
    u64 generation;
}

unsafe impl clone_message(*const HandleParts value) {
    return Ok(*value);
}

HandleParts parts_from_handle(resource::Handle handle) {
    return {
        owner_id: unsafe { handle.owner_id },
        resource_id: unsafe { handle.resource_id },
        generation: unsafe { handle.generation },
    };
}

resource::Handle handle_from_parts(HandleParts parts) {
    return unsafe {
        {
            owner_id: parts.owner_id,
            resource_id: parts.resource_id,
            generation: parts.generation,
        }
    };
}

sqlite::Connection connection_from_parts(HandleParts parts) {
    return unsafe { { handle: handle_from_parts(parts) } };
}

sqlite::Statement statement_from_parts(HandleParts parts) {
    return unsafe { { handle: handle_from_parts(parts) } };
}

Result<void, Error> expect_void_error(Result<void, Error> result) {
    switch (result) {
        case Ok:
            return Err(text_error("expected sqlite resource error"));
        case Err(_):
            return Ok;
    }
    return Err(text_error("bad sqlite result"));
}

Result<void, Error> expect_step_error(Result<sqlite::Step, Error> result) {
    switch (result) {
        case Ok(_):
            return Err(text_error("expected sqlite statement error"));
        case Err(_):
            return Ok;
    }
    return Err(text_error("bad sqlite step result"));
}

i32 main() {
    HandleParts connection_parts = must(resource::scoped<HandleParts>(|| {
        sqlite::Connection db = sqlite::open_memory()?;
        sqlite::exec(db, "CREATE TABLE t (id INTEGER)")?;
        return Ok(parts_from_handle(unsafe { db.handle }));
    }));
    sqlite::Connection stale_connection = connection_from_parts(connection_parts);
    must(expect_void_error(sqlite::exec(stale_connection, "SELECT 1")));

    sqlite::Connection db = must(sqlite::open_memory());
    must(sqlite::exec(db, "CREATE TABLE t (id INTEGER)"));
    HandleParts statement_parts = must(resource::scoped<HandleParts>(|| {
        sqlite::Statement statement = sqlite::prepare(db, "SELECT 1")?;
        return Ok(parts_from_handle(unsafe { statement.handle }));
    }));
    sqlite::Statement stale_statement = statement_from_parts(statement_parts);
    must(expect_step_error(sqlite::step(stale_statement)));
    must(sqlite::close(db));
    return 0;
}
