// ciel-test: run
// expect-exit: 42

extern "C" {
    opaque struct CielRoot;

    i32 ciel_thread_attach();
    void ciel_thread_detach();

    *CielRoot ciel_root_pin(*void value);
    *void ciel_root_get(*CielRoot root);
    void ciel_root_unpin(*CielRoot root);
}

i32 main() {
    ciel_thread_attach();
    i64 value = 42;
    *CielRoot root = ciel_root_pin(&value as *void);
    *i64 ptr = ciel_root_get(root) as *i64;
    i64 out = *ptr;
    ciel_root_unpin(root);
    ciel_thread_detach();
    return out as i32;
}
