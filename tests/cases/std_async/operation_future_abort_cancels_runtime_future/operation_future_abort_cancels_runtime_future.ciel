// ciel-test: run
// expect-exit: 0
// expect-stdout: 9

import /std/async as async;
import /std/async;
import /std/async/internal/adapter as adapter;
import /std/async_io as aio;
import /std/bytes as bytes;
import /std/c as c;
import /std/io as io;
import /std/os/fd as fd;
import /std/panic;
import /std/result;

#c_include "unistd.h"

unsafe extern "C" {
    opaque struct CielAsyncOp;
    opaque struct CielFuture;

    c::c_int pipe(*c::c_int fds);
    c::c_int close(c::c_int fd);
    c::c_int ciel_async_again_errno();
    c::c_int ciel_async_finish_read(*CielAsyncOp op, *?*u8 out, *usize len, *usize cap);
    c::c_int ciel_future_poll_trampoline(*CielFuture future, *void out);
}

*CielFuture raw_future<A: async::Awaitable<Result<bytes::Bytes, async::AsyncError>>>(
    *const A future
) {
    return unsafe {
        async::awaitable_future<Result<bytes::Bytes, async::AsyncError>>(future) as *CielFuture
    };
}

Result<aio::AsyncFd, Error> pipe_read_end(*c::c_int write_fd_out) {
    [2]c::c_int @fds = [0 as c::c_int;];
    c::c_int rc = unsafe { pipe(&fds[0]) };
    if ((rc as i64) != 0) {
        return Err(code_error(5));
    }
    *write_fd_out = fds[1];
    fd::RawFd raw = unsafe { fd::from_raw_fd(fds[0]) };
    return Ok(unsafe { aio::async_from_raw_fd(raw)? });
}

Result<usize, Error> drive() {
    c::c_int @write_fd = -1 as c::c_int;
    aio::AsyncFd read_fd = pipe_read_end(&write_fd)?;
    aio::AsyncRead read = aio::read_bytes_async(&read_fd, 8)?;
    ?*void raw_op_void = adapter::raw_operation(&read);
    if (raw_op_void == null) {
        return Err(code_error(80));
    }
    *CielAsyncOp raw_op = unsafe { raw_op_void as *CielAsyncOp };
    _ future = async::future_from_op(read);
    Result<bytes::Bytes, async::AsyncError> @out = Err(async::Runtime(0));
    c::c_int start = unsafe { ciel_future_poll_trampoline(raw_future(&future), &out as *void) };
    if (start != unsafe { ciel_async_again_errno() }) {
        return Err(code_error(81));
    }
    async::abort_future(&future)?;

    ?*u8 @raw = null;
    usize @len = 0;
    usize @cap = 0;
    c::c_int finish_rc = unsafe { ciel_async_finish_read(raw_op, &raw, &len, &cap) };
    aio::close_async(read_fd)?;
    _ close_writer = unsafe { close(write_fd) };
    if (finish_rc == unsafe { ciel_async_again_errno() }) {
        return Err(code_error(82));
    }
    return Ok(9);
}

i32 main() {
    must(io::print_value(must(drive())));
    return 0;
}
