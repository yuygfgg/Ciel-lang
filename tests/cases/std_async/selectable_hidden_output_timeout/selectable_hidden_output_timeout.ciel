// ciel-test: run
// expect-exit: 0

import /std/async as async;
import /std/async_time as async_time;
import /std/panic;
import /std/result;

Result<Out, async::AsyncError> drive_timeout<A: async::SelectableFuture<Out = _>>(A future) {
    return async::block_on(async::timeout(future, 100));
}

i32 main() {
    Result<void, async::AsyncError> slept = must(drive_timeout(async_time::sleep_ms(0)));
    must(slept);
    return 0;
}
