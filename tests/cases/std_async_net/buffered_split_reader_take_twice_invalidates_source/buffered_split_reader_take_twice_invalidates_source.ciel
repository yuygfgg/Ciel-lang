// ciel-test: run
// expect-exit: 0

import /std/async as async;
import /std/async_net as anet;
import /std/net as net;
import /std/result;

async Result<void, Error> accept_once(anet::AsyncTcpListener listener) {
    anet::AsyncTcpStream stream = await anet::accept(&listener)?;
    anet::close_stream(stream)?;
    return Ok;
}

async Result<void, Error> drive() {
    anet::AsyncTcpListener listener =
        anet::listen_async(net::parse_addr("127.0.0.1:0")?)?;
    net::SocketAddr bound = anet::listener_addr(&listener)?;
    async::Task<void, Error> server = async::spawn<void>(accept_once(listener))?;

    anet::AsyncTcpStream client = await anet::connect(bound)?;
    anet::AsyncTcpBufferedSplit @split = anet::buffered_split(client, 8)?;
    anet::BufferedStreamReader reader = anet::take_buffered_split_reader(&split)?;
    switch (anet::take_buffered_split_reader(&split)) {
        case Ok(_):
            return Err(code_error(91));
        case Err(_):
    }
    anet::AsyncTcpWriteHalf write = anet::take_buffered_split_write(&split)?;
    anet::shutdown_write_half(&write)?;
    anet::AsyncTcpReadHalf half = anet::into_read_half(reader)?;
    anet::shutdown_read_half(&half)?;
    await server?;
    return Ok;
}

i32 main() {
    must(async::block_on(drive()));
    return 0;
}
