// ciel-test: compile

import /std/async as async;
import /std/async_net as anet;
import /std/net as net;
import /std/result;

async Result<void, Error> accept_once(anet::AsyncTcpListener listener) {
    anet::AsyncTcpStream server = await anet::accept(&listener)?;
    anet::close_stream(server)?;
    return Ok;
}

async Result<usize, Error> drive() {
    anet::AsyncTcpListener listener =
        anet::listen_async(net::parse_addr("127.0.0.1:0")?)?;
    net::SocketAddr bound = anet::listener_addr(&listener)?;
    async::Task<void, Error> server = async::spawn<void>(accept_once(listener))?;
    anet::AsyncTcpStream client = await anet::connect_timeout(bound, 100)?;
    anet::close_stream(client)?;
    await server?;
    return Ok(1);
}

i32 main() {
    return 0;
}
