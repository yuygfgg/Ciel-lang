// ciel-test: run
// expect-exit: 0
// expect-stdout: 6

import /std/async as async;
import /std/async_net as anet;
import /std/async_time as async_time;
import /std/bytes as bytes;
import /std/io as io;
import /std/net as net;
import /std/panic;
import /std/result;

bool same_bytes([]u8 got, []const u8 want) {
    if (got.len != want.len) {
        return false;
    }
    usize @i = 0;
    while (i < want.len) {
        if (got[i] != want[i]) {
            return false;
        }
        i = i + 1;
    }
    return true;
}

async Result<void, Error> write_delayed_chunks(anet::AsyncTcpListener listener) {
    anet::AsyncTcpStream @server = await anet::accept(&listener)?;
    [2]u8 first = [1 as u8, 2 as u8];
    [4]u8 second = [3 as u8, 4 as u8, 5 as u8, 6 as u8];
    server = await anet::write_all(server, bytes::bytes_copy(first[..])?)?;
    await async_time::sleep_ms(80)?;
    server = await anet::write_all(server, bytes::bytes_copy(second[..])?)?;
    anet::shutdown_write(&server)?;
    anet::close_stream(server)?;
    return Ok;
}

async Result<usize, Error> drive() {
    net::SocketAddr addr = net::parse_addr("127.0.0.1:0")?;
    anet::AsyncTcpListener listener = anet::listen_async(addr)?;
    net::SocketAddr bound = anet::listener_addr(&listener)?;
    async::Task<void> server = async::spawn<void>(write_delayed_chunks(listener))?;

    anet::AsyncTcpStream client = await anet::connect(bound)?;
    anet::BufferedStreamReader reader = anet::buffered_reader_from_stream(client, 2)?;
    await async_time::sleep_ms(20)?;

    Result<Result<bytes::Bytes, anet::AsyncNetError>, async::AsyncError> timed =
        await async::timeout(anet::read_exact_buffered(&reader, 6), 20);
    switch (timed) {
        case Err(_):
            {}
        case Ok(_):
            return Err(code_error(90));
    }

    bytes::Bytes exact = await anet::read_exact_buffered(&reader, 6)?;
    [6]u8 @got = [0;];
    usize copied = bytes::bytes_copy_to(exact, got[..])?;
    [6]u8 want = [1 as u8, 2 as u8, 3 as u8, 4 as u8, 5 as u8, 6 as u8];
    if (copied != 6 || !same_bytes(got[..], want[..])) {
        return Err(code_error(91));
    }

    anet::AsyncTcpReadHalf half = anet::into_read_half(reader)?;
    anet::shutdown_read_half(&half)?;
    await server?;
    return Ok(copied);
}

i32 main() {
    must(io::print_value(must(async::block_on(drive()))));
    return 0;
}
