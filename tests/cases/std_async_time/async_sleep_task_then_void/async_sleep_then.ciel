// ciel-test: run
// expect-exit: 0
// expect-stdout: 7

import /std/async as flow;
import /std/async_time as atime;
import /std/channel;
import /std/io;
import /std/panic;
import /std/result;

i32 main() {
    Channel<i64> done = must(make_channel<i64>());
    flow::AsyncRunner<Channel<i64>> runner =
        must(flow::spawn_runner<Channel<i64>>(done));

    flow::AsyncTask<Channel<i64>, void> first =
        must(atime::sleep_ms_task<Channel<i64>>(1));
    flow::AsyncTask<Channel<i64>, void> delayed = flow::then(first, |void marker| {
        marker;
        return atime::sleep_ms_task<Channel<i64>>(0);
    });

    must(flow::start(runner, delayed, |Channel<i64> ch, void marker| {
        marker;
        channel_send(&ch, 7)?;
        return Ok(ch);
    }));

    i64 value = must(channel_recv(&done));
    must(print_value(value));

    must(flow::join_runner(&runner));
    must(channel_close(&done));
    return 0;
}
