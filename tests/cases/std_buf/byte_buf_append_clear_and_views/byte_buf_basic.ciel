// ciel-test: run
// expect-exit: 0

import /std/buf as buf;
import /std/bytes as bytes;
import /std/result;

bool is_discard_error(Result<void, buf::BufError> value) {
    switch (value) {
        case Ok:
            return false;
        case Err(error):
            switch (error) {
                case buf::DiscardOutOfBounds:
                    return true;
                case buf::CapacityOverflow:
                    return false;
                case buf::Runtime(_):
                    return false;
            }
    }
}

i64 main() {
    buf::ByteBuf @bytes = must(buf::byte_buf_new(4));
    if (bytes.buf::len() != 0) {
        return 1;
    }

    must(bytes.buf::push_slice([1 as u8, 2 as u8, 3 as u8]));
    if (bytes.buf::len() != 3) {
        return 2;
    }

    []const u8 readonly = bytes.buf::slice();
    if (readonly.len != 3 || readonly[0] != (1 as u8) ||
        readonly[2] != (3 as u8)) {
        return 3;
    }

    []u8 writable = bytes.buf::mut_slice();
    if (writable.len != 3) {
        return 4;
    }
    writable[1] = 9 as u8;

    []const u8 after_write = bytes.buf::slice();
    if (after_write[1] != (9 as u8)) {
        return 5;
    }

    bytes.buf::clear();
    if (bytes.buf::len() != 0) {
        return 6;
    }
    if (bytes.buf::slice().len != 0 || bytes.buf::mut_slice().len != 0) {
        return 7;
    }

    must(bytes.buf::push_slice([7 as u8, 8 as u8, 9 as u8, 10 as u8]));
    []const u8 reused = bytes.buf::slice();
    if (reused.len != 4 || reused[0] != (7 as u8) || reused[3] != (10 as u8)) {
        return 8;
    }

    must(bytes.buf::discard_prefix(2));
    []const u8 discarded = bytes.buf::slice();
    if (discarded.len != 2 || discarded[0] != (9 as u8) ||
        discarded[1] != (10 as u8)) {
        return 9;
    }

    must(bytes.buf::discard_prefix(0));
    if (bytes.buf::len() != 2) {
        return 10;
    }

    if (!is_discard_error(bytes.buf::discard_prefix(3))) {
        return 11;
    }

    must(bytes.buf::discard_prefix(2));
    if (bytes.buf::len() != 0 || bytes.buf::slice().len != 0) {
        return 12;
    }

    buf::ByteBuf @from_slice = must(
        buf::byte_buf_from_slice([11 as u8, 12 as u8])
    );
    if (from_slice.buf::len() != 2 || from_slice.buf::capacity() != 2) {
        return 13;
    }

    []u8 spare = must(from_slice.buf::spare_mut_slice(3));
    if (spare.len != 3) {
        return 14;
    }
    spare[0] = 13 as u8;
    spare[1] = 14 as u8;
    spare[2] = 15 as u8;
    must(from_slice.buf::commit_tail(3));

    []const u8 committed = from_slice.buf::slice();
    if (committed.len != 5 || committed[0] != (11 as u8) ||
        committed[4] != (15 as u8)) {
        return 15;
    }

    bytes::Bytes copied = must(from_slice.buf::to_bytes());
    []u8 copied_slice = must(bytes::bytes_to_slice(copied));
    if (copied_slice.len != 5 || copied_slice[1] != (12 as u8) ||
        copied_slice[3] != (14 as u8)) {
        return 16;
    }

    bytes::Bytes frozen = must(from_slice.buf::freeze());
    if (bytes::bytes_len(frozen) != 5) {
        return 17;
    }
    []u8 frozen_slice = must(bytes::bytes_to_slice(frozen));
    if (frozen_slice.len != 5 || frozen_slice[2] != (13 as u8) ||
        frozen_slice[4] != (15 as u8)) {
        return 18;
    }

    spare[0] = 99 as u8;
    spare[2] = 88 as u8;
    []u8 frozen_after_alias_write = must(bytes::bytes_to_slice(frozen));
    if (frozen_after_alias_write[2] != (13 as u8) ||
        frozen_after_alias_write[4] != (15 as u8)) {
        return 19;
    }

    return 0;
}
