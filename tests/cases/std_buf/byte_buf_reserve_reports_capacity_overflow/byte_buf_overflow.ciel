// ciel-test: run
// expect-exit: 0

import /std/buf as buf;
import /std/result;

bool is_err(Result<void, Error> value) {
    switch (value) {
        case Ok(_):
            return false;
        case Err(_):
            return true;
    }
}

i64 main() {
    buf::ByteBuf @bytes = must(buf::byte_buf_new(1));
    must(buf::byte_buf_push_slice(&bytes, [1 as u8]));
    if (!is_err(buf::byte_buf_reserve(&bytes, ~(0 as usize)))) {
        return 1;
    }
    []const u8 view = buf::byte_buf_slice(&bytes);
    if (view.len != 1 || view[0] != (1 as u8)) {
        return 2;
    }
    return 0;
}
