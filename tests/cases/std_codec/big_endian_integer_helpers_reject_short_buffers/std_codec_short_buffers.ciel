// ciel-test: run
// expect-exit: 0

import /std/codec as codec;
import /std/meta as meta;
import /std/result;

bool is_output_too_short(Result<void, codec::CodecError> result) {
    switch (result) {
        case Ok(_):
            return false;
        case Err(error):
            switch (error) {
                case codec::OutputTooShort:
                    return true;
                case codec::InputTooShort:
                    return false;
                case codec::UnsupportedIntegerWidth:
                    return false;
            }
    }
}

bool is_input_too_short_u16(Result<u16, codec::CodecError> result) {
    switch (result) {
        case Ok(_):
            return false;
        case Err(error):
            switch (error) {
                case codec::InputTooShort:
                    return true;
                case codec::OutputTooShort:
                    return false;
                case codec::UnsupportedIntegerWidth:
                    return false;
            }
    }
}

bool is_input_too_short_u32(Result<u32, codec::CodecError> result) {
    switch (result) {
        case Ok(_):
            return false;
        case Err(error):
            switch (error) {
                case codec::InputTooShort:
                    return true;
                case codec::OutputTooShort:
                    return false;
                case codec::UnsupportedIntegerWidth:
                    return false;
            }
    }
}

i64 main() {
    [4]u8 @buf = [0;];
    meta::Type<u16> u16_tag = {};
    meta::Type<u32> u32_tag = {};

    if (!is_output_too_short(codec::put_be(buf[..1], 1 as u16))) {
        return 1;
    }
    if (!is_output_too_short(codec::put_le(buf[..3], 1 as u32))) {
        return 2;
    }
    if (!is_input_too_short_u16(codec::get_be(u16_tag, buf[..1]))) {
        return 3;
    }
    if (!is_input_too_short_u32(codec::get_le(u32_tag, buf[..3]))) {
        return 4;
    }

    must(codec::put_be(buf[..2], 0xabcd as u16));
    must(codec::put_le(buf[..4], 0x01020304 as u32));

    return 0;
}
