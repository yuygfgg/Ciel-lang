// ciel-test: run
// expect-exit: 0

import /std/buf as buf;
import /std/crypto as crypto;
import /std/result;

bool bytes_eq([]const u8 left, []const u8 right) {
    if (left.len != right.len) {
        return false;
    }
    usize @i = 0;
    while (i < left.len) {
        if (left[i] != right[i]) {
            return false;
        }
        i = i + 1;
    }
    return true;
}

bool any_nonzero([]const u8 data) {
    usize @i = 0;
    while (i < data.len) {
        if (data[i] != (0 as u8)) {
            return true;
        }
        i = i + 1;
    }
    return false;
}

bool is_err_usize(Result<usize, Error> value) {
    switch (value) {
        case Ok(_):
            return false;
        case Err(_):
            return true;
    }
}

bool is_err_void(Result<void, Error> value) {
    switch (value) {
        case Ok(_):
            return false;
        case Err(_):
            return true;
    }
}

bool is_digit(char ch) {
    return ch == '0' || ch == '1' || ch == '2' || ch == '3' || ch == '4' ||
           ch == '5' || ch == '6' || ch == '7' || ch == '8' || ch == '9';
}

bool numeric_error_text([]const char text) {
    if (text.len == 0) {
        return false;
    }
    usize @i = 0;
    if (text[0] == '-') {
        i = 1;
    }
    if (i == text.len) {
        return false;
    }
    while (i < text.len) {
        if (!is_digit(text[i])) {
            return false;
        }
        i = i + 1;
    }
    return true;
}

i64 test_rng() {
    [16]u8 @first = [0;];
    [16]u8 @second = [0;];
    must(crypto::random_bytes(first[..]));
    must(crypto::random_bytes(second[..]));
    if (!any_nonzero(first[..]) && !any_nonzero(second[..])) {
        return 1;
    }

    buf::ByteBuf @empty = must(buf::byte_buf_new(0));
    must(crypto::random_bytes(buf::byte_buf_mut_slice(&empty)));

    crypto::SystemRng rng = must(crypto::system_rng());
    [8]u8 @from_handle = [0;];
    [8]u8 @from_handle_again = [0;];
    must(crypto::rng_random_bytes(rng, from_handle[..]));
    must(crypto::rng_random_bytes(rng, from_handle_again[..]));
    if (!any_nonzero(from_handle[..]) && !any_nonzero(from_handle_again[..])) {
        return 2;
    }
    return 0;
}

i64 test_hash() {
    [3]u8 abc = [0x61 as u8, 0x62 as u8, 0x63 as u8];
    [64]u8 @out = [0;];

    [16]u8 md5 = [
        0x90 as u8, 0x01 as u8, 0x50 as u8, 0x98 as u8,
        0x3c as u8, 0xd2 as u8, 0x4f as u8, 0xb0 as u8,
        0xd6 as u8, 0x96 as u8, 0x3f as u8, 0x7d as u8,
        0x28 as u8, 0xe1 as u8, 0x7f as u8, 0x72 as u8
    ];

    [32]u8 sha256 = [
        0xba as u8, 0x78 as u8, 0x16 as u8, 0xbf as u8,
        0x8f as u8, 0x01 as u8, 0xcf as u8, 0xea as u8,
        0x41 as u8, 0x41 as u8, 0x40 as u8, 0xde as u8,
        0x5d as u8, 0xae as u8, 0x22 as u8, 0x23 as u8,
        0xb0 as u8, 0x03 as u8, 0x61 as u8, 0xa3 as u8,
        0x96 as u8, 0x17 as u8, 0x7a as u8, 0x9c as u8,
        0xb4 as u8, 0x10 as u8, 0xff as u8, 0x61 as u8,
        0xf2 as u8, 0x00 as u8, 0x15 as u8, 0xad as u8
    ];

    [48]u8 sha384 = [
        0xcb as u8, 0x00 as u8, 0x75 as u8, 0x3f as u8,
        0x45 as u8, 0xa3 as u8, 0x5e as u8, 0x8b as u8,
        0xb5 as u8, 0xa0 as u8, 0x3d as u8, 0x69 as u8,
        0x9a as u8, 0xc6 as u8, 0x50 as u8, 0x07 as u8,
        0x27 as u8, 0x2c as u8, 0x32 as u8, 0xab as u8,
        0x0e as u8, 0xde as u8, 0xd1 as u8, 0x63 as u8,
        0x1a as u8, 0x8b as u8, 0x60 as u8, 0x5a as u8,
        0x43 as u8, 0xff as u8, 0x5b as u8, 0xed as u8,
        0x80 as u8, 0x86 as u8, 0x07 as u8, 0x2b as u8,
        0xa1 as u8, 0xe7 as u8, 0xcc as u8, 0x23 as u8,
        0x58 as u8, 0xba as u8, 0xec as u8, 0xa1 as u8,
        0x34 as u8, 0xc8 as u8, 0x25 as u8, 0xa7 as u8
    ];

    [64]u8 sha512 = [
        0xdd as u8, 0xaf as u8, 0x35 as u8, 0xa1 as u8,
        0x93 as u8, 0x61 as u8, 0x7a as u8, 0xba as u8,
        0xcc as u8, 0x41 as u8, 0x73 as u8, 0x49 as u8,
        0xae as u8, 0x20 as u8, 0x41 as u8, 0x31 as u8,
        0x12 as u8, 0xe6 as u8, 0xfa as u8, 0x4e as u8,
        0x89 as u8, 0xa9 as u8, 0x7e as u8, 0xa2 as u8,
        0x0a as u8, 0x9e as u8, 0xee as u8, 0xe6 as u8,
        0x4b as u8, 0x55 as u8, 0xd3 as u8, 0x9a as u8,
        0x21 as u8, 0x92 as u8, 0x99 as u8, 0x2a as u8,
        0x27 as u8, 0x4f as u8, 0xc1 as u8, 0xa8 as u8,
        0x36 as u8, 0xba as u8, 0x3c as u8, 0x23 as u8,
        0xa3 as u8, 0xfe as u8, 0xeb as u8, 0xbd as u8,
        0x45 as u8, 0x4d as u8, 0x44 as u8, 0x23 as u8,
        0x64 as u8, 0x3c as u8, 0xe8 as u8, 0x0e as u8,
        0x2a as u8, 0x9a as u8, 0xc9 as u8, 0x4f as u8,
        0xa5 as u8, 0x4c as u8, 0xa4 as u8, 0x9f as u8
    ];

    usize @written = must(crypto::hash_once_alg(crypto::Sha256, abc[..], out[..]));
    if (written != 32 || !bytes_eq(out[..written], sha256[..])) {
        return 10;
    }

    written = must(crypto::hash_once("SHA-384", abc[..], out[..]));
    if (written != 48 || !bytes_eq(out[..written], sha384[..])) {
        return 11;
    }

    written = must(crypto::hash_once("SHA-512", abc[..], out[..]));
    if (written != 64 || !bytes_eq(out[..written], sha512[..])) {
        return 12;
    }

    written = must(crypto::hash_once("MD5", abc[..], out[..]));
    if (written != 16 || !bytes_eq(out[..written], md5[..])) {
        return 18;
    }

    [8]u8 @short_out = [0;];
    if (!is_err_usize(crypto::hash_once("SHA-256", abc[..], short_out[..]))) {
        return 13;
    }
    Result<usize, Error> unknown_hash = crypto::hash_once("NO-SUCH-HASH", abc[..], out[..]);
    switch (unknown_hash) {
        case Ok(_):
            return 14;
        case Err(error):
            []const char message = error_message(&error);
            if (message.len == 0 || numeric_error_text(message)) {
                return 19;
            }
    }

    [8]char embedded_nul = [
        'S', 'H', 'A', '-', '2', '5', '6', '\0'
    ];
    if (!is_err_usize(crypto::hash_once(embedded_nul[..], abc[..], out[..]))) {
        return 15;
    }

    crypto::Hash hash = must(crypto::hash_new_alg(crypto::Sha256));
    must(crypto::hash_update(hash, abc[..1]));
    must(crypto::hash_update(hash, abc[1..]));
    written = must(crypto::hash_finish(hash, out[..]));
    if (written != 32 || !bytes_eq(out[..written], sha256[..])) {
        return 16;
    }
    must(crypto::hash_clear(hash));
    if (!is_err_void(crypto::hash_update(hash, abc[..]))) {
        return 17;
    }

    return 0;
}

i64 test_mac() {
    [20]u8 key = [0x0b as u8;];
    [16]u8 legacy_key = [0x0b as u8;];
    [8]u8 data = [
        0x48 as u8, 0x69 as u8, 0x20 as u8, 0x54 as u8,
        0x68 as u8, 0x65 as u8, 0x72 as u8, 0x65 as u8
    ];
    [64]u8 @out = [0;];

    [16]u8 hmac_md5 = [
        0x92 as u8, 0x94 as u8, 0x72 as u8, 0x7a as u8,
        0x36 as u8, 0x38 as u8, 0xbb as u8, 0x1c as u8,
        0x13 as u8, 0xf4 as u8, 0x8e as u8, 0xf8 as u8,
        0x15 as u8, 0x8b as u8, 0xfc as u8, 0x9d as u8
    ];

    [32]u8 hmac256 = [
        0xb0 as u8, 0x34 as u8, 0x4c as u8, 0x61 as u8,
        0xd8 as u8, 0xdb as u8, 0x38 as u8, 0x53 as u8,
        0x5c as u8, 0xa8 as u8, 0xaf as u8, 0xce as u8,
        0xaf as u8, 0x0b as u8, 0xf1 as u8, 0x2b as u8,
        0x88 as u8, 0x1d as u8, 0xc2 as u8, 0x00 as u8,
        0xc9 as u8, 0x83 as u8, 0x3d as u8, 0xa7 as u8,
        0x26 as u8, 0xe9 as u8, 0x37 as u8, 0x6c as u8,
        0x2e as u8, 0x32 as u8, 0xcf as u8, 0xf7 as u8
    ];

    [48]u8 hmac384 = [
        0xaf as u8, 0xd0 as u8, 0x39 as u8, 0x44 as u8,
        0xd8 as u8, 0x48 as u8, 0x95 as u8, 0x62 as u8,
        0x6b as u8, 0x08 as u8, 0x25 as u8, 0xf4 as u8,
        0xab as u8, 0x46 as u8, 0x90 as u8, 0x7f as u8,
        0x15 as u8, 0xf9 as u8, 0xda as u8, 0xdb as u8,
        0xe4 as u8, 0x10 as u8, 0x1e as u8, 0xc6 as u8,
        0x82 as u8, 0xaa as u8, 0x03 as u8, 0x4c as u8,
        0x7c as u8, 0xeb as u8, 0xc5 as u8, 0x9c as u8,
        0xfa as u8, 0xea as u8, 0x9e as u8, 0xa9 as u8,
        0x07 as u8, 0x6e as u8, 0xde as u8, 0x7f as u8,
        0x4a as u8, 0xf1 as u8, 0x52 as u8, 0xe8 as u8,
        0xb2 as u8, 0xfa as u8, 0x9c as u8, 0xb6 as u8
    ];

    [64]u8 hmac512 = [
        0x87 as u8, 0xaa as u8, 0x7c as u8, 0xde as u8,
        0xa5 as u8, 0xef as u8, 0x61 as u8, 0x9d as u8,
        0x4f as u8, 0xf0 as u8, 0xb4 as u8, 0x24 as u8,
        0x1a as u8, 0x1d as u8, 0x6c as u8, 0xb0 as u8,
        0x23 as u8, 0x79 as u8, 0xf4 as u8, 0xe2 as u8,
        0xce as u8, 0x4e as u8, 0xc2 as u8, 0x78 as u8,
        0x7a as u8, 0xd0 as u8, 0xb3 as u8, 0x05 as u8,
        0x45 as u8, 0xe1 as u8, 0x7c as u8, 0xde as u8,
        0xda as u8, 0xa8 as u8, 0x33 as u8, 0xb7 as u8,
        0xd6 as u8, 0xb8 as u8, 0xa7 as u8, 0x02 as u8,
        0x03 as u8, 0x8b as u8, 0x27 as u8, 0x4e as u8,
        0xae as u8, 0xa3 as u8, 0xf4 as u8, 0xe4 as u8,
        0xbe as u8, 0x9d as u8, 0x91 as u8, 0x4e as u8,
        0xeb as u8, 0x61 as u8, 0xf1 as u8, 0x70 as u8,
        0x2e as u8, 0x69 as u8, 0x6c as u8, 0x20 as u8,
        0x3a as u8, 0x12 as u8, 0x68 as u8, 0x54 as u8
    ];

    usize @written = must(crypto::mac_once_alg(crypto::HmacSha256, key[..], data[..], out[..]));
    if (written != 32 || !bytes_eq(out[..written], hmac256[..])) {
        return 20;
    }

    written = must(crypto::mac_once("HMAC(SHA-384)", key[..], data[..], out[..]));
    if (written != 48 || !bytes_eq(out[..written], hmac384[..])) {
        return 21;
    }

    written = must(crypto::mac_once("HMAC(SHA-512)", key[..], data[..], out[..]));
    if (written != 64 || !bytes_eq(out[..written], hmac512[..])) {
        return 22;
    }

    written = must(crypto::mac_once("HMAC(MD5)", legacy_key[..], data[..], out[..]));
    if (written != 16 || !bytes_eq(out[..written], hmac_md5[..])) {
        return 29;
    }

    [8]u8 @short_out = [0;];
    if (!is_err_usize(crypto::mac_once("HMAC(SHA-256)", key[..], data[..], short_out[..]))) {
        return 23;
    }
    if (!is_err_usize(crypto::mac_once("NO-SUCH-MAC", key[..], data[..], out[..]))) {
        return 24;
    }

    [20]u8 wrong_key = [0x0c as u8;];
    written = must(crypto::mac_once("HMAC(SHA-256)", wrong_key[..], data[..], out[..]));
    if (bytes_eq(out[..written], hmac256[..])) {
        return 25;
    }

    [8]u8 short_key = [1 as u8;];
    if (!is_err_usize(crypto::mac_once_alg(crypto::HmacSha256, short_key[..], data[..], out[..]))) {
        return 26;
    }

    crypto::Mac mac = must(crypto::mac_new_alg(crypto::HmacSha256, key[..]));
    must(crypto::mac_update(mac, data[..2]));
    must(crypto::mac_update(mac, data[2..]));
    written = must(crypto::mac_finish(mac, out[..]));
    if (written != 32 || !bytes_eq(out[..written], hmac256[..])) {
        return 27;
    }
    must(crypto::mac_clear(mac));
    if (!is_err_void(crypto::mac_update(mac, data[..]))) {
        return 28;
    }

    return 0;
}

i64 test_constant_time_eq() {
    [3]u8 same_a = [1 as u8, 2 as u8, 3 as u8];
    [3]u8 same_b = [1 as u8, 2 as u8, 3 as u8];
    [3]u8 different = [1 as u8, 2 as u8, 4 as u8];
    [2]u8 short = [1 as u8, 2 as u8];
    buf::ByteBuf @empty = must(buf::byte_buf_new(0));

    if (!crypto::constant_time_eq(same_a[..], same_b[..])) {
        return 30;
    }
    if (crypto::constant_time_eq(same_a[..], different[..])) {
        return 31;
    }
    if (crypto::constant_time_eq(same_a[..], short[..])) {
        return 32;
    }
    if (!crypto::constant_time_eq(buf::byte_buf_slice(&empty), buf::byte_buf_slice(&empty))) {
        return 33;
    }
    return 0;
}

i64 main() {
    i64 rng = test_rng();
    if (rng != 0) {
        return rng;
    }
    i64 hash = test_hash();
    if (hash != 0) {
        return hash;
    }
    i64 mac = test_mac();
    if (mac != 0) {
        return mac;
    }
    return test_constant_time_eq();
}
