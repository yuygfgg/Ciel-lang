// ciel-test: run
// expect-exit: 0
// expect-stdout: 5
// run-arg: @tmp/async_read_fixture.txt

import /std/lib;
import /std/async_io as aio;
import /std/bytes as bytes;
import /std/env as env;

Result<Channel<usize>, Error> handle(
    Channel<usize> out, usize expected_len
) {
    channel_send(&out, expected_len)?;
    return Ok(out);
}

i32 main() {
    []const char path = must(env::arg(1));
    must(
        with_create<void>(
            path, |file| {
                write_text(&file, "hello")?;
                return Ok;
            }
        )
    );

    Channel<usize> done = must(make_channel<usize>());
    Actor<usize> actor = must(
        spawn_actor_cloned<Channel<usize>, usize>(done, handle)
    );
    aio::AsyncFd fd = must(aio::open_async_read(path));
    aio::AsyncRead op = must(aio::read_bytes_async(&fd, 16));
    must(aio::notify_read_done(&op, &actor, 5));
    usize len = must(channel_recv(&done));
    bytes::Bytes bytes = must(aio::finish_read(op));
    if (bytes::bytes_len(bytes) != len) {
        return 1;
    }
    must(print_value(len));
    must(join(&actor));
    must(aio::close_async(fd));
    return 0;
}
