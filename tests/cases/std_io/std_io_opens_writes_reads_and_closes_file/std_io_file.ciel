// ciel-test: run
// expect-exit: 0
// expect-stdout: file-output

import /std/io;

i32 main() {
    must(with_create<void>("/tmp/ciel_std_io_fixture.txt", |file| {
        write_text(file, "file-output")?;
        return Ok;
    }));

    usize n = must(with_open_read<usize>("/tmp/ciel_std_io_fixture.txt", |file| {
        [32]u8 @buffer = [0;];
        usize read_count = read(file, buffer[..])?;
        return Ok(read_count);
    }));
    if (n != 11) {
        return 1;
    }
    must(print("{}", ["file-output"]));
    return 0;
}
