// ciel-test: run
// expect-exit: 7
// run-arg: @tmp/std_io_missing_file_should_not_exist

import /std/env as env;
import /std/io;

i32 main() {
    []const char path = must(env::arg(1));
    Result<void, IoWithError<IoError>> result = with_open_read<void, IoError>(
        path, |file| {
            return Ok;
        }
    );
    switch (result) {
        case Ok(_):
            return 1;
        case Err(error):
            return 7;
    }
}
