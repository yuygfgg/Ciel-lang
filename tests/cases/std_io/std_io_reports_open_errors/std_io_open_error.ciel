// ciel-test: run
// expect-exit: 7

import /std/io;

i32 main() {
    Result<void, Error> result = with_open_read("/tmp/ciel_std_io_missing_file_should_not_exist", |file| {
        return Ok;
    });
    switch (result) {
        case Ok(_):
            return 1;
        case Err(error):
            return 7;
    }
}
