// ciel-test: run
// expect-exit: 0
// run-arg: @tmp/std_io_infer_fixture.txt

import /std/env as env;
import /std/io;

i32 main() {
    []const char path = must(env::arg(1));
    must(
        with_create<void>(
            path, |file| {
                write_text(&file, "ok")?;
                return Ok;
            }
        )
    );

    usize n = must(
        with_open_read<usize>(
            path, |file| {
                [8]u8 @buffer = [0;];
                usize read_count = read(&file, buffer[..])?;
                return Ok(read_count);
            }
        )
    );
    if (n != 2) {
        return 1;
    }
    return 0;
}
