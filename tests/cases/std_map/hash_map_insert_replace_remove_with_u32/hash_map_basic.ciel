// ciel-test: run
// expect-exit: 0

import /std/map as map;
import /std/result;

i64 insert_code(map::InsertResult<i64> result) {
    switch (result) {
        case map::InsertResult::Inserted:
            return 0;
        case map::InsertResult::Replaced(value):
            return value;
    }
}

i64 remove_code(map::RemoveResult<i64> result) {
    switch (result) {
        case map::RemoveResult::Removed(value):
            return value;
        case map::RemoveResult::Missing:
            return -1;
    }
}

bool is_err(Result<i64, Error> value) {
    switch (value) {
        case Ok(ok):
            return false;
        case Err(error):
            return true;
    }
}

i64 main() {
    _ @table = must(map::hash_map_new<u32, i64>());
    if (table.map::len() != 0) {
        return 1;
    }

    if (insert_code(must(table.map::insert(7 as u32, 10))) != 0) {
        return 2;
    }
    if (table.map::len() != 1) {
        return 3;
    }
    if (!must(table.map::contains_key(7 as u32))) {
        return 4;
    }
    if (must(table.map::contains_key(8 as u32))) {
        return 5;
    }

    map::GetResult<i64> initial_get = must(table.map::get(7 as u32));
    switch (initial_get) {
        case map::GetResult::Found(value):
            if (value != 10) {
                return 15;
            }
        case map::GetResult::Missing:
            return 16;
    }

    if (insert_code(must(table.map::insert(7 as u32, 20))) != 10) {
        return 6;
    }
    if (table.map::len() != 1) {
        return 7;
    }

    i64 after_update = must(table.map::with(7 as u32, |value| {
        *value = *value + 5;
        return Ok(*value);
    }));
    if (after_update != 25) {
        return 8;
    }

    i64 read_back = must(table.map::with(7 as u32, |value| {
        return Ok(*value);
    }));
    if (read_back != 25) {
        return 9;
    }

    if (!is_err(table.map::with(9 as u32, |value| {
        return Ok(*value);
    }))) {
        return 10;
    }

    map::GetResult<i64> missing_get = must(table.map::get(9 as u32));
    switch (missing_get) {
        case map::GetResult::Found(_):
            return 17;
        case map::GetResult::Missing:
            {}
    }

    if (remove_code(must(table.map::remove(7 as u32))) != 25) {
        return 11;
    }
    if (remove_code(must(table.map::remove(7 as u32))) != -1) {
        return 12;
    }

    must(table.map::insert(1 as u32, 100));
    must(table.map::insert(2 as u32, 200));
    table.map::clear();
    if (table.map::len() != 0) {
        return 13;
    }
    if (must(table.map::contains_key(1 as u32))) {
        return 14;
    }

    return 0;
}
