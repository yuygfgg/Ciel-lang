// ciel-test: run
// expect-exit: 0

import /std/net as net;
import /std/resource as resource;
import /std/result;

struct HandleParts {
    u64 owner_id;
    u64 resource_id;
    u64 generation;
}

HandleParts parts_from_handle(*const resource::Handle handle) {
    return {
        owner_id: unsafe { handle->owner_id },
        resource_id: unsafe { handle->resource_id },
        generation: unsafe { handle->generation },
    };
}

resource::Handle handle_from_parts(HandleParts parts) {
    return unsafe {
        {
            owner_id: parts.owner_id,
            resource_id: parts.resource_id,
            generation: parts.generation,
        }
    };
}

net::TcpListener listener_from_parts(HandleParts parts) {
    return unsafe { { handle: handle_from_parts(parts) } };
}

bool is_void_err(Result<void, Error> result) {
    switch (result) {
        case Ok(_):
            return false;
        case Err(_):
            return true;
    }
}

bool is_stream_err(Result<net::TcpStream, Error> result) {
    switch (result) {
        case Ok(_):
            return false;
        case Err(_):
            return true;
    }
}

i32 main() {
    net::TcpListener listener = must(net::tcp_listen(must(net::parse_addr("127.0.0.1:0"))));
    HandleParts stale_parts = parts_from_handle(unsafe { &listener.handle });
    must(net::listener_close(listener));
    if (is_void_err(net::listener_close(listener_from_parts(stale_parts)))) {
        return 1;
    }
    net::TcpListener stale_listener = listener_from_parts(stale_parts);
    if (!is_stream_err(net::tcp_accept(&stale_listener))) {
        return 2;
    }
    return 0;
}
