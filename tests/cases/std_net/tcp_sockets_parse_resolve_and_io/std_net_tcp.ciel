// ciel-test: run
// expect-exit: 0

import /std/net as net;
import /std/result;

bool is_ip4(net::AddressFamily family) {
    switch (family) {
        case net::Ip4:
            return true;
        case net::Ip6:
            return false;
    }
    return false;
}

bool is_ip6(net::AddressFamily family) {
    switch (family) {
        case net::Ip4:
            return false;
        case net::Ip6:
            return true;
    }
    return false;
}

bool is_addr_err(Result<net::SocketAddr, Error> result) {
    switch (result) {
        case Ok(_):
            return false;
        case Err(_):
            return true;
    }
}

bool same_text([]const char left, []const char right) {
    if (left.len != right.len) {
        return false;
    }
    usize @i = 0;
    while (i < left.len) {
        if (left[i] != right[i]) {
            return false;
        }
        i = i + 1;
    }
    return true;
}

i32 test_parse_and_resolve() {
    net::SocketAddr v4 = must(net::parse_addr("127.0.0.1:8080"));
    if (!is_ip4(must(net::addr_family(v4)))) {
        return 1;
    }
    if (must(net::addr_port(v4)) != (8080 as u16)) {
        return 2;
    }
    if (!same_text(must(net::addr_to_string(v4)), "127.0.0.1:8080")) {
        return 3;
    }

    net::SocketAddr v6 = must(net::parse_addr("[::1]:9090"));
    if (!is_ip6(must(net::addr_family(v6)))) {
        return 4;
    }
    if (must(net::addr_port(v6)) != (9090 as u16)) {
        return 5;
    }

    if (!is_addr_err(net::parse_addr("localhost:80"))) {
        return 6;
    }
    if (!is_addr_err(net::parse_addr("127.0.0.1"))) {
        return 7;
    }
    if (!is_addr_err(net::parse_addr("127.0.0.1:70000"))) {
        return 8;
    }

    net::SocketAddr resolved = must(net::resolve_tcp("localhost", 12345 as u16));
    if (must(net::addr_port(resolved)) != (12345 as u16)) {
        return 9;
    }
    return 0;
}

i32 test_tcp_io() {
    net::TcpListener listener = must(net::tcp_listen(must(net::parse_addr("127.0.0.1:0"))));
    net::SocketAddr bound = must(net::listener_addr(listener));
    if (must(net::addr_port(bound)) == (0 as u16)) {
        return 10;
    }

    net::TcpStream client = must(net::tcp_connect(bound));
    net::TcpStream server = must(net::tcp_accept(listener));

    [5]u8 payload = [104 as u8, 101 as u8, 108 as u8, 108 as u8, 111 as u8];
    must(net::tcp_write_all(client, payload[..]));
    [8]u8 @buffer = [0;];
    usize @n = must(net::tcp_read(server, buffer[..]));
    if (n != 5) {
        return 11;
    }
    if (buffer[0] != payload[0] || buffer[1] != payload[1] || buffer[2] != payload[2] || buffer[3] != payload[3] || buffer[4] != payload[4]) {
        return 12;
    }

    [4]u8 reply = [112 as u8, 111 as u8, 110 as u8, 103 as u8];
    must(net::tcp_write_all(server, reply[..]));
    [4]u8 @reply_in = [0;];
    n = must(net::tcp_read(client, reply_in[..]));
    if (n != 4 || reply_in[0] != reply[0] || reply_in[1] != reply[1] || reply_in[2] != reply[2] || reply_in[3] != reply[3]) {
        return 13;
    }

    must(net::tcp_shutdown_write(client));
    n = must(net::tcp_read(server, buffer[..]));
    if (n != 0) {
        return 14;
    }

    must(net::tcp_close(client));
    must(net::tcp_close(server));
    must(net::listener_close(listener));
    return 0;
}

Result<i32, Error> with_api_body(net::TcpListener listener) {
    u16 port = net::addr_port(net::listener_addr(listener)?)?;
    return net::with_tcp_connect_host<i32>("127.0.0.1", port, |client| {
        net::TcpStream server = net::tcp_accept(listener)?;
        defer net::tcp_close(server);
        [1]u8 one = [42 as u8];
        net::tcp_write_all(client, one[..])?;
        [1]u8 @got = [0;];
        usize n = net::tcp_read(server, got[..])?;
        if (n != 1 || got[0] != (42 as u8)) {
            return Ok(15);
        }
        return Ok(0);
    });
}

i32 test_with_apis() {
    i32 result = must(net::with_tcp_listen<i32>(must(net::parse_addr("127.0.0.1:0")), with_api_body));
    if (result != 0) {
        return result;
    }
    return 0;
}

i32 main() {
    i32 @result = test_parse_and_resolve();
    if (result != 0) {
        return result;
    }
    result = test_tcp_io();
    if (result != 0) {
        return result;
    }
    return test_with_apis();
}
