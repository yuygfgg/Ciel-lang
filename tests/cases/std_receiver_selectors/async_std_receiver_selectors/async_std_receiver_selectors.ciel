// ciel-test: compile

import /std/lib;

Result<void, Error> use_async_io_tokens(
    AsyncRead read_notify,
    AsyncRead read_finish,
    AsyncRead read_cancel,
    AsyncWrite write_notify,
    AsyncWrite write_finish,
    AsyncWrite write_cancel,
    Actor<i64> actor
) {
    read_notify.notify_done(&actor, 1)?;
    write_notify.notify_done(&actor, 2)?;
    read_finish.finish()?;
    write_finish.finish()?;
    read_cancel.cancel()?;
    write_cancel.cancel()?;
    return Ok;
}

Result<void, Error> use_sleep_token(
    AsyncSleep sleep_notify,
    AsyncSleep sleep_finish,
    AsyncSleep sleep_cancel,
    Actor<i64> actor
) {
    sleep_notify.notify_done(&actor, 3)?;
    sleep_finish.finish()?;
    sleep_cancel.cancel()?;
    return Ok;
}

Result<void, Error> use_async_net_tokens(
    AsyncAccept accept_notify,
    AsyncAccept accept_finish,
    AsyncAccept accept_cancel,
    AsyncConnect connect_notify,
    AsyncConnect connect_finish,
    AsyncConnect connect_cancel,
    AsyncTcpRead read_notify,
    AsyncTcpRead read_finish,
    AsyncTcpRead read_cancel,
    AsyncTcpWrite write_notify,
    AsyncTcpWrite write_finish,
    AsyncTcpWrite write_cancel,
    AsyncBufferedRead buffered_op,
    Actor<i64> actor
) {
    accept_notify.notify_done(&actor, 4)?;
    connect_notify.notify_done(&actor, 5)?;
    read_notify.notify_done(&actor, 6)?;
    write_notify.notify_done(&actor, 7)?;
    accept_finish.finish()?;
    connect_finish.finish()?;
    read_finish.finish()?;
    write_finish.finish()?;
    accept_cancel.cancel()?;
    connect_cancel.cancel()?;
    read_cancel.cancel()?;
    write_cancel.cancel()?;
    buffered_op.cancel()?;
    return Ok;
}

async Result<void, Error> use_async_fd(AsyncFd fd, Bytes data) {
    AsyncRead read_op = fd.read_async(64)?;
    read_op.cancel()?;
    AsyncWrite write_op = fd.write_async(data)?;
    write_op.cancel()?;
    Bytes read_bytes = await fd.read(64)?;
    usize written = await fd.write(data)?;
    if (read_bytes.len() > written) {
        fd.close()?;
    }
    return Ok;
}

async Result<void, Error> use_async_tcp(
    SocketAddr addr,
    AsyncTcpListener listener,
    AsyncTcpStream @stream,
    AsyncTcpStream stream_for_split,
    AsyncTcpReadHalf read_half,
    AsyncTcpReadHalf read_half_for_buffer,
    AsyncTcpWriteHalf @write_half,
    BufferedStreamReader reader,
    Bytes data
) {
    AsyncTcpListener fresh_listener = addr.listen_async()?;
    fresh_listener.close()?;
    AsyncConnect connect_op = addr.connect_async()?;
    connect_op.cancel()?;
    AsyncTcpStream timed = await addr.connect_timeout(10)?;
    timed.close()?;

    listener.addr()?;
    AsyncAccept accept_op = listener.accept_async()?;
    accept_op.cancel()?;
    listener.close()?;

    stream.local_addr()?;
    stream.peer_addr()?;
    AsyncTcpSplit split = stream_for_split.split()?;
    BufferedStreamReader owned_reader = split.buffered_reader(4096)?;
    AsyncTcpRead read_op = stream.read_async(64)?;
    read_op.cancel()?;
    AsyncTcpReadInto read_into_op = stream.read_into_async(data)?;
    read_into_op.cancel()?;
    AsyncTcpWrite write_op = stream.write_async(data)?;
    write_op.cancel()?;
    Bytes got = await stream.read(64)?;
    ReadIntoResult into_result = await stream.read_into(data)?;
    usize written = await stream.write(data)?;
    stream = await stream.write_all(data)?;
    if (got.len() + into_result.read + written > data.len()) {
        stream.shutdown_read()?;
    }
    stream.shutdown_write()?;
    stream.close()?;

    read_half.shutdown_read()?;
    AsyncBufferedRead buffered = owned_reader.read_async(64)?;
    buffered.cancel()?;
    AsyncBufferedRead exact = owned_reader.read_exact_async(4)?;
    exact.cancel()?;
    BufferedStreamReader owned_reader2 = read_half_for_buffer.buffered_reader(4096)?;
    owned_reader2.into_read_half()?;
    Bytes buffered_bytes = await reader.read(64)?;
    Bytes exact_bytes = await reader.read_exact(4)?;
    if (buffered_bytes.len() + exact_bytes.len() > data.len()) {
        reader.into_read_half()?;
    }

    AsyncTcpWrite half_write = write_half.write_async(data)?;
    half_write.cancel()?;
    await write_half.write(data)?;
    write_half = await write_half.write_all(data)?;
    write_half.shutdown_write()?;
    return Ok;
}

i32 main() {
    return 0;
}
