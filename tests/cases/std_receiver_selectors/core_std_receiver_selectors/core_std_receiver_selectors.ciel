// ciel-test: run
// expect-exit: 0

import /std/lib;

struct AddOne {}

struct IsEven {}

impl update_value<i64, i64, SyncError>(*const AddOne updater, i64 value) {
    return Ok({
        value: value + 1,
        result: value + 1,
    });
}

impl map_call<i64, i64>(*AddOne mapper, i64 value) {
    return value + 1;
}

impl filter_accept<i64>(*IsEven predicate, *const i64 value) {
    return ((*value) % 2) == 0;
}

i64 sum_i64_slice([]const i64 items) {
    i64 @total = 0;
    usize @i = 0;
    while (i < items.len) {
        total = total + items[i];
        i = i + 1;
    }
    return total;
}

i64 sum_u8_slice([]const u8 items) {
    i64 @total = 0;
    usize @i = 0;
    while (i < items.len) {
        total = total + (items[i] as i64);
        i = i + 1;
    }
    return total;
}

i64 main() {
    Result<i64, Error> ok = Ok(7);
    if (ok.must() != 7) {
        return 1;
    }
    if (ok.expect("expected ok") != 7) {
        return 2;
    }

    Error err = text_error("base").with_context("ctx");
    if (err.message().len != 3) {
        return 3;
    }

    Bytes bytes = bytes_from_text("abc").must();
    if (bytes.len() != 3) {
        return 4;
    }
    if (bytes.const_slice().len != 3) {
        return 5;
    }
    Bytes tail = bytes.slice(1, 2).must();
    if (tail.len() != 2) {
        return 6;
    }
    [4]u8 @out = [0;];
    if (bytes.copy_to(out[..]).must() != 3) {
        return 7;
    }
    [4]char @chars = ['\0';];
    if (bytes.copy_to_chars(chars[..]).must() != 3) {
        return 8;
    }
    [1]u8 prefix = [88 as u8];
    Bytes prefixed = bytes.prepend(prefix[..]).must();
    if (prefixed.len() != 4) {
        return 9;
    }
    Bytes appended = bytes.append(tail).must();
    if (appended.len() != 5) {
        return 10;
    }
    if (appended.to_slice().must().len != 5) {
        return 11;
    }

    Text text = text_copy("hello").must();
    if (text.len() != 5) {
        return 12;
    }
    if (text.to_bytes().must().len() != 5) {
        return 13;
    }
    if (text.to_chars().must().len != 5) {
        return 14;
    }
    if (text.slice().must().len != 5) {
        return 15;
    }

    Channel<i64> channel = make_channel<i64>().must();
    channel.send(42).must();
    if (channel.recv().must() != 42) {
        return 16;
    }
    channel.close().must();

    Mutex<i64> mutex = make_mutex<i64>(5).must();
    AddOne updater = {};
    Result<i64, SyncWithError<SyncError>> updated_result = mutex.update(&updater);
    if (updated_result.must() != 6) {
        return 17;
    }
    Result<i64, SyncWithError<SyncError>> with_result = mutex.with(|slot| {
        *slot = *slot + 2;
        return Ok(*slot);
    });
    if (with_result.must() != 8) {
        return 18;
    }

    Atomic<i64> atomic = make_atomic<i64>(10).must();
    if (atomic.load(SeqCst).must() != 10) {
        return 19;
    }
    atomic.store(20, SeqCst).must();
    if (atomic.exchange(30, SeqCst).must() != 20) {
        return 20;
    }
    CompareExchange<i64> exchanged =
        atomic.compare_exchange(30, 40, SeqCst, Acquire).must();
    if (!exchanged.exchanged || exchanged.previous != 30) {
        return 21;
    }
    if (atomic.fetch_add(2, SeqCst).must() != 40) {
        return 22;
    }
    if (atomic.fetch_sub(1, SeqCst).must() != 42) {
        return 23;
    }
    if (atomic.load(SeqCst).must() != 41) {
        return 24;
    }

    SharedMap<u32, i64> shared = shared_map_new<u32, i64>().must();
    shared.insert(3 as u32, 9).must();
    if (shared.len().must() != 1) {
        return 25;
    }
    SharedMapGet<i64> found = shared.get(3 as u32).must();
    switch (found) {
        case SharedMapGet::Found(value):
            if (value != 9) {
                return 26;
            }
        case SharedMapGet::Missing:
            return 27;
    }
    shared.remove(3 as u32).must();
    if (shared.len().must() != 0) {
        return 28;
    }
    switch (shared.pop_any().must()) {
        case SharedMapPop::Item(key, value):
            return 29;
        case SharedMapPop::Empty:
            {}
    }

    Vec<i64> @numbers = vec_new<i64>(0).must();
    numbers.reserve(2).must();
    numbers.push(3).must();
    numbers.push(5).must();
    if (numbers.len() != 2 || numbers.capacity() < 2) {
        return 30;
    }
    *const i64 first = numbers.at(0).must();
    *i64 second = numbers.mut_at(1).must();
    *second = 6;
    []i64 mutable_numbers = numbers.mut_slice();
    mutable_numbers[0] = 2;
    if (*first != 2 || numbers.slice()[1] != 6) {
        return 31;
    }

    AddOne add = {};
    IsEven even = {};
    [5]i64 raw = [1, 2, 3, 4, 5];
    Result<Vec<i64>, VecError> selector_collected_result =
        raw[..].iter().filter(even).map(add).collect();
    Vec<i64> selector_collected = selector_collected_result.must();
    Result<Vec<i64>, VecError> ordinary_collected_result =
        collect<Vec<i64>>(map(filter(slice_iter(raw[..]), even), add));
    Vec<i64> ordinary_collected = ordinary_collected_result.must();
    if (
        selector_collected.len() != ordinary_collected.len() ||
        sum_i64_slice(selector_collected.slice()) != sum_i64_slice(ordinary_collected.slice())
    ) {
        return 32;
    }
    if (selector_collected.len() != 2 || sum_i64_slice(selector_collected.slice()) != 8) {
        return 33;
    }

    i64 selector_fold =
        range(0, 6).filter(even).map(add).take(2).fold(0, |i64 acc, i64 value| {
            return acc + value;
        });
    i64 ordinary_fold = fold(
        take(map(filter(range(0, 6), even), add), 2),
        0,
        |i64 acc, i64 value| {
            return acc + value;
        }
    );
    if (selector_fold != ordinary_fold || selector_fold != 4) {
        return 34;
    }

    Result<Vec<i64>, VecError> vec_iter_result = numbers.iter().collect();
    Vec<i64> vec_iter_values = vec_iter_result.must();
    if (vec_iter_values.len() != 2 || sum_i64_slice(vec_iter_values.slice()) != 8) {
        return 35;
    }
    Result<Vec<u8>, VecError> byte_iter_result = bytes.iter().collect();
    Vec<u8> byte_iter_values = byte_iter_result.must();
    if (byte_iter_values.len() != 3 || sum_u8_slice(byte_iter_values.slice()) != 294) {
        return 36;
    }
    if (text.chars().count() != 5) {
        return 37;
    }
    numbers.clear();
    if (numbers.len() != 0 || numbers.slice().len != 0) {
        return 38;
    }

    return 0;
}
