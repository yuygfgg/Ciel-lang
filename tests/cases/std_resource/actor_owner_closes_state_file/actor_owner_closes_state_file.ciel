// ciel-test: run
// expect-exit: 0
// run-arg: @tmp/std_resource_actor_owner.txt

import /std/actor;
import /std/channel;
import /std/env as env;
import /std/io as io;
import /std/message;
import /std/result;
import /std/resource as resource;

struct HandleParts {
    u64 owner_id;
    u64 resource_id;
    u64 generation;
}

unsafe impl clone_message(*const HandleParts value) {
    return Ok(*value);
}

enum Command {
    Snapshot(void),
}

unsafe impl clone_message(*const Command value) {
    return Ok(*value);
}

resource struct OwnedState {
    io::File file;
    Channel<HandleParts> out;
}

HandleParts parts_from_handle(
    resource::Handle handle
) {
    return {
        owner_id: unsafe { handle.owner_id },
        resource_id: unsafe { handle.resource_id },
        generation: unsafe { handle.generation },
    };
}

io::File file_from_parts(HandleParts parts) {
    resource::Handle handle = unsafe {
        {
            owner_id: parts.owner_id,
            resource_id: parts.resource_id,
            generation: parts.generation,
        }
    };
    return unsafe { { handle: handle } };
}

Result<OwnedState, Error> init_state(
    Channel<HandleParts> out
) {
    []const char path = env::arg(1)?;
    return Ok({
        file: io::open_read(path)?,
        out: out,
    }
    );
}

Result<void, Error> handle(
    *OwnedState state, Actor<Command> self, Command command
) {
    switch (command) {
        case Snapshot(_):
            channel_send(
                &state->out, parts_from_handle(unsafe { state->file.handle })
            )?;
            stop(&self)?;
            return Ok;
    }
}

i32 main() {
    []const char path = must(env::arg(1));
    must(
        io::with_create<void>(
            path, |file| {
                io::write_text(&file, "actor-owned")?;
                return Ok;
            }
        )
    );

    Channel<HandleParts> out = must(make_channel<HandleParts>());
    Actor<Command> actor = must(
        spawn_actor_state<OwnedState, Command>(
            || init_state(out),
            handle
        )
    );
    must(send(&actor, Snapshot));
    HandleParts parts = must(channel_recv(&out));
    must(join(&actor));
    must(channel_close(&out));

    io::File stale = file_from_parts(parts);
    [1]u8 @buffer = [0;];
    switch (io::read(&stale, buffer[..])) {
        case Ok(_):
            return 1;
        case Err(_):
            return 0;
    }
}
