// ciel-test: run
// expect-exit: 0
// run-arg: @tmp/std_resource_async_descriptor_quota.txt

import /std/async_io as aio;
import /std/async_net as anet;
import /std/env as env;
import /std/io as io;
import /std/net as net;
import /std/result;
import /std/resource as resource;

i32 main() {
    []const char path = must(env::arg(1));
    must(io::with_create<void>(path, |file| {
        io::write_text(file, "quota")?;
        return Ok;
    }));

    resource::Limits limits = {
        max_resources: 8,
        max_child_owners: 16,
        max_pending_ops: 16,
        max_descriptors: 1,
    };
    must(resource::scoped_with_limits<void>(limits, || {
        aio::AsyncFd first = aio::open_async_read(path)?;
        net::SocketAddr addr = net::parse_addr("127.0.0.1:0")?;
        switch (anet::listen_async(addr)) {
            case Ok(listener):
                anet::close_listener(listener)?;
                aio::close_async(first)?;
                return Err(text_error("quota accepted async listener after async fd"));
            case Err(_):
                aio::close_async(first)?;
                return Ok;
        }
    }));
    return 0;
}
