// ciel-test: run
// expect-exit: 0
// run-arg: @tmp/std_resource_erased_future_passthrough_cleanup.txt

import /std/async as async;
import /std/async_time as async_time;
import /std/env as env;
import /std/io as io;
import /std/resource as resource;
import /std/result;

async Result<void, Error> hold_file(io::File @file) {
    await async_time::sleep_ms(10000)?;
    io::close(file)?;
    return Ok;
}

async::Future<Result<void, Error>> pass(async::Future<Result<void, Error>> future) {
    return future;
}

i32 main() {
    []const char path = must(env::arg(1));
    must(io::with_create<void>(path, |file| {
        io::write_text(&file, "future cleanup")?;
        return Ok;
    }));

    resource::Limits limits = {
        max_resources: 8,
        max_child_owners: 16,
        max_pending_ops: 16,
        max_descriptors: 1,
    };
    must(resource::scoped_with_limits<void>(limits, || {
        {
            io::File file = io::open_read(path)?;
            _ future = pass(hold_file(file));
        }
        io::File again = io::open_read(path)?;
        io::close(again)?;
        return Ok;
    }));
    return 0;
}
