// ciel-test: run
// expect-exit: 0
// run-arg: @tmp/std_resource_expr_closure_returns_resource_param.txt

import /std/env as env;
import /std/io as io;
import /std/result;

io::File pass_through(
    io::File |(io::File)| body, io::File @file
) {
    return body(file);
}

i32 main() {
    []const char path = must(env::arg(1));
    must(
        io::with_create<void>(
            path, |file| {
                io::write_text(&file, "closure-return")?;
                return Ok;
            }
        )
    );

    io::File file = must(io::open_read(path));
    io::File returned = pass_through(|file| file, file);
    [16]u8 @buffer = [0;];
    usize n = must(io::read(&returned, buffer[..]));
    if (n != 14) {
        return 1;
    }
    must(io::close(returned));
    return 0;
}
