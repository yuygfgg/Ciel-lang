// ciel-test: error
// expect-error: cannot move resource subvalue of type `File`

import /std/io as io;
import /std/result;

resource struct Holder {
    io::File file;
}

Result<void, Error> drive([]const char path) {
    Holder holder = { file: io::open_read(path)? };
    io::File file = holder.file;
    io::close(file)?;
    return Ok;
}

i32 main() {
    return 0;
}
