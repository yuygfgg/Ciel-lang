// ciel-test: error
// expect-error: resource_free_marker

import /std/async_net as anet;
import /std/net as net;
import /std/result;
import /std/resource as resource;

Result<anet::AsyncTcpListener, Error> leak_async_listener() {
    return resource::scoped<anet::AsyncTcpListener>(|| {
        net::SocketAddr addr = net::parse_addr("127.0.0.1:0")?;
        return anet::listen_async(addr);
    });
}

i32 main() {
    return 0;
}
