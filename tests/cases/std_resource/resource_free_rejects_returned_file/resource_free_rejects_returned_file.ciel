// ciel-test: error
// expect-error: resource_free_marker
// expect-error: resource_handle_marker

import /std/io as io;
import /std/result;
import /std/resource as resource;

Result<io::File, Error> leak_file([]const char path) {
    return resource::scoped<io::File>(|| {
        return io::open_read(path);
    });
}

i32 main() {
    return 0;
}
