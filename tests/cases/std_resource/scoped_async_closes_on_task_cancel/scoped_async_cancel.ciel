// ciel-test: run
// expect-exit: 0
// run-arg: @tmp/std_resource_scoped_async_cancel.txt

import /std/async as async;
import /std/async_time as async_time;
import /std/env as env;
import /std/io as io;
import /std/message;
import /std/result;
import /std/resource as resource;

struct HandleParts {
    u64 owner_id;
    u64 resource_id;
    u64 generation;
}

unsafe impl clone_message(*const HandleParts value) {
    return Ok(*value);
}

HandleParts parts_from_handle(resource::Handle handle) {
    return {
        owner_id: unsafe { handle.owner_id },
        resource_id: unsafe { handle.resource_id },
        generation: unsafe { handle.generation },
    };
}

io::File file_from_parts(HandleParts parts) {
    resource::Handle handle = unsafe {
        {
            owner_id: parts.owner_id,
            resource_id: parts.resource_id,
            generation: parts.generation,
        }
    };
    return unsafe { { handle: handle } };
}

async Result<void, Error> scoped_worker(async::Sender<HandleParts> sender) {
    await resource::scoped_async<void, Error>(async || {
        []const char path = env::arg(1)?;
        io::File file = io::open_read(path)?;
        async::try_send<HandleParts>(sender, parts_from_handle(unsafe { file.handle }))?;
        await async_time::sleep_ms(10000)?;
        return Ok;
    })?;
    return Ok;
}

i32 main() {
    []const char path = must(env::arg(1));
    must(io::with_create<void>(path, |file| {
        io::write_text(&file, "cancel-scope")?;
        return Ok;
    }));

    async::ChannelPair<HandleParts> pair = must(async::channel<HandleParts>(1));
    async::Task<void> task = must(async::spawn<void>(scoped_worker(pair.sender)));
    HandleParts parts = must(async::block_on(async::recv<HandleParts>(pair.receiver)));
    must(async::cancel<void>(&task));
    must(async::close<HandleParts>(pair.sender));
    must(async::close_receiver<HandleParts>(pair.receiver));

    io::File stale = file_from_parts(parts);
    [1]u8 @buffer = [0;];
    switch (io::read(&stale, buffer[..])) {
        case Ok(_):
            return 1;
        case Err(_):
            return 0;
    }
}
