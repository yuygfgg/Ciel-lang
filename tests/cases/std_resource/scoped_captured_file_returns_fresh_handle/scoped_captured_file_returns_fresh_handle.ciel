// ciel-test: run
// expect-exit: 0
// run-arg: @tmp/std_resource_scoped_captured_file.txt

import /std/env as env;
import /std/io as io;
import /std/resource as resource;
import /std/result;

Result<io::File, Error> open_via_scoped_capture([]const char path) {
    io::File file = io::open_read(path)?;
    io::File returned = resource::scoped<io::File, Error>(|| {
        return Ok(file);
    })?;
    return Ok(returned);
}

i32 main() {
    []const char path = must(env::arg(1));
    must(io::with_create<void>(path, |file| {
        io::write_text(&file, "captured")?;
        return Ok;
    }));

    io::File file = must(open_via_scoped_capture(path));
    [16]u8 @buffer = [0;];
    usize n = must(io::read(&file, buffer[..]));
    if (n != 8) {
        return 1;
    }
    must(io::close(file));
    return 0;
}
