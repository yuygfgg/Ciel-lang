// ciel-test: run
// expect-exit: 0
// run-arg: @tmp/std_resource_scope.txt

import /std/env as env;
import /std/io as io;
import /std/result;
import /std/resource as resource;

struct HandleParts {
    u64 owner_id;
    u64 resource_id;
    u64 generation;
}

HandleParts parts_from_handle(
    resource::Handle handle
) {
    return {
        owner_id: unsafe { handle.owner_id },
        resource_id: unsafe { handle.resource_id },
        generation: unsafe { handle.generation },
    };
}

io::File file_from_parts(HandleParts parts) {
    resource::Handle handle = unsafe {
        {
            owner_id: parts.owner_id,
            resource_id: parts.resource_id,
            generation: parts.generation,
        }
    };
    return unsafe { { handle: handle } };
}

Result<HandleParts, Error> open_deep(
    []const char path
) {
    io::File file = io::open_read(path)?;
    return Ok(parts_from_handle(unsafe { file.handle }));
}

i32 main() {
    []const char path = must(env::arg(1));
    must(
        io::with_create<void>(
            path, |file| {
                io::write_text(&file, "x")?;
                return Ok;
            }
        )
    );

    HandleParts parts = must(
        resource::scoped<HandleParts>(|| {
            return open_deep(path);
        })
    );
    io::File stale = file_from_parts(parts);

    [1]u8 @buffer = [0;];
    switch (io::read(&stale, buffer[..])) {
        case Ok(_):
            return 1;
        case Err(_):
            return 0;
    }
}
