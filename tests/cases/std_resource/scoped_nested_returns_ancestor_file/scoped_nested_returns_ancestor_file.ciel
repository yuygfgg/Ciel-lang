// ciel-test: run
// expect-exit: 0
// run-arg: @tmp/std_resource_scoped_nested_returns_ancestor_file.txt

import /std/env as env;
import /std/io as io;
import /std/resource as resource;
import /std/result;

Result<io::File, Error> return_from_nested_scope(io::File @file) {
    return resource::scoped<io::File>(|| {
        return resource::scoped<io::File>(|| {
            return Ok(file);
        });
    });
}

i32 main() {
    []const char path = must(env::arg(1));
    must(io::with_create<void>(path, |file| {
        io::write_text(&file, "nested-scope")?;
        return Ok;
    }));

    io::File root_file = must(io::open_read(path));
    io::File returned = must(return_from_nested_scope(root_file));
    [16]u8 @buffer = [0;];
    usize n = must(io::read(&returned, buffer[..]));
    if (n != 12) {
        return 1;
    }
    must(io::close(returned));
    return 0;
}
