// ciel-test: run
// expect-exit: 0
// run-arg: @tmp/std_resource_switch_moves_resource_payload.txt

import /std/env as env;
import /std/io as io;
import /std/result;

Result<io::File, io::IoError> pass_through(
    Result<io::File, io::IoError> input
) {
    switch (input) {
        case Ok(file):
            return Ok(file);
        case Err(error):
            return Err(error);
    }
}

i32 main() {
    []const char path = must(env::arg(1));
    must(
        io::with_create<void>(
            path, |file| {
                io::write_text(&file, "switch")?;
                return Ok;
            }
        )
    );

    io::File file = must(pass_through(io::open_read(path)));
    [8]u8 @buffer = [0;];
    usize n = must(io::read(&file, buffer[..]));
    if (n != 6) {
        return 1;
    }
    must(io::close(file));
    return 0;
}
