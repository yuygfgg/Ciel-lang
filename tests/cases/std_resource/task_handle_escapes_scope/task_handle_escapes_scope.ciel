// ciel-test: run
// expect-exit: 0

import /std/async as async;
import /std/async_time as async_time;
import /std/result;
import /std/resource as resource;

async Result<usize, Error> delayed_value() {
    await async_time::sleep_ms(1)?;
    return Ok(42);
}

Result<async::Task<usize>, Error> spawn_inside_scope() {
    async::Task<usize> task = resource::scoped<async::Task<usize>>(|| {
        async::Task<usize> task = async::spawn<usize>(delayed_value())?;
        return Ok(task);
    })?;
    return Ok(task);
}

i32 main() {
    async::Task<usize> task = must(spawn_inside_scope());
    usize value = must(async::block_on(task));
    if (value != 42) {
        return 1;
    }
    return 0;
}
