// ciel-test: run
// expect-exit: 0
// run-arg: @tmp/std_resource_task_owner.txt

import /std/async as async;
import /std/env as env;
import /std/io as io;
import /std/message;
import /std/result;
import /std/resource as resource;
import /std/text as text;

struct HandleParts {
    u64 owner_id;
    u64 resource_id;
    u64 generation;
}

unsafe impl clone_message(*const HandleParts value) {
    return Ok(*value);
}

HandleParts parts_from_handle(resource::Handle handle) {
    return {
        owner_id: unsafe { handle.owner_id },
        resource_id: unsafe { handle.resource_id },
        generation: unsafe { handle.generation },
    };
}

io::File file_from_parts(HandleParts parts) {
    resource::Handle handle = unsafe {
        {
            owner_id: parts.owner_id,
            resource_id: parts.resource_id,
            generation: parts.generation,
        }
    };
    return unsafe { { handle: handle } };
}

async Result<HandleParts, Error> open_in_task(text::Text path) {
    io::File file = io::open_read(text::text_to_slice(path)?)?;
    return Ok(parts_from_handle(unsafe { file.handle }));
}

i32 main() {
    []const char path = must(env::arg(1));
    must(io::with_create<void>(path, |file| {
        io::write_text(&file, "t")?;
        return Ok;
    }));

    text::Text owned_path = must(text::text_copy(path));
    async::Task<HandleParts, Error> task = must(async::spawn<HandleParts>(open_in_task(owned_path)));
    HandleParts parts = must(async::block_on(task));
    io::File stale = file_from_parts(parts);

    [1]u8 @buffer = [0;];
    switch (io::read(&stale, buffer[..])) {
        case Ok(_):
            return 1;
        case Err(_):
            return 0;
    }
}
