// ciel-test: run
// expect-exit: 0
// run-arg: @tmp/std_resource_unawaited_future_cleanup.txt

import /std/async_io as aio;
import /std/async_time as async_time;
import /std/env as env;
import /std/io as io;
import /std/resource as resource;
import /std/result;

async Result<void, Error> hold_file(aio::AsyncFd @file) {
    await async_time::sleep_ms(10000)?;
    aio::close_async(file)?;
    return Ok;
}

i32 main() {
    []const char path = must(env::arg(1));
    must(io::with_create<void>(path, |file| {
        io::write_text(&file, "future cleanup")?;
        return Ok;
    }));

    resource::Limits limits = {
        max_resources: 8,
        max_child_owners: 16,
        max_pending_ops: 16,
        max_descriptors: 1,
    };
    must(resource::scoped_with_limits<void>(limits, || {
        {
            aio::AsyncFd file = aio::open_async_read(path)?;
            _ future = hold_file(file);
        }
        aio::AsyncFd again = aio::open_async_read(path)?;
        aio::close_async(again)?;
        return Ok;
    }));
    return 0;
}
