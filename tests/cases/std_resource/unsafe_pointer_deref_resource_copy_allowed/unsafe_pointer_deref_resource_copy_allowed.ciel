// ciel-test: run
// expect-exit: 0

resource unsafe struct RawToken {
    i64 value;
}

i32 main() {
    RawToken token = unsafe { { value: 7 } };
    *const RawToken pointer = &token;
    RawToken copied = unsafe { *pointer };
    if (unsafe { copied.value } != 7) {
        return 1;
    }
    return 0;
}
