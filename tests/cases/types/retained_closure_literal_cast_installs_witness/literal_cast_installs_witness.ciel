// ciel-test: run
// expect-exit: 9

import /std/lib;

T clone_value<T: Message>(T value) {
    T local = value;
    return must(clone_message(&local));
}

i64 main() {
    i64 offset = 4;
    i64 |(i64): Message| callback = (|i64 value| value + offset) as i64 |(i64): Message|;
    i64 |(i64): Message| copy = clone_value(callback);
    return copy(5);
}
