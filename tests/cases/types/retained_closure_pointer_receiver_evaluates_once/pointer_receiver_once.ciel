// ciel-test: run
// expect-exit: 108

import /std/lib;

interface<T> i64 score(*T value);

impl<T: Message> score(*T value) {
    return (*value)(2);
}

struct PickState {
    usize idx;
}

*(i64 |(i64): Message + score|) pick(
    *[2](i64 |(i64): Message + score|) handlers,
    *PickState state,
) {
    usize idx = state->idx;
    state->idx = state->idx + 1;
    return &(*handlers)[idx];
}

i64 main() {
    i64 left_base = 4;
    i64 right_base = 100;
    i64 |(i64): Message + score| left = |i64 value| value + left_base;
    i64 |(i64): Message + score| right = |i64 value| value + right_base;
    [2](i64 |(i64): Message + score|) handlers = [left, right];
    PickState state = { idx: 0 };
    return score(pick(&handlers, &state)) + (state.idx as i64) + handlers[1](1);
}
