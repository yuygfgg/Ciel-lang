// ciel-test: run
// expect-exit: 17

import /std/lib;

type Op = i64 fn(i64);

interface<T> i64 score(*T value);

impl score(*Op value) {
    Op op = *value;
    return op(4);
}

impl<T: Message> score(*T value) {
    return 101;
}

i64 plus_five(i64 value) {
    return value + 5;
}

i64 main() {
    i64 |(i64): Message + score| retained = plus_five;
    return retained(3) + score(&retained);
}
