// ciel-test: run
// expect-exit: 8

import /std/lib;

interface<T> T duplicate(*T value);

impl<T: Message> duplicate(*T value) {
    return *value;
}

i64 main() {
    i64 @base = 3;
    i64 |(i64): Message + duplicate| handler = |i64 value| value + base;
    i64 |(i64): Message + duplicate| copied = duplicate(&handler);
    base = 100;
    return copied(5);
}
